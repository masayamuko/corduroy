---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, COMPANY } from '../lib/constants';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  legalName: COMPANY.legalName,
  url: SITE.url,
  email: COMPANY.email,
  telephone: COMPANY.phone,
  address: {
    '@type': 'PostalAddress',
    addressLocality: '福岡市',
    addressRegion: '福岡県',
    addressCountry: 'JP',
  },
};

const strengths = [
  {
    iconPath: '<path d="M2.06 12.35a1 1 0 0 1 0-.7 11.7 11.7 0 0 1 19.88 0 1 1 0 0 1 0 .7 11.7 11.7 0 0 1-19.88 0Z"/><circle cx="12" cy="12" r="3"/>',
    title: '受け入れたあとが、見える',
    body: '採用後の生活・仕事・心の動きを、月次レポートで雇用主に共有。「定着しているか分からない」を解消します。',
  },
  {
    iconPath: '<path d="m11 17 2 2a2.8 2.8 0 0 0 4 0l2-2"/><path d="m14 14 2.5 2.5a2.8 2.8 0 0 0 4 0 2.8 2.8 0 0 0 0-4L16 8l-2.5 2.5a2.1 2.1 0 0 1-3 0 2.1 2.1 0 0 1 0-3L13 5"/><path d="m7 8 4-3 3 3"/><path d="m2 12 5-5 4 4"/><path d="m22 12-5-5-4 4"/>',
    title: '福岡で根を張るコミュニティ',
    body: '地域ボランティア・先輩同郷者・自治体と連携。困ったときに頼れる「もう一つの家族」を一緒に作ります。',
  },
  {
    iconPath: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z"/>',
    title: 'インドネシア特化',
    body: 'P3MI等の現地側制度、宗教文化、言語面の確認事項を整理。受入企業と本人の説明内容をそろえます。',
  },
];

const numbers = [
  { value: '13,943', label: '福岡県内 特定技能在留者数（2025年）', source: '出入国在留管理庁' },
  { value: '22.6%', label: '在留外国人のうちインドネシア人材の比率', source: '同上 (全国2位)' },
  { value: '10+α', label: '義務的支援10項目に加えてプラスαの定着支援', source: '当社サービス' },
];

const flow = [
  { step: '01', title: '無料相談', body: '受け入れ業種・人数・時期をヒアリング' },
  { step: '02', title: '採用導線の確認', body: '候補者情報、技能・日本語要件、送出経路を確認' },
  { step: '03', title: '受け入れ準備', body: 'ビザ・住居・初期オリエンテーション' },
  { step: '04', title: '定着支援', body: '義務的10項目＋コミュニティ・国際交流イベント' },
];

const industries = [
  ['介護', '/industries/介護/', '利用者対応、申し送り、夜勤、介護記録、家族対応、食事・礼拝配慮を確認します。'],
  ['外食', '/industries/外食/', '食品衛生、HACCP、アレルゲン、接客日本語、まかない、深夜交通を整理します。'],
  ['建設', '/industries/建設/', '現場安全、保護具、朝礼、危険表示、現場移動、建設分野固有手続きを確認します。'],
];

const faqPreview = [
  ['義務的支援10項目はすべて必要ですか？', '必要です。支援計画に基づき、本人が理解できる言語で実施できる体制を整えます。'],
  ['面談はどのくらいの頻度ですか？', '制度上は3か月に1回以上、本人と監督者への定期面談が必要です。運用上は月次確認も設計します。'],
  ['インドネシア人材の宗教配慮は必要ですか？', '礼拝、食事、ラマダン期の働き方などを、職場のルールに合わせて事前に確認します。'],
];
---
<BaseLayout jsonLd={orgJsonLd}>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">特定技能・インドネシア人材 | 福岡</p>
        <h1>受け入れたあとが、<br/>見える。</h1>
        <p class="lead">
          特定技能の受け入れで、いちばん不安なのは「受け入れたあと」。<br/>
          わたしたちは、義務的支援10項目に加えて、地域コミュニティと一緒に
          定着状況を記録・共有する登録支援機関です。
        </p>
        <div class="hero-cta">
          <a href="/contact/" class="btn btn-primary">無料相談する</a>
          <a href="/services/" class="btn btn-secondary">サービスを見る</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <svg class="support-timeline" viewBox="0 0 420 320" aria-hidden="true">
          <rect x="18" y="16" width="384" height="288" rx="24" fill="#fff"/>
          <path d="M92 72v176" fill="none" stroke="#E89F4A" stroke-width="4" stroke-linecap="round"/>
          <g>
            <circle cx="92" cy="72" r="18" fill="#E89F4A"/>
            <path d="M84 72h16M92 64v16" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
            <text x="128" y="66">入国前</text>
            <text x="128" y="88" class="muted">条件・生活説明を整理</text>
          </g>
          <g>
            <circle cx="92" cy="130" r="18" fill="#2D5F3F"/>
            <path d="M84 130h16" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
            <text x="128" y="124">3か月</text>
            <text x="128" y="146" class="muted">職場と生活の初期確認</text>
          </g>
          <g>
            <circle cx="92" cy="188" r="18" fill="#0F3057"/>
            <path d="m84 188 6 6 12-14" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <text x="128" y="182">6か月</text>
            <text x="128" y="204" class="muted">定着状況を月次共有</text>
          </g>
          <g>
            <circle cx="92" cy="248" r="18" fill="#E89F4A"/>
            <path d="M85 248h14M92 241v14" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
            <text x="128" y="242">1年</text>
            <text x="128" y="264" class="muted">継続雇用の課題を更新</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <section class="section industries">
    <div class="container">
      <div class="section-head">
        <p class="section-eyebrow">Industry Preparation</p>
        <h2 class="section-title">業種別の受け入れ準備</h2>
      </div>
      <div class="industry-grid">
        {industries.map(([title, href, body], index) => (
          <article class="card">
            <svg class="card-icon" viewBox="0 0 24 24" aria-hidden="true">
              {index === 0 && <><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></>}
              {index === 1 && <><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></>}
              {index === 2 && <><path d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2H2v2Z"/><path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M4 15v-3a6 6 0 0 1 6-6"/><path d="M14 6a6 6 0 0 1 6 6v3"/></>}
            </svg>
            <h3>{title}</h3>
            <p>{body}</p>
            <a href={href}>詳しく見る</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 3 STRENGTHS -->
  <section class="section strengths">
    <div class="container">
      <p class="section-eyebrow">Core Strengths</p>
      <h2 class="section-title">わたしたちの3つの強み</h2>
      <div class="strengths-grid">
        {strengths.map((s) => (
          <article class="strength-card card">
            <svg class="strength-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={s.iconPath} />
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section faq-preview">
    <div class="container">
      <p class="section-eyebrow">FAQ</p>
      <h2 class="section-title">よくある質問</h2>
      <div class="faq-list">
        {faqPreview.map(([q, a]) => (
          <details>
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
      <p class="center-link"><a href="/faq/">FAQをすべて見る</a></p>
    </div>
  </section>

  <!-- NUMBERS -->
  <section class="section numbers">
    <div class="container">
      <p class="section-eyebrow">Fukuoka Market</p>
      <h2 class="section-title">数字で見る、福岡の特定技能</h2>
      <div class="numbers-grid">
        {numbers.map((n) => (
          <div class="number-card">
            <div class="number-value">{n.value}</div>
            <div class="number-label">{n.label}</div>
            <div class="number-source">出典: {n.source}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FLOW -->
  <section class="section flow">
    <div class="container">
      <p class="section-eyebrow">Onboarding Flow</p>
      <h2 class="section-title">受け入れまでの流れ</h2>
      <ol class="flow-list">
        {flow.map((f) => (
          <li class="flow-item">
            <svg class="flow-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6v6l4 2"/><circle cx="12" cy="12" r="10"/></svg>
            <div class="flow-step">{f.step}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="section bottom-cta">
    <div class="container">
      <div class="cta-box">
        <h2>まずは、話を聞いてみてください</h2>
        <p>受け入れの不安・疑問、何でもお話しください。営業はしません。</p>
        <a href="/contact/" class="btn btn-primary">無料相談する</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--c-sand) 0%, var(--c-off-white) 100%);
    border-bottom: 3px solid transparent;
    border-image: linear-gradient(90deg, var(--c-orange), var(--c-orange-dark), transparent) 1;
    padding: 80px 0 100px;
  }
  .hero-inner {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-inner { grid-template-columns: 1.4fr 1fr; }
  }
  .eyebrow {
    color: var(--c-orange-dark);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    margin: 0 0 16px;
  }
  .hero h1 {
    font-size: clamp(36px, 7vw, 64px);
    line-height: 1.2;
    margin: 0 0 24px;
  }
  .lead { font-size: 17px; max-width: 560px; }
  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .hero-visual {
    position: relative;
    min-height: 280px;
  }
  .support-timeline {
    width: min(100%, 420px);
    filter: drop-shadow(0 14px 30px rgba(15, 48, 87, 0.12));
  }
  .support-timeline text {
    fill: var(--c-navy);
    font-size: 18px;
    font-weight: 800;
  }
  .support-timeline .muted {
    fill: var(--c-muted);
    font-size: 13px;
    font-weight: 600;
  }
  @media (max-width: 1023px) {
    .hero-visual { display: none; }
  }

  .section-title {
    text-align: center;
    margin-top: 0;
    margin-bottom: 42px;
  }
  .section-head {
    max-width: 760px;
    margin: 0 auto 42px;
    text-align: center;
  }
  .section-head .section-title {
    margin-bottom: 0;
  }
  .industries { background: var(--c-white); }
  .strengths { background: var(--section-alt-bg); }
  .faq-preview { background: var(--c-white); }
  .numbers { background: var(--c-off-white); }
  .flow { background: var(--c-white); }
  .strengths-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .strengths-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .strength-icon,
  .card-icon,
  .flow-icon {
    width: 42px;
    height: 42px;
    margin-bottom: 14px;
    fill: none;
    stroke: var(--c-orange-dark);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .strength-card .strength-icon {
    display: block;
    margin-bottom: 12px;
  }
  .strength-card h3 { font-size: 20px; }
  .industry-grid .card-icon {
    width: 32px;
    height: 32px;
  }

  .industry-grid {
    display: grid;
    gap: 20px;
  }
  .industry-grid .card {
    border-left: 0 solid var(--c-orange);
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-left-width 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .industry-grid .card:hover {
    border-left-width: 4px;
  }
  @media (min-width: 860px) {
    .industry-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .numbers-grid {
    display: grid;
    gap: 40px;
    grid-template-columns: 1fr;
    text-align: center;
  }
  @media (min-width: 768px) {
    .numbers-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .number-value {
    font-size: clamp(40px, 7vw, 60px);
    font-weight: 800;
    color: var(--c-orange);
    line-height: 1;
  }
  .number-label {
    margin-top: 12px;
    font-weight: 600;
    color: var(--c-body);
  }
  .number-source {
    margin-top: 8px;
    font-size: 12px;
    color: var(--c-muted);
  }

  .flow-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
    grid-template-columns: 1fr;
    counter-reset: flow;
  }
  @media (min-width: 768px) {
    .flow-list { grid-template-columns: repeat(4, 1fr); }
  }
  .flow-item {
    background: var(--c-white);
    border-radius: var(--radius-card);
    padding: 28px;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .flow-item:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }
  .flow-step {
    font-family: var(--font-serif);
    color: var(--c-orange);
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .flow-item h3 { font-size: 18px; }
  .faq-list {
    max-width: 860px;
    margin: 0 auto;
  }
  details {
    background: var(--c-white);
    padding: 18px 22px;
    border-radius: 10px;
    margin-bottom: 12px;
    box-shadow: var(--shadow-card);
  }
  summary {
    color: var(--c-navy);
    cursor: pointer;
    font-weight: 800;
  }
  .center-link { text-align: center; margin-top: 20px; }
  .center-link a {
    color: var(--c-orange-dark);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 800;
    padding: 4px;
    text-decoration: none;
  }
  .center-link a::after {
    content: "→";
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .center-link a:hover::after {
    transform: translateX(4px);
  }

  .bottom-cta { background: var(--c-sand); }
  .cta-box {
    text-align: center;
    background: var(--c-white);
    padding: 56px 24px;
    border-radius: 16px;
    box-shadow: var(--shadow-card);
  }
  .cta-box h2 { margin-bottom: 16px; }
</style>
