---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../lib/constants';

const programs = [
  ['国際交流イベント', '福岡で暮らす日本人、インドネシア人、受入企業が自然に出会える場を準備し、開催実績を積み上げます。'],
  ['生活オリエンテーション後のフォロー', '初日に説明して終わりではなく、実際に暮らし始めてから出る困りごとを拾います。'],
  ['地域ボランティア連携', '日本語、買い物、病院、休日の過ごし方など、地域の人とつながる導線を整えます。'],
  ['企業向け共有レポート', 'イベント参加、相談内容、定着の兆しを月次で整理し、受入企業へ共有します。'],
];

const breadcrumb = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE.url },
  { '@type': 'ListItem', position: 2, name: 'コミュニティ', item: `${SITE.url}/community/` },
] };
---
<BaseLayout title="コミュニティ" description="福岡で働くインドネシア人材が孤立しないよう、国際交流イベント、地域ボランティア、月次レポートで定着を支援します。" jsonLd={breadcrumb}>
  <section class="hero"><div class="container hero-inner"><div><p class="eyebrow">Community</p><h1>職場の外にも、相談できる場所を。</h1><p class="lead">人は、仕事だけで定着するわけではありません。休日に話せる相手、母国語で相談しやすい場、地域の人とつながる機会。福岡での暮らしが見えるよう、コミュニティ運営を支援に組み込みます。</p></div><div class="note"><strong>義務的支援10項目 + α</strong><p>コミュニティは制度上の支援を置き換えるものではありません。必要な支援を実施したうえで、孤立を防ぐ追加の取り組みとして準備・運営します。</p></div></div></section>
  <section class="section"><div class="container"><h2 class="center">コミュニティ支援の4つの柱</h2><div class="grid">{programs.map(([title, body]) => <article class="card"><h3>{title}</h3><p>{body}</p></article>)}</div></div></section>
  <section class="section band"><div class="container two-col"><div><p class="eyebrow">Monthly Report</p><h2>「会社の外で何が起きているか」を共有します。</h2></div><div><p>受入企業が見えにくいのは、勤務後や休日の生活です。生活リズム、相談内容、地域との接点、本人の表情の変化を、守秘に配慮しながら共有します。</p><p>困りごとが大きくなる前に、企業・本人・支援担当者の三者で調整できる状態をつくることが目的です。</p></div></div></section>
  <section class="section"><div class="container timeline"><h2>運営イメージ</h2><ol><li><span>来日前</span>福岡での生活、宗教・食事、住居、交通を説明</li><li><span>来日直後</span>買い物、通勤、行政手続き、相談先を確認</li><li><span>1か月目</span>本人面談と企業面談で初期不安を整理</li><li><span>3か月目以降</span>地域イベントや同郷者との接点を増やす</li></ol></div></section>
  <section class="section band"><div class="container two-col"><div><p class="eyebrow">Status</p><h2>準備中・予定・運営方針を分けて管理します。</h2></div><div><ul class="status-list"><li><strong>準備中:</strong> 地域協力者、会場候補、相談導線の確認</li><li><strong>予定:</strong> 受入企業・本人の参加可能日を踏まえた交流機会の設計</li><li><strong>運営方針:</strong> 相談内容は守秘に配慮し、企業共有は本人の不利益にならない範囲で整理</li></ul></div></div></section>
  <section class="section bottom-cta"><div class="container cta-box"><h2>定着の仕組みを、採用前から設計します。</h2><p>職場だけでなく、生活と地域の接点まで含めて受け入れ計画をつくります。</p><a href="/contact/" class="btn btn-primary">相談する</a></div></section>
</BaseLayout>
<style>
  .hero{background:linear-gradient(135deg,var(--c-sand),var(--c-off-white));padding:72px 0}.hero-inner{display:grid;gap:32px}@media(min-width:900px){.hero-inner{grid-template-columns:1.2fr .8fr;align-items:center}}.eyebrow{color:var(--c-orange-dark);font-weight:800;letter-spacing:.1em;font-size:13px}.lead{font-size:18px;max-width:820px}.note{background:var(--c-navy);color:var(--c-white);padding:28px;border-radius:var(--radius-card)}.note strong{color:var(--c-orange);font-size:22px}.note p{margin:10px 0 0}.center{text-align:center}.grid{display:grid;gap:20px;margin-top:36px}@media(min-width:860px){.grid{grid-template-columns:repeat(4,1fr)}}.band{background:var(--c-white)}.two-col{display:grid;gap:32px}@media(min-width:900px){.two-col{grid-template-columns:.8fr 1.2fr}}.timeline{max-width:900px}.timeline ol{display:grid;gap:14px;padding:0;list-style:none}.timeline li{background:var(--c-white);padding:20px;border-radius:var(--radius-card);box-shadow:var(--shadow-card)}.timeline span{display:block;color:var(--c-orange-dark);font-weight:800}.status-list{background:var(--c-off-white);border-radius:var(--radius-card);padding:24px 24px 24px 44px;box-shadow:var(--shadow-card)}.bottom-cta{background:var(--c-sand);text-align:center}
</style>
