---
/**
 * Breadcrumb.astro — 共通パンくずコンポーネント（視覚パンくず専任）
 *
 * 使い方（ブログ記事・最頻パターン）:
 *   <Breadcrumb title={pageTitle} />
 *   → TOP / ブログ / {pageTitle}（現在地）を出力。
 *
 * 多階層（services 等）で階層を明示したい場合:
 *   <Breadcrumb items={[
 *     { label: "TOP", href: "/" },
 *     { label: "サービス", href: "/services/" },
 *     { label: "AI顧問" }          // href なし = 現在地
 *   ]} />
 *
 * 注意:
 * - JSON-LD（BreadcrumbList）はこのコンポーネントに入れない。
 *   全記事が head 側で既に出力済みのため、二重出力を避ける。
 * - 区切り "/" は CSS（li::after）で描画。DOM テキストにしない。
 */
interface Crumb {
  label: string;
  href?: string; // 省略時は現在地（aria-current）
}

interface Props {
  title?: string;        // ブログ用: 現在地の記事タイトル
  items?: Crumb[];       // 多階層用: 明示的なパンくず配列（title より優先）
  className?: string;
}

const { title, items, className = "" } = Astro.props;

// items 未指定なら title からブログ階層を生成
const crumbs: Crumb[] =
  items ?? [
    { label: "TOP", href: "/" },
    { label: "ブログ", href: "/blog/" },
    { label: title ?? "" }, // href なし = 現在地
  ];
---
<nav class={`breadcrumb fade-up ${className}`.trim()} aria-label="パンくずリスト">
  <ol>
    {crumbs.map((c) =>
      c.href ? (
        <li><a href={c.href}>{c.label}</a></li>
      ) : (
        <li><span aria-current="page">{c.label}</span></li>
      )
    )}
  </ol>
</nav>

<style>
  .breadcrumb {
    font-size: 12.5px;
    color: var(--text-light);
    margin-bottom: 32px;
  }
  .breadcrumb ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .breadcrumb li {
    display: inline-flex;
    align-items: center;
  }
  .breadcrumb li:not(:last-child)::after {
    content: "/";
    margin-left: 8px;
    opacity: 0.5;
  }
  .breadcrumb a {
    color: var(--sea);
    font-weight: 600;
  }
  .breadcrumb a:hover {
    text-decoration: underline;
  }
  .breadcrumb [aria-current="page"] {
    opacity: 0.7;
  }
</style>
