---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// import ChatWidget from '../components/ChatWidget.jsx';

interface Props {
	title: string;
	description?: string;
    canonicalUrl?: string;
    ogUrl?: string;
    ogImage?: string;
    ogType?: string;
}

const { 
    title, 
    description, 
    canonicalUrl, 
    ogUrl, 
    ogImage = "https://www.corduroy.co.jp/assets/images/ogp.png",
    ogType = "website"
} = Astro.props;

const siteBase = Astro.site?.href ?? "https://www.corduroy.co.jp";
const rawPath = Astro.url?.pathname ?? "/";
const normalizedPath = rawPath
  .replace(/\/index\.html$/i, "/")
  .replace(/\.html$/i, "")
  .replace(/\/?$/, "/");
const pageUrl = new URL(normalizedPath, siteBase).href;
const resolvedCanonicalUrl = canonicalUrl ?? pageUrl;
const resolvedOgUrl = ogUrl ?? pageUrl;
---

<!doctype html>
<html lang="ja">
	<head>
		<!-- Google tag (gtag.js) -->
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GTLHM3EM7C"></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            gtag('js', new Date());

            gtag('config', 'G-GTLHM3EM7C');
        </script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/x-icon" href="/assets/images/faviconC.ico" />
		<meta name="robots" content="max-image-preview:large" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description || "AIとの関係性を育てる、本質的な学びと伴走。AI顧問・AI講座・AIコミュニティで、想いに寄り添いながら小さく試して広げます。"} />
		<link rel="canonical" href={resolvedCanonicalUrl} />
        
        <meta property="og:type" content={ogType}>
        <meta property="og:url" content={resolvedOgUrl}>
        <meta property="og:title" content={title}>
        <meta property="og:description" content={description || "AIとの関係性を育てる、本質的な学びと伴走。AI顧問・AI講座・AIコミュニティで、想いに寄り添いながら小さく試して広げます。"}>
        <meta property="og:image" content={ogImage}>
        <meta property="og:locale" content="ja_JP">
        <meta property="og:site_name" content="株式会社コールテン">

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:url" content={resolvedOgUrl}>
        <meta name="twitter:title" content={title}>
        <meta name="twitter:description" content={description || "AIとの関係性を育てる、本質的な学びと伴走。AI顧問・AI講座・AIコミュニティで、想いに寄り添いながら小さく試して広げます。"}>
        <meta name="twitter:image" content={ogImage}>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" href="/assets/fonts/craftmincho.woff2" as="font" type="font/woff2" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Klee+One:wght@400;600&family=Space+Grotesk:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap">
		<link href="https://fonts.googleapis.com/css2?family=Klee+One:wght@400;600&family=Space+Grotesk:wght@400;500;700&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">

        <!-- Organization & WebSite Schema.org -->
        <script type="application/ld+json" is:inline set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "Organization",
                    "@id": "https://www.corduroy.co.jp/#organization",
                    "name": "株式会社コールテン",
                    "alternateName": "Corduroy Inc.",
                    "url": "https://www.corduroy.co.jp/",
                    "logo": "https://www.corduroy.co.jp/assets/images/logo.png",
                    "description": "AIとの関係性を育てる、本質的な学びと伴走。AI顧問・AI講座・AIコミュニティで、想いに寄り添いながら小さく試して広げます。",
                    "legalName": "株式会社コールテン",
                    "foundingDate": "2025-11-21",
                    "address": {
                        "@type": "PostalAddress",
                        "addressLocality": "福岡市",
                        "addressRegion": "福岡県",
                        "addressCountry": "JP"
                    },
                    "founder": {
                        "@type": "Person",
                        "name": "向 雅也",
                        "alternateName": "Masaya Muko",
                        "url": "https://www.corduroy.co.jp/members/masaya/"
                    },
                    "sameAs": [
                        "https://x.com/MasayaToAi",
                        "https://www.instagram.com/masayatoai/",
                        "https://www.tiktok.com/@masayatoai"
                    ],
                    "contactPoint": {
                        "@type": "ContactPoint",
                        "contactType": "customer support",
                        "email": "info@corduroy.co.jp",
                        "availableLanguage": ["ja"]
                    }
                },
                {
                    "@type": "WebSite",
                    "@id": "https://www.corduroy.co.jp/#website",
                    "url": "https://www.corduroy.co.jp/",
                    "name": "株式会社コールテン",
                    "publisher": { "@id": "https://www.corduroy.co.jp/#organization" },
                    "inLanguage": "ja-JP"
                }
            ]
        })} />

        <slot name="head" />
	</head>
	<body>
        <Header />
		<slot />
        <Footer />
        {/* <ChatWidget client:idle /> */}

        {/* ===== FAQ コンプリート ポップアップ（全ページ共通） ===== */}
        <div class="faq-complete-popup" id="faqCompletePopup" hidden role="dialog" aria-modal="true" aria-labelledby="faqCompletePopupTitle">
          <div class="popup-overlay" data-popup-close></div>
          <div class="popup-card">
            <button type="button" class="popup-close" data-popup-close aria-label="閉じる">&times;</button>
            <img src="/assets/images/faq-complete-celebration.png" alt="盤上テトとTikiが両手を上げてお祝いしているイラスト" loading="lazy" />
            <h3 id="faqCompletePopupTitle">たくさん見てくれてありがとう</h3>
            <p>引き続き<a href="/">コールテンのサイト</a>を楽しんでね。</p>
          </div>
        </div>
        <script>
            // --- Scroll Fade-in Animation ---
            const observer = new IntersectionObserver((entries) => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  entry.target.classList.remove('pending');
                  observer.unobserve(entry.target);
                }
              });
            }, { 
                threshold: 0.1,
                rootMargin: '0px'
            });
            document.querySelectorAll('.fade-up').forEach(el => {
              el.classList.add('pending');
              observer.observe(el);
              // Fallback to ensure visibility
              setTimeout(() => {
                  if (el.classList.contains('pending')) {
                      el.classList.remove('pending');
                  }
              }, 3000);
            });

            // --- GA CTA Tracking ---
            document.addEventListener('click', (event) => {
              const target = event.target.closest('[data-ga-event]');
              if (!target || typeof gtag !== 'function') return;
              const eventName = target.getAttribute('data-ga-event');
              if (!eventName) return;
              gtag('event', eventName, {
                event_label: target.getAttribute('data-ga-label') || undefined,
                event_category: target.getAttribute('data-ga-category') || undefined,
              });
            });

            // ===== FAQ ゲーミフィケーション（全ページ共通・DOM自動検出） =====
            (function () {
              const faqSections = document.querySelectorAll('section.faq, .container.faq');
              const popup = document.getElementById('faqCompletePopup');
              let popupBound = false;

              faqSections.forEach((section, sectionIdx) => {
                const itemsWrap = section.querySelector('.faq-items');
                if (!itemsWrap) return;
                const detailsList = itemsWrap.querySelectorAll(':scope > details');
                if (detailsList.length === 0) return;
                if (section.querySelector('.faq-progress')) return; // 既に存在ならスキップ

                // details に id を自動付与（重複しないように section index を含める）
                const idPrefix = 'faq-s' + sectionIdx + '-';
                detailsList.forEach((d, i) => {
                  if (!d.id) d.id = idPrefix + (i + 1);
                });

                // 進捗ブロック生成
                const progress = document.createElement('div');
                progress.className = 'faq-progress fade-up';
                const lead = document.createElement('p');
                lead.className = 'faq-progress-lead';
                lead.textContent = '緑のボタンを押して、答えを集めてみよう。';
                const collection = document.createElement('div');
                collection.className = 'faq-collection';
                collection.setAttribute('role', 'list');
                collection.setAttribute('aria-label', 'FAQ進捗');
                detailsList.forEach((d, i) => {
                  const slot = document.createElement('button');
                  slot.type = 'button';
                  slot.className = 'faq-slot' + (d.open ? ' is-collected' : '');
                  slot.dataset.target = d.id;
                  slot.setAttribute('aria-label', '質問' + (i + 1) + 'へスクロール');
                  const inner = document.createElement('span');
                  inner.className = 'faq-slot-button';
                  inner.setAttribute('aria-hidden', 'true');
                  slot.appendChild(inner);
                  collection.appendChild(slot);
                });
                progress.appendChild(lead);
                progress.appendChild(collection);

                // 挿入位置: section-head の直後 or faq-items の前
                const head = section.querySelector('.section-head');
                if (head && head.nextSibling) {
                  head.parentNode.insertBefore(progress, head.nextSibling);
                } else {
                  itemsWrap.parentNode.insertBefore(progress, itemsWrap);
                }

                // 状態管理
                const slots = collection.querySelectorAll('.faq-slot');
                const collected = new Set();
                detailsList.forEach((d) => { if (d.open) collected.add(d.id); });
                let completedFired = false;

                function syncSlots() {
                  slots.forEach((slot) => {
                    const id = slot.dataset.target;
                    slot.classList.toggle('is-collected', collected.has(id));
                  });
                }

                function fireConfetti() {
                  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
                  const colors = ['#16614e', '#d4a04d', '#f2bd78', '#ffffff', '#0b3326'];
                  const container = document.createElement('div');
                  container.className = 'confetti-container';
                  document.body.appendChild(container);
                  for (let i = 0; i < 90; i++) {
                    const piece = document.createElement('div');
                    piece.className = 'confetti-piece';
                    piece.style.left = (Math.random() * 100) + '%';
                    piece.style.background = colors[Math.floor(Math.random() * colors.length)];
                    piece.style.animationDelay = (Math.random() * 0.6) + 's';
                    piece.style.animationDuration = (2 + Math.random() * 2.4) + 's';
                    piece.style.transform = 'rotate(' + (Math.random() * 360) + 'deg)';
                    container.appendChild(piece);
                  }
                  setTimeout(() => container.remove(), 6000);
                }

                function fireComplete() {
                  if (completedFired) return;
                  completedFired = true;
                  fireConfetti();
                  setTimeout(() => { if (popup) popup.hidden = false; }, 700);
                  if (typeof gtag === 'function') {
                    gtag('event', 'faq_complete', { event_category: 'faq', event_label: 'all_opened' });
                  }
                }

                detailsList.forEach((d) => {
                  d.addEventListener('toggle', () => {
                    if (!d.open) return;
                    const before = collected.size;
                    collected.add(d.id);
                    if (collected.size > before) {
                      syncSlots();
                      if (typeof gtag === 'function') {
                        gtag('event', 'faq_open', { event_category: 'faq', event_label: d.id });
                      }
                      if (collected.size === detailsList.length) fireComplete();
                    }
                  });
                });

                slots.forEach((slot) => {
                  slot.addEventListener('click', () => {
                    const target = document.getElementById(slot.dataset.target);
                    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    if (typeof gtag === 'function') {
                      gtag('event', 'faq_slot_click', { event_category: 'faq', event_label: slot.dataset.target });
                    }
                  });
                });
              });

              // ポップアップ閉じる（1度だけバインド）
              if (popup && !popupBound) {
                popupBound = true;
                popup.querySelectorAll('[data-popup-close]').forEach((el) => {
                  el.addEventListener('click', () => { popup.hidden = true; });
                });
                document.addEventListener('keydown', (e) => {
                  if (e.key === 'Escape' && !popup.hidden) popup.hidden = true;
                });
              }
            })();
        </script>
	</body>
</html>
<style is:global>
    @font-face {
      font-family: 'CraftMincho';
      src: url('/assets/fonts/craftmincho.woff2') format('woff2'),
           url('/assets/fonts/craftmincho.otf') format('opentype');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }

    :root {
      /* Core Palette - Deep & Rich */
      --green: #0b3326;
      --mint: #eef7f3;
      --mint-dark: #c8e1d6;
      --cream: #fbf9f5;
      --white: #ffffff;

      /* Accents */
      --accent: #d4a04d;
      --orange: #f2bd78;

      /* Text */
      --text: #1a2e28;
      --text-light: #486358;
      --ink: #052018;

      /* UI Elements */
      --line: #dbebe3;
      --line-strong: #bfd6cc;
      --sea: #16614e;

      /* Effects */
      --shadow-sm: 0 2px 4px rgba(5, 32, 24, 0.04), 0 1px 2px rgba(5, 32, 24, 0.02);
      --shadow-md: 0 8px 16px rgba(5, 32, 24, 0.06), 0 4px 8px rgba(5, 32, 24, 0.03);
      --shadow-lg: 0 24px 48px rgba(5, 32, 24, 0.08), 0 12px 24px rgba(5, 32, 24, 0.04);
      --glass: rgba(255, 255, 255, 0.8);
      --glass-border: rgba(255, 255, 255, 0.4);
    }

    html {
      scroll-behavior: smooth
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box
    }

    body {
      margin: 0;
      font-family: "Noto Sans JP", "Space Grotesk", "Helvetica Neue", Arial, sans-serif;
      color: var(--text);
      background: var(--cream);
    }
    
    /* Global Typography */
    h1, h2, h3, h4 {
        margin: 0;
        color: var(--ink);
        font-family: 'CraftMincho', serif;
        font-feature-settings: "palt";
        letter-spacing: 0.05em;
    }
    
    h1 {
      font-size: clamp(40px, 6vw, 64px);
      line-height: 1.15;
    }

    h2 {
      font-size: clamp(28px, 4vw, 42px);
      line-height: 1.3;
      margin-bottom: 16px;
    }

    h3 {
      font-size: 20px;
      line-height: 1.5;
      font-weight: 600;
    }

    p {
      line-height: 1.8;
      letter-spacing: 0.02em;
      color: var(--text-light);
    }
    
    a {
      text-decoration: none;
      color: inherit;
      transition: color 0.2s ease;
    }

    img {
      max-width: 100%;
      display: block;
    }
    
    /* Section & Head */
    section {
      padding: 100px 0;
      position: relative;
    }

    .section-head {
      text-align: center;
      margin-bottom: 72px;
      position: relative;
    }

    .section-head small {
      display: inline-block;
      color: var(--accent);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 16px;
      font-family: "Space Grotesk", sans-serif;
      font-size: 12px;
    }

    .section-head p {
      max-width: 600px;
      margin: 0 auto;
      color: var(--text-light);
    }
    
    .container {
      max-width: 1240px;
      margin: 0 auto;
      padding: 0 32px;
    }
    
    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 36px;
      border-radius: 100px;
      border: none;
      background: var(--sea);
      color: #fff;
      font-weight: 700;
      font-size: 15px;
      box-shadow: 0 4px 12px rgba(22, 97, 78, 0.25);
      letter-spacing: 0.05em;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(22, 97, 78, 0.35);
      background: #0f4d3d;
      filter: none;
    }

    .btn.secondary {
      background: transparent;
      border: 1px solid var(--text-light);
      color: var(--text);
      box-shadow: none;
    }

    .btn.secondary:hover {
      border-color: var(--sea);
      color: var(--sea);
      background: rgba(22, 97, 78, 0.03);
      box-shadow: none;
    }

    .btn.btn-outline {
      background: #fff;
      border: 2px solid var(--sea);
      color: var(--sea);
      box-shadow: none;
    }

    .btn.btn-outline:hover {
      background: var(--sea);
      color: #fff;
      box-shadow: 0 4px 12px rgba(22, 97, 78, 0.25);
    }

    /* Card */
    .card {
        background: #fff;
        border: 1px solid #eef2f0;
        border-radius: 24px;
        padding: 32px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .02), 0 20px 45px rgba(0, 0, 0, .06);
        transition: .25s transform, .25s box-shadow;
    }
    
    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, .02), 0 28px 60px rgba(0, 0, 0, .09);
    }
    
    /* Mini text utility */
    .mini {
        font-size: 14px;
        color: var(--text-light);
        line-height: 1.8;
    }
    
    .card .mini {
        color: #486358;
    }
    
    /* Background Utilities */
    .bg-gradient-soft {
        background: linear-gradient(180deg, #fbfaf8 0%, #f5f9f7 100%);
    }
    
    .bg-contact {
        background: linear-gradient(180deg, #f5f9f7 0%, #e6f3ed 100%);
    }
    
    /* Values Section - Promise Numbers */
    #values .promise-number {
      font-size: 4rem;
      font-weight: 700;
      color: var(--mint);
      line-height: 1;
      margin-bottom: 0.2em;
      font-family: 'CraftMincho', serif;
    }
    
    /* Split Layout */
    .split-layout {
      display: grid;
      gap: 32px;
      align-items: center;
      margin-top: 28px;
    }

    @media(min-width:880px) {
      .split-layout {
        grid-template-columns: 1fr 1fr;
        gap: 48px;
      }
      
      .split-layout.reverse>*:first-child {
        grid-column-start: 2;
      }

      .split-layout.reverse>*:last-child {
        grid-column-start: 1;
        grid-row-start: 1;
      }
    }

    .split-layout .img-container {
      border-radius: 24px;
      overflow: hidden;
      box-shadow: var(--shadow-md);
      position: relative;
    }

    .split-layout .img-container img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: .3s transform;
    }

    .split-layout .img-container:hover img {
      transform: scale(1.03);
    }
    
    /* Brand Story */
    #brand-story .story-container {
      max-width: 680px;
      margin: 0 auto;
    }

    #brand-story .story-text-blocks {
      display: flex;
      flex-direction: column;
      gap: 1.5em;
      text-align: left;
      background-color: var(--cream);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 32px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, .05);
      line-height: 1.8;
    }

    #brand-story .story-lead {
      font-size: 22px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 16px;
      text-align: center;
    }
    
    /* Fade Up Animation */
    /* Fade Up Animation */
    .fade-up {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .fade-up.pending {
        opacity: 0;
        transform: translateY(30px);
    }
    
    /* ============================================
       FAQ — Corduroy Standard
       ============================================ */
    .faq .faq-items {
      max-width: 800px;
      margin: 0 auto;
    }
    .faq details {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px 24px;
      background: #fff;
      margin-bottom: 12px;
      position: relative;
    }
    .faq summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--ink);
      font-size: 17px;
      padding-right: 60px;
      position: relative;
      list-style: none;
    }
    .faq summary::-webkit-details-marker { display: none; }

    /* Closed: Animated arrow hint */
    .faq summary::before {
      content: '\2192';
      position: absolute;
      right: 40px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 15px;
      font-weight: 700;
      color: var(--accent, #d4a04d);
      opacity: 0.75;
      animation: faq-arrow-nudge 1.6s ease-in-out infinite;
      transition: opacity 0.3s ease;
    }

    @keyframes faq-arrow-nudge {
      0%, 100% { transform: translateY(-50%) translateX(0); }
      50% { transform: translateY(-50%) translateX(5px); }
    }

    /* Closed: Green filled button with white border + white dots */
    .faq summary::after {
      content: '';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background-color: var(--sea);
      border: 1.5px dotted #fff;
      background-image:
        radial-gradient(circle at 38% 50%, #fff 1.5px, transparent 2px),
        radial-gradient(circle at 62% 50%, #fff 1.5px, transparent 2px);
      background-repeat: no-repeat;
      outline: 1.5px solid var(--sea);
      outline-offset: 0;
      box-shadow: none;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    /* Open: Hide arrow */
    .faq details[open] summary::before {
      opacity: 0;
      animation: none;
    }

    /* Open: Large green checkmark (no circle) */
    .faq details[open] summary::after {
      width: 48px;
      height: 48px;
      background-color: transparent;
      border: none;
      outline: none;
      box-shadow: none;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23d4a04d' stroke-width='3.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='4 12 10 18 20 6'/></svg>");
      background-size: 100% 100%;
      background-repeat: no-repeat;
      background-position: center;
      transform: translateY(-50%);
      animation: faq-check-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

