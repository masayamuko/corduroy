---
import Layout from '../layouts/Layout.astro';

const title = "株式会社コールテン｜想いを大切にするAI活用サポート";
const description = "想いを大切にするAI活用サポート。AIとの関係性を育てる、本質的な学びと伴走。無料のAI講座や体験会から、あなたに合ったAI活用を一緒に見つけていきます。";
---

<Layout title={title} description={description}>
    <script slot="head" type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "AI導入は初めてですが、大丈夫ですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "もちろんです。コールテンのお客さまの多くは「AIを初めて本格的に導入する」という方々です。専門用語を使わず、基礎の基礎から丁寧にサポートします。まずは無料のAI講座で雰囲気をつかんでみてください。"
          }
        }, {
          "@type": "Question",
          "name": "法人じゃなくても大丈夫ですか？個人でも相談できますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "もちろんです。法人・個人問わずご利用いただけます。創作活動、フリーランス、副業、趣味の延長線上でAIを使いたい方も大歓迎です。これまで教育、士業、NPO、サービス業から個人クリエイターまで幅広くサポートしています。"
          }
        }, {
          "@type": "Question",
          "name": "AIを入れると、人の仕事はなくなりますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "いいえ、なくなりません。私たちは「AIは人の仕事を奪うものではなく、人が本来やりたいこと（想い）を実現するためのパートナー」だと考えています。コールテン自身も29名のAI社員と一緒に経営しており、人とAIの共存を日々実践しています。"
          }
        }, {
          "@type": "Question",
          "name": "費用はどのくらいかかりますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ご予算やフェーズに合わせて柔軟に対応します。月額5〜20万円のAI顧問、体系的に学べるAI講座、仲間と続けるAIコミュニティなど、段階に合った形をご用意しています。まずは無料動画講座や無料体験会でお気軽にお試しください。"
          }
        }, {
          "@type": "Question",
          "name": "まずは話を聞いてみたいのですが、どこから始めればいい？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "LINEで受け取れる無料動画講座で雰囲気をつかむのがおすすめです。対面で体験したい方は無料体験会もあります。個別に相談したい方はお問い合わせページからお気軽にご連絡ください。"
          }
        }, {
          "@type": "Question",
          "name": "無料で試せるものはありますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい。LINEで受け取れる無料動画講座と、対面の無料体験会をご用意しています。まずは気軽に触れてみてください。"
          }
        }, {
          "@type": "Question",
          "name": "オンラインで受けられますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AI顧問は完全オンライン対応しています。AI講座や体験会は対面が中心ですが、オンライン対応が可能な場合もありますので、お気軽にご相談ください。"
          }
        }, {
          "@type": "Question",
          "name": "法人として依頼したい場合は？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "法人さまにはAI顧問（月額5〜20万円の伴走型サポート）と法人研修をご用意しています。チーム全体でAI活用力を高めたい場合に最適です。まずはお問い合わせください。"
          }
        }, {
          "@type": "Question",
          "name": "他のAI会社との違いは何ですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "コールテン代表はプロコーチ出身で、AIの「使い方」ではなく「関係性」を重視しています。ゴールは依存ではなく自走。お客さま自身がAIと共に成長し、コールテンを卒業できる状態を目指しています。"
          }
        }]
      }
    </script>
  <main id="top">
    <section class="hero">
      <div class="container hero-inner">
        <div class="fade-up">
          <h1><span class="jp-kanji">想</span><span class="jp-hiragana">いを</span><span class="jp-kanji">大切</span><span
              class="jp-hiragana">に！</span><br><span class="jp-kanji">AI</span><span class="jp-hiragana">との</span><span
              class="jp-kanji">関係性</span><span class="jp-hiragana">を</span><span class="jp-kanji">育</span><span class="jp-hiragana">む</span></h1>
          <small style="display:block; margin-top:16px; margin-bottom: 8px;">株式会社コールテン</small>
          <a class="btn hero-story-btn" href="#brand-story" data-ga-event="cta_click" data-ga-label="hero_brand_story"><span class="btn-nande">なんで</span>「コールテン」<span class="btn-question">？</span></a>
        </div>
      </div>
    </section>

    <section id="voices" class="container">
      <div class="section-head fade-up">
        <small>Voices</small>
        <h2><span class="jp-kanji">クライアント</span><span class="jp-hiragana">さんの</span><span class="jp-kanji">声</span></h2>
        <p>コールテン自慢のクライアントさんたちです。</p>
      </div>
      <div class="voice-bubbles">
        <!-- Takaro-san (Active) -->
        <a class="voice-card fade-up" href="/voices/takaro">
          <div class="voice-avatar-block">
            <div class="voice-avatar"><img
                src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png"
                alt="中野たかろーさん" width="60" height="60" loading="lazy"></div>
            <div class="voice-title">フリーランス</div>
            <div class="voice-meta">中野たかろーさん</div>
            <span class="voice-tag">AI顧問</span>
          </div>
          <p class="voice-detail">「検索ツール」から「第二の自分」へ。価値観を学習させたAIとの対話で、孤独な制作業務に最強の相談相手を獲得。</p>
        </a>

        <!-- Sano-san (Active) -->
        <a class="voice-card fade-up" href="/voices/sano" style="transition-delay:.05s;">
          <div class="voice-avatar-block">
            <div class="voice-avatar"><img
                src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudeniaru.png"
                alt="佐野さん" width="60" height="60" loading="lazy"></div>
            <div class="voice-title">株式会社スデニアル</div>
            <div class="voice-meta">代表 佐野さん</div>
            <span class="voice-tag">AI顧問</span>
          </div>
          <p class="voice-detail">議事録要約止まりだったAI活用から、マーケ施策のシミュレーションを高速に回せる状態へ。提案の幅と検証スピードを一気に拡大。</p>
        </a>

        <!-- Numazawa-san (Active) -->
        <a class="voice-card fade-up" href="/voices/numazawa" style="transition-delay:.1s;">
          <div class="voice-avatar-block">
            <div class="voice-avatar"><img
                src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png"
                alt="沼澤さん" width="60" height="60" loading="lazy"></div>
            <div class="voice-title">SHU行政書士事務所</div>
            <div class="voice-meta">代表 沼澤さん</div>
            <span class="voice-tag">AI講座</span>
          </div>
          <p class="voice-detail">AIを「調べるだけ」から「対話型の相棒」へ。第二の自分ワークを起点に内省の回転数が上がり、DX推進にも波及。</p>
        </a>

        <!-- Kubota-san (許可未取得・準備中表示) -->
        <div class="voice-card fade-up" style="transition-delay:.15s; opacity:0.7; cursor:default;">
          <div class="voice-avatar-block" style="filter:grayscale(100%);">
            <div class="voice-avatar"><img
                src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png"
                alt="窪田さん" width="60" height="60" loading="lazy"></div>
            <div class="voice-title">NPO法人スマイリーフラワーズ</div>
            <div class="voice-meta">代表 窪田さん</div>
            <span class="voice-tag" style="background:#ddd; color:#666; border-color:#ccc;">準備中</span>
          </div>
          <p class="voice-detail">準備中</p>
        </div>

        <!-- Higashide-san (Coming Soon) -->
        <div class="voice-card fade-up" style="transition-delay:.2s; opacity:0.7; cursor:default;">
          <div class="voice-avatar-block" style="filter:grayscale(100%);">
            <div class="voice-avatar"><img
                src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765800932/higashide_hokkaidoryugaku.jpg"
                alt="東出さん" width="60" height="60" loading="lazy"></div>
            <div class="voice-title">北海道留学センター</div>
            <div class="voice-meta">代表 東出さん</div>
            <span class="voice-tag" style="background:#ddd; color:#666; border-color:#ccc;">準備中</span>
          </div>
          <p class="voice-detail">準備中</p>
        </div>

        <!-- S-san (Coming Soon) -->
        <div class="voice-card fade-up" style="transition-delay:.25s; opacity:0.7; cursor:default;">
          <div class="voice-avatar-block" style="filter:grayscale(100%);">
            <div class="voice-avatar"><img src="/assets/images/dummy_s_san.png" alt="Sさん" width="60" height="60" loading="lazy"></div>
            <div class="voice-title">NPO法人N</div>
            <div class="voice-meta">Sさん</div>
            <span class="voice-tag" style="background:#ddd; color:#666; border-color:#ccc;">準備中</span>
          </div>
          <p class="voice-detail">準備中</p>
        </div>

      </div>
      <div class="section-head fade-up" style="margin-top:28px">
        <a class="btn secondary" href="/voices/">もっと見る</a>
      </div>
    </section>

    <section id="services" class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Services</small>
          <h2><span class="jp-kanji">提供</span><span class="jp-hiragana">サービス</span></h2>
          <p>あなたに合った形で、AIとの付き合い方を育みます。</p>
        </div>
        <div class="service-two-col">
          <!-- AI講座（メイン・緑背景） -->
          <div class="card service-card-main service-card-highlight fade-up">
            <div class="ribbon"><span>ここから</span></div>
            <div class="icon-lg">🎓</div>
            <h3>AI講座</h3>
            <p class="mini">AIを「優秀な人間」に例え、専門用語を使わずにAIの基礎と可能性をお伝えすることにはじまり、さまざまな事例に触れつつ多様な仕事での導入や活用を追求します。</p>
            <a class="btn" href="/services/" style="margin-top:16px; background:#fff; color:var(--sea);">まずは無料AI講座から</a>
          </div>

          <!-- AIコミュニティ -->
          <div class="card service-card-main fade-up">
            <div class="icon-lg">🏠</div>
            <h3>AIコミュニティ</h3>
            <p class="mini">月2回の作業会（糸口会）とDiscordで、AIを学んだあとも使い続ける仲間とつながる場所。学んで終わりにしない環境がここにあります。</p>
            <a class="btn secondary" href="/services/study/community" style="margin-top:16px;">コミュニティを見る →</a>
          </div>
        </div>

        <!-- AI顧問（ライン区切り） -->
        <div class="advisory-section fade-up">
          <div class="advisory-two-col">
            <div class="advisory-left">
              <div class="advisory-label"><span>🤝</span> AI顧問</div>
              <p class="advisory-lead">社内の「AI担当」を代行しながら、<br>御社の中にAI人材を育てます。</p>
              <p class="mini">最新のAI動向のキャッチアップ、業務への導入設計、社内勉強会の実施まで——外部のAI専門家が御社専属で伴走。「何から始めればいいかわからない」段階から、社内でAIを自走できる状態を一緒に目指します。</p>
            </div>
            <div class="advisory-right">
              <div class="advisory-price">
                <span class="price-label">月額</span>
                <span class="price-value">5〜20<span class="price-unit">万円</span></span>
              </div>
              <p class="price-note">（ご予算・頻度に応じてカスタマイズ）</p>
              <a class="btn secondary" href="/services/advisory">詳しく見る →</a>
              <p class="advisory-sub">個人の方のマンツーマンレッスンもご相談ください。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="members-teaser" class="container">
      <div class="section-head fade-up">
        <small>Team Members</small>
        <h2><span class="jp-kanji">29</span><span class="jp-hiragana">名の</span><span class="jp-kanji">AI</span><span class="jp-hiragana">社員が</span><span class="jp-kanji">働</span><span class="jp-hiragana">く</span><span class="jp-kanji">組織</span></h2>
        <p>経営・マーケ・開発・営業・CS・経理・人事・法務——業務領域ごとに専門化したAIエージェントが、人間のスタッフと一緒にチームを組んでいます。</p>
      </div>
      <div class="teaser-wrap fade-up">
        <div class="office-image-wrap">
          <img src="/assets/images/members/office_overview.png"
               alt="10部門29名のAI社員のピクセルアートオフィス全景"
               width="1371" height="738"
               loading="lazy" />
        </div>
        <small class="teaser-disclosure">※ 掲載メンバーはすべて株式会社コールテンが構築・運用するAIエージェント（AI社員）です。</small>
        <div class="section-head" style="margin-top:28px">
          <a class="btn secondary" href="/members/" data-ga-event="cta_click" data-ga-label="top_members">メンバー一覧を見る →</a>
        </div>
      </div>
    </section>

    <section id="values" class="container">
      <div class="split-layout">
        <div class="img-container fade-up">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764599196/BRAND_STORY_fkpzup.png"
            alt="本棚の背景にコールテンのロゴ" width="800" height="600" loading="lazy">
        </div>
        <div class="fade-up" style="transition-delay: .2s">
          <small class="section-head" style="text-align:left;margin-bottom:12px;"><small>Values</small></small>
          <h2><span class="jp-kanji">コールテン</span><span class="jp-kanji">２</span><span class="jp-hiragana">つの</span><span
              class="jp-kanji">約束</span></h2>
          <p class="mini" style="margin-top:16px; margin-bottom:24px;">
            私たちは、AI導入だけを目的としません。使う人と組織の「想い」に寄り添い、組織全体の安心と成長につながる支援を約束します。</p>
          <div class="card" style="margin-bottom: 16px;">
            <div class="promise-number">1</div>
            <h3>らしさを引き出し活かします！</h3>
            <p class="mini">欠けてる部分や苦手さえも、あなたの魅力の一部。自分自身や組織内では気付きにくい想いと個性を丁寧に汲み取り、AIがあなたの“物語の続きを進める相棒"になるよう支援します。</p>
          </div>
          <div class="card">
            <div class="promise-number">2</div>
            <h3>本質的な変化を、着実に！</h3>
            <p class="mini">いきなり変えようとしなくて大丈夫。小さな成功を一緒に喜びながら、気づき → 試す → 育てる を穏やかに続けられるAI活用を育てていきます。</p>
          </div>
        </div>
      </div>
    </section>

    <section id="brand-story" class="bg-gradient-soft">
      <div class="container story-container">
        <div class="section-head fade-up">
          <small>Brand Story</small>
        </div>
        <div class="story-text-blocks fade-up">
          <div class="story-lead">欠けているからこそ、<br>ストーリーがあり、魅力がある。</div>
          <div style="text-align:center; margin:8px 0 16px;">
            <a href="https://amzn.to/48wo9qi" target="_blank" rel="noopener noreferrer"
              style="display:inline-block; border-radius:6px; overflow:hidden; box-shadow:0 12px 28px rgba(0,0,0,.12); margin:0 auto;">
              <img
                src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764694229/%E3%81%8F%E3%81%BE%E3%81%AE%E3%82%B3%E3%83%BC%E3%83%AB%E3%83%86%E3%83%B3%E3%81%8F%E3%82%93_yze3al.jpg"
                alt="くまのコールテンくん 絵本カバー" width="200" height="280" loading="lazy" style="display:block; width:200px; height:auto; max-width:100%;">
            </a>
          </div>
          <p class="mini">
            社名は、絵本『くまのコールテンくん』から名付けました。<br>ボタンが欠けてて売れ残ってしまったぬいぐるみ“コールテン"。<br>ボタン探しの旅に出て、さまざまな景色や出来事に触れ、<br>最後には「そのままの姿」で迎え入れられます。
          </p>
          <p class="mini">代表の向もまた、<br>“普通ができない"と感じて悩んでいた時期がありました。<br>けれどその旅の途中で AI
            と出会い、<br>自分の苦手を補い、得意を伸ばし、<br>仕事がぐっと楽しくなる感覚 を知りました。<br>「欠けている」と思っていた部分が、<br>むしろ前に進むためのエネルギーに変わっていったのです。</p>
          <p class="mini">
            コールテンは、そんな経験から生まれた会社です。<br>欠けている思う気持ちも、未完成さも、<br>その人の魅力であり、物語を動かす力になる。<br>そう信じて、クライアントさんの想いや良さを一緒に見つめながら、<br>AIで楽しく働ける未来をつくるお手伝いをしています。
          </p>
        </div>
      </div>
    </section>

    <section class="container faq">
      <div class="section-head fade-up">
        <small>FAQ</small>
        <h2>よくあるご質問</h2>
      </div>
      <div class="faq-items fade-up">
        <details open>
          <summary>AI導入は初めてですが、大丈夫ですか？</summary>
          <p class="mini">
            もちろんです。コールテンのお客さまの多くは「AIを初めて本格的に導入する」という方々です。専門用語を使わず、基礎の基礎から丁寧にサポートします。まずは<a href="/services/">無料のAI講座</a>で雰囲気をつかんでみてください。
          </p>
        </details>
        <details>
          <summary>法人じゃなくても大丈夫ですか？個人でも相談できますか？</summary>
          <p class="mini">
            もちろんです。法人・個人問わずご利用いただけます。創作活動、フリーランス、副業、趣味の延長線上でAIを使いたい方も大歓迎です。これまで教育、士業、NPO、サービス業から個人クリエイターまで幅広くサポートしています。「その活動におけるAIの活かし方」を一緒に考えます。<a href="/voices/">利用者の声</a>もぜひご覧ください。
          </p>
        </details>
        <details>
          <summary>AIを入れると、人の仕事はなくなりますか？</summary>
          <p class="mini">
            いいえ、なくなりません。私たちは「AIは人の仕事を奪うものではなく、人が本来やりたいこと（想い）を実現するためのパートナー」だと考えています。コールテン自身も<a href="/members/about">29名のAI社員と一緒に経営</a>しており、人とAIの共存を日々実践しています。
          </p>
        </details>
        <details>
          <summary>費用はどのくらいかかりますか？</summary>
          <p class="mini">
            ご予算やフェーズに合わせて柔軟に対応します。月額5〜20万円の<a href="/services/advisory">AI顧問</a>、体系的に学べる<a href="/services/study/program">AI講座</a>、仲間と続ける<a href="/services/study/community">AIコミュニティ</a>など、段階に合った形をご用意しています。まずは<a href="/services/">無料動画講座</a>や<a href="/services/study/trial">無料体験会</a>でお気軽にお試しください。
          </p>
        </details>
        <details>
          <summary>まずは話を聞いてみたいのですが、どこから始めればいい？</summary>
          <p class="mini">
            LINEで受け取れる<a href="/services/">無料動画講座</a>で雰囲気をつかむのがおすすめです。対面で体験したい方は<a href="/services/study/trial">無料体験会</a>もあります。個別に相談したい方は<a href="/contact">お問い合わせページ</a>からお気軽にご連絡ください。
          </p>
        </details>
        <details>
          <summary>無料で試せるものはありますか？</summary>
          <p class="mini">
            はい。LINEで受け取れる<a href="/services/">無料動画講座</a>と、対面の<a href="/services/study/trial">無料体験会</a>をご用意しています。まずは気軽に触れてみてください。
          </p>
        </details>
        <details>
