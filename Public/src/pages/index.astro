      tiki: container.querySelector('.buddy-right')
    };
    if (!buddies.tiki || !buddies.teto) return;

    // ===== state =====
    let sectionKey = 'hero';      // スクロール由来の現在セクション
    let hoverKey = null;          // カードhover中のキー（null=なし）
    let buddyShouldShow = false;  // Voices 上端が画面上40%に到達したら true

    // ===== buddy 適用 =====
    function applyBuddy(char, conf) {
      const el = buddies[char];
      if (!el) return;
      if (!conf || conf.hide) {
        el.classList.add('is-hidden');
        return;
      }
      el.classList.remove('is-hidden');
      el.classList.toggle('upper', !!conf.upper);

      if (conf.img) {
        const img = el.querySelector('[data-img]');
        const newSrc = buildUrl(char, conf.img);
        if (img && img.getAttribute('src') !== newSrc) {
          img.setAttribute('src', newSrc);
          img.setAttribute('alt', char === 'tiki' ? 'Tikiちゃん' : '盤上テト');
        }
      }

      const bubble = el.querySelector('[data-bubble]');
      const text = el.querySelector('[data-bubble-text]');
      if (conf.say && conf.say.trim().length > 0) {
        if (text) text.textContent = conf.say;
        if (bubble) bubble.classList.remove('is-empty');
      } else {
        if (text) text.textContent = '';
        if (bubble) bubble.classList.add('is-empty');
      }
    }

    // ===== state 合成（表示モード判定 → section base → hover override） =====
    function computeEffective() {
      if (!buddyShouldShow) {
        return BUDDY_MAP['hero']; // 全 hide
      }
      const sec = BUDDY_MAP[sectionKey] || BUDDY_MAP['hero'];
      if (hoverKey && HOVER_MAP[hoverKey]) {
        const ovr = HOVER_MAP[hoverKey];
        return {
          tiki: ovr.tiki || sec.tiki,
          teto: ovr.teto || sec.teto
        };
      }
      return sec;
    }
    function applyState() {
      const conf = computeEffective();
      applyBuddy('tiki', conf.tiki);
      applyBuddy('teto', conf.teto);
    }

    // 初期化
    applyState();

    if (!('IntersectionObserver' in window)) return;

    // ===== Voices 上端到達 監視（画面上から40%ラインで切替） =====
    const voicesEl = document.getElementById('voices');
    if (voicesEl) {
      let scrollScheduled = false;
      const updateBuddyShow = () => {
        scrollScheduled = false;
        const rect = voicesEl.getBoundingClientRect();
        const triggerY = window.innerHeight * 0.4;
        const newShow = rect.top < triggerY;
        if (newShow !== buddyShouldShow) {
          buddyShouldShow = newShow;
          applyState();
        }
      };
      const onScroll = () => {
        if (scrollScheduled) return;
        scrollScheduled = true;
        requestAnimationFrame(updateBuddyShow);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      updateBuddyShow(); // 初期判定
    }

    // ===== その他セクション監視 =====
    const targets = [];
    document.querySelectorAll('main > section').forEach((s) => {
      const key = s.id;
      if (!key) return;             // hero(class.hero, no id) はスキップ
      if (!BUDDY_MAP[key]) return;
      s.dataset.buddyKey = key;
      targets.push(s);
    });

    const lastBuddyKey = targets[targets.length - 1]?.dataset.buddyKey || null;
    const isAtPageBottom = () => {
      return window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
    };
    const lockLastSectionAtBottom = () => {
      if (!lastBuddyKey || !isAtPageBottom() || sectionKey === lastBuddyKey) return;
      sectionKey = lastBuddyKey;
      applyState();
    };

    if (targets.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        if (isAtPageBottom() && lastBuddyKey) {
          if (sectionKey !== lastBuddyKey) {
            sectionKey = lastBuddyKey;
            applyState();
          }
          return;
        }

        const viewportMid = window.innerHeight / 2;
        let bestKey = null;
        let bestDist = Infinity;
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const rect = entry.boundingClientRect;
          const sectionMid = rect.top + rect.height / 2;
          const dist = Math.abs(sectionMid - viewportMid);
          if (dist < bestDist) {
            bestDist = dist;
            bestKey = entry.target.dataset.buddyKey;
          }
        });
        if (bestKey && bestKey !== sectionKey) {
          sectionKey = bestKey;
          applyState();
        }
      }, {
        threshold: [0, 0.15, 0.35, 0.55, 0.75, 1],
        rootMargin: '-30% 0px -30% 0px'
      });
      targets.forEach((el) => observer.observe(el));
    }

    window.addEventListener('scroll', lockLastSectionAtBottom, { passive: true });
    window.addEventListener('resize', lockLastSectionAtBottom, { passive: true });
    lockLastSectionAtBottom();

    // ===== カード hover override（hover対応デバイスのみ） =====
    const supportsHover = window.matchMedia('(hover: hover)').matches;
    if (supportsHover) {
      document.querySelectorAll('[data-buddy-hover]').forEach((card) => {
        const key = card.getAttribute('data-buddy-hover');
        if (!key || !HOVER_MAP[key]) return;
        const setHover = () => {
          if (hoverKey !== key) { hoverKey = key; applyState(); }
        };
        const clearHover = () => {
          if (hoverKey === key) { hoverKey = null; applyState(); }
        };
        card.addEventListener('mouseenter', setHover);
        card.addEventListener('focusin', setHover);
        card.addEventListener('mouseleave', clearHover);
        card.addEventListener('focusout', clearHover);
      });
    }
  })();
</script>
