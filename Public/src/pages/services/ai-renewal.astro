<style>
    /* ============================================ */
    /* Hero                                          */
    /* ============================================ */
    .hero {
      padding: 140px 0 120px;
      background:
        linear-gradient(90deg, rgba(240, 253, 249, 0.96) 0%, rgba(240, 253, 249, 0.7) 40%, rgba(240, 253, 249, 0.25) 70%, rgba(227, 245, 237, 0.15) 100%),
        url('/assets/images/ai-renewal/hero-bg.png') no-repeat center right / cover,
        linear-gradient(135deg, #f0fdf9 0%, #e3f5ed 100%);
      text-align: left;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -30%;
      right: -10%;
      width: 50%;
      height: 100%;
      background: radial-gradient(circle, rgba(139, 211, 193, 0.25) 0%, transparent 70%);
      z-index: 0;
      pointer-events: none;
    }
    .hero-inner { position: relative; z-index: 1; max-width: 720px; }
    .hero h1 {
      margin-bottom: 24px;
