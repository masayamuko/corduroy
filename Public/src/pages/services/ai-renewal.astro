      margin: 0 auto 40px;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 18px 46px rgba(22, 97, 78, 0.1);
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(22, 97, 78, 0.08);
    }
    .section-diagram img {
      display: block;
      width: 100%;
      height: auto;
    }
    .section-diagram-dark {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.12);
      box-shadow: 0 22px 52px rgba(6, 14, 11, 0.24);
