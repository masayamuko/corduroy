      position: absolute;
      inset: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .icon-fallback[hidden] { display: none; }
    .icon-asset {
      display: block;
      position: relative;
      z-index: 1;
      object-fit: contain;
    }
    :global(.icon-fallback svg) {
      display: block;
      width: 100%;
      height: 100%;
    }
    .icon-lg .icon-media {
      width: 72px;
      height: 72px;
    }
    .bg-gradient-soft { background: linear-gradient(180deg, #fcfdfc 0%, #f1f7f5 100%); }

    /* ============================================ */
    /* Dark section                                  */
    /* ============================================ */
    .bg-dark { background-color: #35524a; color: #fff; }
