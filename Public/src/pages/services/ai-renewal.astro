---
import Layout from '../../layouts/Layout.astro';

const SERVICE_NAME = 'AI時代のサイトリニューアルサービス';
const SERVICE_SUB = 'AI検索（AIO・LLMO）対応 / ChatGPTで更新できる';
const SERVICE_URL = 'https://www.corduroy.co.jp/services/ai-renewal/';
const SERVICE_DESC = 'WordPressなどの既存サイトを、AI検索（AIO・LLMO）に強い構造へリニューアル。ChatGPTやCodexから自分で更新できるサイトに変えます。買い切り10万円から。';
const CLOUDINARY_ICON_BASE = 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1/corduroy/services/ai-renewal/v2/icons';
const CLOUDINARY_DIAGRAM_BASE = 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1/corduroy/services/ai-renewal/v2/diagrams';
const CLOUDINARY_HERO_BASE = 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1/corduroy/services/ai-renewal/v2/hero';
const iconUrl = (slug) => `${CLOUDINARY_ICON_BASE}/${slug}.png`;
const diagramUrl = (slug) => `${CLOUDINARY_DIAGRAM_BASE}/${slug}.png`;
const heroUrl = (slug) => `${CLOUDINARY_HERO_BASE}/${slug}.png`;
const ICON_ONLOAD = "this.previousElementSibling && (this.previousElementSibling.hidden = true);";
const ICON_ONERROR = "this.hidden = true;";
const fallbackSvg = (name) => ({
  sprout: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="14" y="46" width="36" height="8" rx="4" fill="currentColor" opacity=".16"/><path d="M32 44V24" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/><path d="M31 27C25 27 21 22 20 16c8 0 13 3 15 10Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><path d="M33 31c7 0 11-5 12-11-8 0-13 3-15 9Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/></svg>',
  note: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="14" y="10" width="28" height="40" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M22 22h12M22 30h12M22 38h8" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/><path d="m40 40 9-9 5 5-9 9-7 2 2-7Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/></svg>',
  tool: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="12" y="14" width="24" height="16" rx="4" stroke="currentColor" stroke-width="3.5"/><rect x="12" y="34" width="18" height="16" rx="4" stroke="currentColor" stroke-width="3.5"/><path d="M40 17c4 0 7 3 7 7 0 1-.2 2-.6 3l5.6 5.6-4.2 4.2-5.6-5.6c-1 .4-2 .6-3 .6-4 0-7-3-7-7s3-8 7-8Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/></svg>',
  decline: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="10" y="12" width="44" height="32" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M18 24h28" stroke="currentColor" stroke-width="3.5"/><path d="m18 40 10-9 8 5 10-12" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  slow: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="10" y="14" width="34" height="24" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M22 45h12c6 0 10-3 10-7 0-4-4-7-10-7h-9c-3 0-6 2-7 5l-2 5" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="24" cy="47" r="2.5" fill="currentColor"/><circle cx="38" cy="47" r="2.5" fill="currentColor"/></svg>',
  pen: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M16 18h18M16 28h18M16 38h12" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/><path d="m36 18 10-10 10 10-24 24-12 4 4-12 12-12Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/></svg>',
  phone: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M24 15c2 7 6 13 11 18s11 9 18 11l-5 10c-1 2-4 3-6 2C24 51 13 40 8 22c-1-2 0-5 2-6l10-5Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><circle cx="49" cy="18" r="7" stroke="currentColor" stroke-width="3.5"/><path d="M49 14v4l3 2" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>',
  robot: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="16" y="16" width="22" height="28" rx="6" stroke="currentColor" stroke-width="3.5"/><circle cx="24" cy="28" r="2.5" fill="currentColor"/><circle cx="32" cy="28" r="2.5" fill="currentColor"/><path d="M27 16v-5M44 18l3 6 6 3-6 3-3 6-3-6-6-3 6-3 3-6Z" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  wallet: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="10" y="18" width="38" height="28" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M40 26h14v12H40a6 6 0 1 1 0-12Z" stroke="currentColor" stroke-width="3.5"/><circle cx="46" cy="32" r="2" fill="currentColor"/></svg>',
  mirror: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="14" y="12" width="36" height="18" rx="5" stroke="currentColor" stroke-width="3.5"/><path d="M20 21h8M36 21h8M18 38c5-5 10-7 14-7s9 2 14 7M18 46c5-5 10-7 14-7s9 2 14 7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>',
  blueprint: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="12" y="12" width="40" height="40" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M24 12v40M40 12v40M12 24h40M12 40h24" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>',
  envelope: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="10" y="18" width="44" height="28" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="m14 22 18 14 18-14" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 30h20" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" opacity=".45"/></svg>',
  magnifier: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M14 20h22M14 30h16M14 40h12" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/><circle cx="40" cy="34" r="10" stroke="currentColor" stroke-width="3.5"/><path d="m47 41 7 7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>',
  chat: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M14 18h24c6 0 10 4 10 10v6c0 6-4 10-10 10H28l-10 8v-8h-4c-6 0-10-4-10-10v-6c0-6 4-10 10-10Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><path d="M46 14l2 4 4 2-4 2-2 4-2-4-4-2 4-2 2-4Z" fill="currentColor"/></svg>',
  mic: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="24" y="12" width="16" height="24" rx="8" stroke="currentColor" stroke-width="3.5"/><path d="M18 30c0 8 6 14 14 14s14-6 14-14M32 44v8M24 52h16" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/><path d="M45 18h8M45 26h6" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" opacity=".45"/></svg>',
  rocket: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M36 12c8 4 12 12 12 20-8 0-16 4-20 12-8-8-8-24 8-32Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><path d="M28 36 18 46l-2-12 10-10M38 46l10-10 2 12-12-2Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><circle cx="38" cy="24" r="3" fill="currentColor"/></svg>',
  camera: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="10" y="18" width="44" height="28" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M20 18 24 12h16l4 6" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><circle cx="32" cy="32" r="8" stroke="currentColor" stroke-width="3.5"/></svg>',
  palette: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M32 12c12 0 22 8 22 18s-6 10-10 10h-4c-3 0-5 2-5 5 0 4-3 7-8 7-11 0-19-9-19-20S19 12 32 12Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><circle cx="23" cy="24" r="2.5" fill="currentColor"/><circle cx="32" cy="20" r="2.5" fill="currentColor"/><circle cx="40" cy="25" r="2.5" fill="currentColor"/><circle cx="23" cy="34" r="2.5" fill="currentColor"/></svg>',
  newsite: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="10" y="14" width="34" height="36" rx="6" stroke="currentColor" stroke-width="3.5"/><path d="M20 26h14M20 34h10M50 20v16M42 28h16" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>',
  handshake: '<svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="m14 24 10-8 8 8 8-8 10 8-8 8-4-4-6 6-6-6-4 4-8-8Z" stroke="currentColor" stroke-width="3.5" stroke-linejoin="round"/><path d="m24 32 8 8 8-8M18 40l8 8h12l8-8" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
})[name];
---

<Layout
    title={`${SERVICE_NAME}｜株式会社コールテン`}
    description={SERVICE_DESC}
    canonicalUrl={SERVICE_URL}
    ogUrl={SERVICE_URL}
>
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "AIサイトリニューアル",
      "provider": {
        "@type": "Organization",
        "name": "株式会社コールテン",
        "url": "https://www.corduroy.co.jp/"
      },
      "name": SERVICE_NAME,
      "description": SERVICE_DESC,
      "url": SERVICE_URL,
      "areaServed": { "@type": "Country", "name": "Japan" },
      "offers": [
        { "@type": "Offer", "name": "単発買い切り", "price": "100000", "priceCurrency": "JPY", "description": "サイト移管 + AI検索対応 + 動画講座" },
        { "@type": "Offer", "name": "Easy管理費", "price": "10000", "priceCurrency": "JPY", "description": "月額・チャット質問対応" },
        { "@type": "Offer", "name": "詰まり対応", "price": "20000", "priceCurrency": "JPY", "description": "月額・チャットで詰まり伴走" }
      ]
    })} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://www.corduroy.co.jp/" },
        { "@type": "ListItem", "position": 2, "name": SERVICE_NAME, "item": SERVICE_URL }
      ]
    })} />
    <script slot="head" type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "WordPress以外のサイトでも移管できますか？", "acceptedAnswer": { "@type": "Answer", "text": "はい。WordPress、Wix、Jimdo、ペライチなど、ほとんどのCMSから移管できます。事前に既存サイトを拝見してご判断します。" } },
        { "@type": "Question", "name": "本当に自分で更新できるようになりますか？", "acceptedAnswer": { "@type": "Answer", "text": "動画講座で操作の流れを覚えていただきます。文字を変える・画像を差し替える・新しい記事を追加するレベルなら、ほとんどの方が一週間で慣れます。詰まったときのために月額のサポートプランもご用意しています。" } },
        { "@type": "Question", "name": "Windowsパソコンでも使えますか？", "acceptedAnswer": { "@type": "Answer", "text": "はい、Mac/Windows両方で使えます。Windowsの場合、初期セットアップを丁寧にお手伝いします。" } },
        { "@type": "Question", "name": "AI検索で本当に上位に表示されるようになりますか？", "acceptedAnswer": { "@type": "Answer", "text": "AI検索（AIOやLLMO）は仕組み上、構造化された情報を持つサイトが引用されやすくなります。私たちが整える土台はその前提条件です。ただし内容・専門性・更新頻度も重要なので、上位表示を保証するものではありません。" } },
        { "@type": "Question", "name": "月額プランに最低契約期間はありますか？", "acceptedAnswer": { "@type": "Answer", "text": "ありません。月単位でいつでも開始・停止できます。一度買い切りでお渡ししたサイトはお客様のものなので、サポートを止めても運用は続けられます。" } },
        { "@type": "Question", "name": "既存のドメインのまま移管できますか？", "acceptedAnswer": { "@type": "Answer", "text": "はい、現在お使いのドメインをそのまま新しいサイトに付け替えます。ドメインの設定変更もこちらでサポートします。" } },
        { "@type": "Question", "name": "他社のホームページ制作と比べて、なぜこの価格でできるのですか？", "acceptedAnswer": { "@type": "Answer", "text": "ChatGPTやCodexなどのAIツールをフル活用して制作工程を圧縮しているためです。同等の移管・AI検索対応サービスは国内相場で初期30万〜100万円が一般的です。" } },
        { "@type": "Question", "name": "AI顧問プランとどう違いますか？", "acceptedAnswer": { "@type": "Answer", "text": "本サービスはサイトの『移管と更新基盤づくり』を一括でお渡しするものです。AI顧問はサイトに限らず事業全体のAI活用、SEO/AIO戦略、第二の自分づくりまで幅広く伴走します。サイト更新で詰まる程度の相談なら本サービスのサポートプランで十分です。" } },
        { "@type": "Question", "name": "セキュリティは大丈夫ですか？", "acceptedAnswer": { "@type": "Answer", "text": "Vercel・GitHubといった海外大手のインフラを使うため、WordPressより一般的にセキュリティ強度は高くなります。プラグインの脆弱性に悩むこともなくなります。" } },
        { "@type": "Question", "name": "サポートを使わずに自分で運用したい場合はどうなりますか？", "acceptedAnswer": { "@type": "Answer", "text": "可能です。ご自身でVercel（月額3,000円程度のサーバー代）を契約していただければ、買い切りの10万円のみで運用できます。設定はこちらでお渡しします。" } }
      ]
    })} />

    <main>
        <!-- 1. Hero -->
        <section class="hero">
          <div class="container hero-inner">
            <div class="fade-up">
              <div class="icon-lg">
                <span class="icon-media" aria-hidden="true">
                  <span class="icon-fallback" set:html={fallbackSvg('sprout')} />
                  <img class="icon-asset" src={iconUrl('sprout-renewal')} alt="" width="48" height="48" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} />
                </span>
              </div>
              <div class="hero-tag">For WordPress Users</div>
              <h1>AI時代のサイトに、リニューアル。</h1>
              <p class="hero-sub">AI検索（AIO・LLMO）に強い構造へ。<br>ChatGPT<sup class="ref">※</sup>から自分で更新できるサイトに変えます。</p>
              <div class="hero-cta">
                <a class="btn" href="#contact">無料の資料を受け取る</a>
              </div>
            </div>
          </div>
        </section>

        <!-- 1.5 Big Wins -->
        <section class="big-wins">
          <div class="container">
            <div class="section-head fade-up">
              <small>Big Wins</small>
              <h2>あなたのサイトに、<br class="sp-only">起こる2つのこと。</h2>
            </div>
            <div class="big-wins-grid">
              <div class="big-win-card fade-up">
                <div class="big-win-num">01</div>
                <div class="big-win-emoji">
                  <span class="icon-media" aria-hidden="true">
                    <span class="icon-fallback" set:html={fallbackSvg('note')} />
                    <img class="icon-asset" src={iconUrl('note-drafting')} alt="" width="64" height="64" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} />
                  </span>
                </div>
                <h3>記事を書く・更新する<br>手間が、激減する。</h3>
                <p>あなたの<strong>「型」と「方針」</strong>をAIに覚えさせれば、AIエージェントが記事の下書きを仕上げてくれる。あなたは確認してボタンを押すだけ。<br><br><span class="big-win-tagline">「書く時間がない」が<br>「次は何を発信しよう」に変わります。</span></p>
              </div>
              <div class="big-win-card fade-up">
                <div class="big-win-num">02</div>
                <div class="big-win-emoji">
                  <span class="icon-media" aria-hidden="true">
                    <span class="icon-fallback" set:html={fallbackSvg('tool')} />
                    <img class="icon-asset" src={iconUrl('tool-self-edit')} alt="" width="64" height="64" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} />
                  </span>
                </div>
                <h3>サイトを、<br>自分の手元に取り戻す。</h3>
                <p>「ちょっと文言を変えたい」「このページ追加したい」「デザインを少し変えたい」が、<strong>AIに聞きながら自分でできる</strong>ようになる。<br><br><span class="big-win-tagline">プログラマーじゃなくていい。<br>制作会社に預けなくていい。</span></p>
              </div>
            </div>
          </div>
        </section>

        <!-- 2. Pain (共感) -->
        <section class="container">
          <div class="section-head fade-up">
            <small>Pain</small>
            <h2>こんなお悩み、ありませんか？</h2>
            <p>WordPressなどで自社サイトを運営している方から、よく聞くお悩みです。</p>
          </div>
          <figure class="section-diagram fade-up">
            <img src={diagramUrl('pain-points-radial')} alt="更新停滞、表示速度、外注依存、AI検索不安などの悩みが広がる構図を示した図解" width="1200" height="675" loading="lazy" />
          </figure>
          <div class="grid cols-3">
            <div class="card fade-up">
              <h3 class="heading-with-icon"><span class="heading-icon" aria-hidden="true"><span class="icon-fallback" set:html={fallbackSvg('decline')} /><img class="icon-asset" src={iconUrl('decline-stale-site')} alt="" width="28" height="28" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} /></span><span class="heading-text">サイトの更新が止まっている</span></h3>
              <p class="mini">忙しくて記事が書けない／プラグインの更新が怖くて触れない／何ヶ月も放置している。</p>
            </div>
            <div class="card fade-up">
              <h3 class="heading-with-icon"><span class="heading-icon" aria-hidden="true"><span class="icon-fallback" set:html={fallbackSvg('slow')} /><img class="icon-asset" src={iconUrl('slow-heavy-site')} alt="" width="28" height="28" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} /></span><span class="heading-text">表示が遅い・重い</span></h3>
              <p class="mini">スマホで開くとカクつく。プラグインを入れすぎて動作が重い。Googleの評価も気になる。</p>
            </div>
            <div class="card fade-up">
              <h3 class="heading-with-icon"><span class="heading-icon" aria-hidden="true"><span class="icon-fallback" set:html={fallbackSvg('pen')} /><img class="icon-asset" src={iconUrl('pen-formatting-burden')} alt="" width="28" height="28" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} /></span><span class="heading-text">記事を書く・貼るのが大変</span></h3>
              <p class="mini">ChatGPTで原稿は書けても、WordPressに貼り付けて整える作業に時間が溶ける。</p>
            </div>
            <div class="card fade-up">
              <h3 class="heading-with-icon"><span class="heading-icon" aria-hidden="true"><span class="icon-fallback" set:html={fallbackSvg('phone')} /><img class="icon-asset" src={iconUrl('phone-vendor-wait')} alt="" width="28" height="28" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} /></span><span class="heading-text">外注先と連絡が取りづらい</span></h3>
              <p class="mini">小さな修正で何日も待たされる。費用もかさむ。自分でできるところは自分でやりたい。</p>
            </div>
            <div class="card fade-up">
              <h3 class="heading-with-icon"><span class="heading-icon" aria-hidden="true"><span class="icon-fallback" set:html={fallbackSvg('robot')} /><img class="icon-asset" src={iconUrl('robot-search-anxiety')} alt="" width="28" height="28" loading="lazy" aria-hidden="true" onload={ICON_ONLOAD} onerror={ICON_ONERROR} /></span><span class="heading-text">AI検索に対応できているか不安</span></h3>
              <p class="mini">ChatGPTやGoogleのAI Overviewでウチの会社が出てこない。何か対策が要るらしいけど、何から始めれば？</p>
            </div>
