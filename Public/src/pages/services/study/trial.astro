---
import Layout from '../../../layouts/Layout.astro';

const title = "体験講座（3,000円）｜AI講座（福岡）｜株式会社コールテン";
const description = "AIデモ＋第二の自分デモを1時間で体感する体験講座。参加費3,000円。福岡・対面開催。「自分にもできる」という自信を持ち帰ってください。";

const trialSchedule = [
  { date: '2026.04.18', day: '土', time: '10:00-11:30', place: '赤坂駅から徒歩すぐ' },
  { date: '2026.04.22', day: '水', time: '19:00-20:30', place: '赤坂駅から徒歩すぐ' },
  { date: '2026.05.16', day: '土', time: '10:00-11:30', place: '赤坂駅から徒歩すぐ' },
  { date: '2026.05.27', day: '水', time: '19:00-20:30', place: '赤坂駅から徒歩すぐ' },
];
---

<Layout title={title} description={description}>

  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="fade-up">
          <div class="icon-lg">🌱</div>
          <div class="hero-badge">参加費 3,000円 / 福岡・対面 / 月1〜2回</div>
          <h1>体験講座</h1>
          <p class="lead">
            AIのデモと「第二の自分」の実例を、<br>
            <b>あなた自身の目で確かめてください。</b>
          </p>
          <p class="lead-sub">「わかりやすい」「自分にもできる」という感覚を、1時間で持ち帰れます。</p>
          <div class="hero-cta">
            <a class="btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">LINE登録して申し込む</a>
            <a class="btn secondary" href="#schedule">開催日程を見る →</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== WHAT YOU GET ===== */-->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Experience</small>
          <h2>体験会でわかること</h2>
          <p>押し売りなし。「自分に合うかどうか」を確かめてから決めてください。</p>
        </div>
        <div class="exp-grid fade-up">
          <div class="exp-item">
            <div class="exp-num">01</div>
            <div class="exp-icon">⚡</div>
            <h3>AIでこんなことができる</h3>
            <p class="mini">「こんなことまでできるの？」という活用例をライブデモで見せます。文章・アイデア・分析・タスク自動化まで、AIの可能性を具体的に体感できます。</p>
          </div>
          <div class="exp-item">
            <div class="exp-num">02</div>
            <div class="exp-icon">🤝</div>
            <h3>自分の情報を入れると変わる</h3>
            <p class="mini">「情報ゼロのAI」と「自分を覚えたAI」の出力を並べて比較。自分専用のAIがどれだけ使いやすくなるか、その差を体感できます。</p>
          </div>
          <div class="exp-item">
            <div class="exp-num">03</div>
            <div class="exp-icon">🚀</div>
            <h3>3ヶ月でどこまで行けるか</h3>
            <p class="mini">コールテン講師のリアルな活用事例と受講生の変化を紹介。「3ヶ月後の自分」のイメージを具体的に持ち帰れます。</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== FLOW ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Program</small>
        <h2>当日の流れ（約1時間）</h2>
      </div>
      <div class="trial-flow fade-up">
        <div class="tf-item">
          <div class="tf-tag">Part 1</div>
          <div class="tf-content">
            <strong>⚡ AIデモ体験（20分）</strong>
            <p class="mini">実際にChatGPTを使いながら「こんなことができる」を体感。参加者も一緒に触れます。</p>
          </div>
        </div>
        <div class="tf-arrow">↓</div>
        <div class="tf-item">
          <div class="tf-tag">Part 2</div>
          <div class="tf-content">
            <strong>🤝 第二の自分デモ（20分）</strong>
            <p class="mini">何も入れていないAI vs 自分情報を入れたAI の出力比較。「自分専用になる」感覚をその場で体験します。</p>
          </div>
        </div>
        <div class="tf-arrow">↓</div>
        <div class="tf-item">
          <div class="tf-tag">Part 3</div>
          <div class="tf-content">
            <strong>🚀 ストーリー＋プログラム案内（20分）</strong>
            <p class="mini">コールテン講師のAI活用ストーリー、受講生の変化、3ヶ月プログラムの内容・価格を説明します。申し込みはその場でも後日でも。</p>
          </div>
        </div>
      </div>
      <div class="trial-note fade-up">
        <span>💡</span>
        <p>体験会への参加はあくまで自由参加です。プログラムへの申し込みは一切強制しません。「まず雰囲気を見たい」という方のための場所です。</p>
      </div>
    </section>


    <!-- ===== SCHEDULE ===== -->
    <section id="schedule" class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Schedule</small>
          <h2>次回開催日程</h2>
          <p>毎月1〜2回・福岡市内（赤坂エリア）で開催しています。</p>
        </div>
        <div class="sched-list fade-up">
          {trialSchedule.map((s) => (
            <div class="sched-item">
              <div class="sched-date">
                <span class="sched-md">{s.date}</span>
                <span class="sched-day">（{s.day}）</span>
              </div>
              <div class="sched-detail">
                <span class="sched-time">{s.time}</span>
                <span class="sched-place">📍 {s.place}</span>
              </div>
              <a class="btn-sm" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">LINE で申込</a>
            </div>
          ))}
        </div>
        <p class="sched-note fade-up">※ 日程は変更になる場合があります。最新情報はLINEでご案内します。</p>
      </div>
    </section>


    <!-- ===== PACKAGE CTA ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Next Step</small>
        <h2>体験後に選べる次のステップ</h2>
      </div>
      <div class="next-grid fade-up">
        <div class="next-item next-main">
          <div class="next-icon">🎯</div>
          <h3>3ヶ月プログラムに参加する</h3>
          <p class="mini">体験会で「これだ」と思ったら、そのまま3ヶ月プログラムへ。次のスタートは6月（2026年）です。</p>
          <div class="next-price">108,000円（税込）</div>
          <a class="btn" href="/services/study">プログラムの詳細を見る →</a>
        </div>
        <div class="next-item">
          <div class="next-icon">💬</div>
          <h3>もう少し話を聞きたい</h3>
          <p class="mini">「自分に合うか不安」「もっと詳しく聞きたい」という方は、LINEでご相談ください。</p>
          <a class="btn secondary" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">LINEで相談する</a>
        </div>
      </div>
    </section>


    <!-- ===== FAQ ===== -->
    <section class="container faq" style="background:#fff;">
      <div class="section-head fade-up">
        <small>FAQ</small>
        <h2>よくあるご質問</h2>
      </div>
      <div class="faq-items fade-up">
        <details open>
          <summary>参加費は本当に3,000円だけですか？</summary>
          <p>はい、体験講座の参加費は3,000円（税込）のみです。それ以外の費用は一切かかりません。</p>
        </details>
        <details>
          <summary>体験講座では何をしますか？</summary>
          <p>約1時間の中で、AIのライブデモ体験、「第二の自分」の実例紹介、3ヶ月プログラムの案内を行います。実際にAIを触りながら「こんなことができるんだ」を体感していただけます。</p>
        </details>
        <details>
          <summary>所要時間はどのくらいですか？</summary>
          <p>約1時間〜1時間半です。終了後に質問タイムを設けていますので、気になることがあれば気軽にお聞きください。</p>
        </details>
        <details>
          <summary>予約は必要ですか？</summary>
          <p>はい、事前予約制です。<a href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener">LINE</a>に登録いただき、そこからお申し込みください。定員がありますので、お早めのご予約をおすすめしています。</p>
        </details>
        <details>
          <summary>AIを触ったことがなくても大丈夫ですか？</summary>
          <p>はい、まったく問題ありません。むしろ「AIって何ができるの？」という方にこそ来ていただきたい場です。専門知識やパソコンの高いスキルは不要です。</p>
        </details>
        <details>
          <summary>体験講座に参加したら、プログラムへの申し込みは必須ですか？</summary>
          <p>いいえ、一切強制しません。体験講座はあくまで「自分に合うかどうか」を確かめる場です。雰囲気を見てから判断していただいて大丈夫です。無理な勧誘はありません。</p>
        </details>
        <details>
          <summary>福岡以外での開催予定はありますか？</summary>
          <p>現在は福岡市内（赤坂エリア）での対面開催のみです。コールテンは「対面で伝わるもの」を大切にしているため、まずは福岡にお越しいただける方が対象となります。今後の展開については<a href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener">LINE</a>で最新情報をお届けしています。</p>
        </details>
      </div>
    </section>

    <!-- ===== LINE CTA ===== -->
    <section class="bg-contact">
      <div class="container">
        <div class="section-head fade-up">
          <small>Apply</small>
          <h2>まずはLINE登録から</h2>
          <p>体験会の申し込みはLINEから受け付けています。<br>無料説明会の動画もあわせてご覧いただけます。</p>
        </div>
        <div class="card fade-up" style="max-width:560px; margin:0 auto; text-align:center;">
          <p class="mini" style="margin-bottom:24px;">無理な勧誘はありません。まずは気軽にどうぞ。</p>
          <a class="btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">LINE登録して申し込む</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
section { padding: 100px 0; position: relative; }

.section-head { text-align: center; margin-bottom: 72px; }
.section-head small {
  display: inline-block;
  color: var(--accent);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 16px;
  font-family: "Space Grotesk", sans-serif;
  font-size: 12px;
}
.section-head p { max-width: 600px; margin: 0 auto; color: var(--text-light); }

/* Hero */
.hero {
  padding: 160px 0 140px;
  background-color: var(--cream);
  background-image:
    radial-gradient(circle, rgba(212, 160, 77, 0.6) 2px, transparent 2.5px),
    radial-gradient(circle, rgba(22, 97, 78, 0.3) 2px, transparent 2.5px);
  background-size: 40px 40px;
  background-position: 0 0, 20px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: "";
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2316614e' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 0.5;
  mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
  -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 100%);
  pointer-events: none;
}
.hero-inner {
  display: flex; flex-direction: column; align-items: center; gap: 32px;
  position: relative; z-index: 1;
}
.hero-badge {
  display: inline-block;
  background: rgba(22, 97, 78, 0.08);
  color: var(--sea);
  font-size: 13px;
  font-weight: 700;
  padding: 6px 16px;
  border-radius: 99px;
  margin-bottom: 8px;
  letter-spacing: 0.05em;
}
.hero h1 {
  margin-bottom: 16px;
  background: linear-gradient(135deg, var(--ink) 0%, var(--sea) 60%, var(--ink) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.3;
}
.hero p.lead { font-size: 20px; color: var(--text); max-width: 560px; margin: 0 auto 4px; line-height: 1.9; }
.lead-sub { font-size: 15px; color: var(--text-light); margin-bottom: 32px !important; }
.hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.sp-only { display: none; }

.icon-lg {
  font-size: 64px; margin-bottom: 24px; color: var(--sea); line-height: 1;
  display: inline-flex; align-items: center; justify-content: center;
  width: 120px; height: 120px;
  background: linear-gradient(135deg, #fff 0%, var(--mint) 100%);
  border-radius: 40px; border: 1px solid var(--white);
  box-shadow: 0 16px 32px rgba(22, 97, 78, 0.1), inset 0 2px 4px rgba(255, 255, 255, 1);
}

/* Backgrounds */
.bg-gradient-soft { background: linear-gradient(180deg, var(--cream) 0%, #f1f7f5 100%); }
.bg-contact { background: linear-gradient(135deg, #f0f7f4 0%, #e6f3ed 100%); }

/* Card */
.card {
  background: #fff;
  border: 1px solid rgba(22, 97, 78, 0.08);
  border-radius: 24px; padding: 40px;
  box-shadow: var(--shadow-sm);
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative; overflow: hidden;
  display: flex; flex-direction: column;
}
.card .mini { font-size: 16px; color: var(--text-light); line-height: 1.8; }

/* Experience Grid */
.exp-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  max-width: 900px; margin: 0 auto;
}
.exp-item {
  background: #fff;
  border: 1px solid rgba(22, 97, 78, 0.08);
  border-radius: 20px; padding: 32px 28px;
  box-shadow: var(--shadow-sm); position: relative;
  transition: all 0.3s ease;
}
.exp-item:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
.exp-num {
  font-family: "Space Grotesk", sans-serif; font-size: 11px; font-weight: 700;
  color: var(--accent); letter-spacing: 0.1em; margin-bottom: 12px;
}
.exp-icon { font-size: 36px; margin-bottom: 16px; }
.exp-item h3 { font-size: 17px; font-weight: 700; color: var(--ink); margin-bottom: 10px; }
.exp-item .mini { font-size: 14px; color: var(--text-light); line-height: 1.7; }

/* Trial Flow */
.trial-flow {
  max-width: 600px; margin: 0 auto;
  display: flex; flex-direction: column;
}
.tf-item {
  display: flex; gap: 20px; align-items: flex-start;
  background: #fff; border: 1px solid rgba(22, 97, 78, 0.08);
  border-radius: 20px; padding: 24px 28px; box-shadow: var(--shadow-sm);
}
.tf-tag {
  flex-shrink: 0;
  font-family: "Space Grotesk", sans-serif; font-size: 11px; font-weight: 700;
  color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase;
  padding-top: 4px; width: 48px;
}
.tf-content strong { display: block; font-size: 16px; margin-bottom: 6px; color: var(--ink); }
.tf-content .mini { font-size: 14px; color: var(--text-light); line-height: 1.7; margin: 0; }
.tf-arrow { text-align: center; font-size: 20px; color: var(--sea); opacity: 0.3; margin: 6px 0; }

.trial-note {
  display: flex; gap: 12px; align-items: flex-start;
  max-width: 600px; margin: 32px auto 0;
  background: #f9fbfa; border-radius: 16px; padding: 16px 20px;
  font-size: 13px; color: var(--text-light); line-height: 1.7;
}
.trial-note span { font-size: 18px; flex-shrink: 0; }
.trial-note p { margin: 0; }

/* Schedule */
.sched-list { max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px; }
.sched-item {
  display: flex; align-items: center; gap: 20px;
  background: #fff; border: 1px solid rgba(22, 97, 78, 0.1);
  border-radius: 16px; padding: 18px 24px; box-shadow: var(--shadow-sm);
}
.sched-date { flex-shrink: 0; display: flex; align-items: baseline; gap: 4px; }
.sched-md { font-size: 16px; font-weight: 700; color: var(--ink); }
.sched-day { font-size: 13px; color: var(--text-light); }
.sched-detail { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.sched-time { font-size: 14px; color: var(--sea); font-weight: 600; }
.sched-place { font-size: 13px; color: var(--text-light); }
.sched-note { text-align: center; font-size: 12px; color: var(--text-light); margin-top: 16px; }

.btn-sm {
  display: inline-block;
  padding: 8px 16px; border-radius: 8px;
  background: var(--sea); color: #fff;
  font-size: 13px; font-weight: 700;
  text-decoration: none;
  transition: all 0.2s ease;
  white-space: nowrap;
}
.btn-sm:hover { background: var(--ink); }

/* Next Grid */
.next-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
  max-width: 800px; margin: 0 auto;
}
.next-item {
  background: #fff; border: 1px solid rgba(22, 97, 78, 0.1);
  border-radius: 24px; padding: 36px 32px;
  box-shadow: var(--shadow-sm); text-align: center;
  display: flex; flex-direction: column; gap: 12px;
}
.next-main {
  border-color: rgba(22, 97, 78, 0.25);
  box-shadow: 0 8px 32px rgba(22, 97, 78, 0.08);
}
.next-icon { font-size: 40px; }
.next-item h3 { font-size: 18px; font-weight: 700; color: var(--ink); }
.next-item .mini { font-size: 14px; color: var(--text-light); line-height: 1.7; }
.next-price {
  font-family: "Space Grotesk", sans-serif; font-size: 22px; font-weight: 700;
  color: var(--sea); margin: 4px 0;
}
.next-item .btn, .next-item .btn.secondary { width: 100%; }

/* Responsive */
@media (max-width: 640px) {
  .sp-only { display: inline; }
  .exp-grid { grid-template-columns: 1fr; }
  .next-grid { grid-template-columns: 1fr; }
  .sched-item { flex-wrap: wrap; }
}
</style>
