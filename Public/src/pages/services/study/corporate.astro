---
import Layout from '../../../layouts/Layout.astro';

const title = "法人向けAI研修｜株式会社コールテン";
const description = "チーム全体のAIリテラシー底上げから、業務に根ざした活用設計まで。現場に合わせたカスタム研修を提供します。福岡・全国対応。";
---

<Layout title={title} description={description} canonicalUrl="https://www.corduroy.co.jp/services/study/corporate/" ogUrl="https://www.corduroy.co.jp/services/study/corporate/">
  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/"},
        {"@type": "ListItem", "position": 2, "name": "サービス", "item": "https://www.corduroy.co.jp/services/"},
        {"@type": "ListItem", "position": 3, "name": "AI講座", "item": "https://www.corduroy.co.jp/services/study/"},
        {"@type": "ListItem", "position": 4, "name": "法人研修"}
      ]
    }
  </script>
  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="container hero-inner">
        <div class="fade-up">
          <div class="hero-eyebrow">
            <span class="eyebrow-dot"></span>
            <span>法人向けAI研修</span>
            <span class="eyebrow-sep">|</span>
            <span>福岡発 · 全国対応</span>
          </div>
          <h1>
            <span class="h1-pre">チームで学ぶと、</span>
            <span class="h1-main">AI活用が<mark>定着</mark>する。</span>
            <span class="h1-post">現場に根ざした法人向けAI研修。</span>
          </h1>
          <div class="hero-ornament">
            <span class="orn-line"></span>
            <span class="orn-mark">✦</span>
            <span class="orn-line"></span>
          </div>
          <p class="lead">
            「研修を受けたけど使えない」にならないために。<br>
            現場の業務と温度感に合わせて、<b>使い続けられる</b>形に設計します。
          </p>
          <div class="hero-cta">
            <a class="btn" href="/contact">まずは相談する</a>
            <a class="btn secondary" href="#program">研修の内容を見る →</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== FOR WHO ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>For You</small>
          <h2>こんな企業・チームへ</h2>
        </div>
        <div class="forwhom-grid fade-up">
          <div class="forwhom-item">
            <span class="fw-check">✔</span>
            <p>AIを導入したいが、<b>何から始めればいいかわからない</b></p>
          </div>
          <div class="forwhom-item">
            <span class="fw-check">✔</span>
            <p>研修を受けたが、<b>現場で使われていない</b></p>
          </div>
          <div class="forwhom-item">
            <span class="fw-check">✔</span>
            <p>チーム全体の<b>AIリテラシーを底上げ</b>したい</p>
          </div>
          <div class="forwhom-item">
            <span class="fw-check">✔</span>
            <p>業務に合わせた<b>実践的な活用方法</b>を習得させたい</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== PROGRAMS ===== -->
    <section id="program" class="container">
      <div class="section-head fade-up">
        <small>Programs</small>
        <h2>研修プログラムの種類</h2>
        <p>規模・目的・業種に合わせてカスタマイズします。<br>まずはご相談ください。</p>
      </div>

      <div class="programs-grid fade-up">
        <div class="program-card">
          <div class="program-icon">🌱</div>
          <div class="program-tag">入門</div>
          <h3>AI基礎理解ワークショップ</h3>
          <div class="program-meta">
            <span>📅 半日〜1日</span>
            <span>👥 〜20名</span>
          </div>
          <p class="mini">AIとは何か・得意不得意・リスクの取り方を正しく理解します。「使ったことがない」チームのスタートラインに最適。</p>
          <ul class="program-list">
            <li>AIの仕組みと特性の理解</li>
            <li>プロンプトの基本型を習得</li>
            <li>業務に使える活用事例を体験</li>
          </ul>
        </div>

        <div class="program-card program-card-featured">
          <div class="program-featured-label">おすすめ</div>
          <div class="program-icon">🎯</div>
          <div class="program-tag">実践</div>
          <h3>業務活用 実践研修</h3>
          <div class="program-meta">
            <span>📅 複数回（月1〜2回）</span>
            <span>👥 5〜15名</span>
          </div>
          <p class="mini">実際の業務フローにAIを組み込む設計を一緒に行います。「知っている」から「使い続けている」へ。</p>
          <ul class="program-list">
            <li>業務フローの棚卸し・AI化ポイント特定</li>
            <li>実際の業務でのプロンプト設計</li>
            <li>チームでの活用ルール策定</li>
            <li>定期フォローアップ</li>
          </ul>
        </div>

        <div class="program-card">
          <div class="program-icon">🚀</div>
          <div class="program-tag">推進</div>
          <h3>AI推進人材 育成プログラム</h3>
          <div class="program-meta">
            <span>📅 3〜6ヶ月</span>
            <span>👥 2〜5名（キーパーソン）</span>
          </div>
          <p class="mini">社内でAI活用を牽引できる人材を育成します。個人の3ヶ月プログラムと顧問サポートを組み合わせた法人特化版。</p>
          <ul class="program-list">
            <li>AI活用の設計・提案スキル</li>
            <li>社内展開・合意形成の型</li>
            <li>継続的な学習環境の構築</li>
          </ul>
        </div>
      </div>
    </section>


    <!-- ===== FLOW ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Flow</small>
          <h2>ご依頼の流れ</h2>
        </div>
        <div class="flow-steps fade-up">
          <div class="flow-item">
            <div class="flow-num">01</div>
            <div class="flow-body">
              <strong>ヒアリング・ご相談</strong>
              <p class="mini">現在の状況・課題・チームの規模・ゴールをお聞きします。まずはお気軽にご連絡ください。</p>
            </div>
          </div>
          <div class="flow-arrow">↓</div>
          <div class="flow-item">
            <div class="flow-num">02</div>
            <div class="flow-body">
              <strong>プログラム設計・ご提案</strong>
              <p class="mini">ヒアリングをもとに、カスタマイズした研修プログラムと費用をご提案します。</p>
            </div>
          </div>
          <div class="flow-arrow">↓</div>
          <div class="flow-item">
            <div class="flow-num">03</div>
            <div class="flow-body">
              <strong>実施・フォローアップ</strong>
              <p class="mini">研修実施後も、定着するまでのフォローアップを行います。「やりっぱなし」にしません。</p>
            </div>
          </div>
        </div>
        <div style="text-align:center; margin-top:48px;" class="fade-up">
          <a class="btn" href="/contact">まずは相談する（無料）</a>
        </div>
      </div>
    </section>


    <!-- ===== INSTRUCTOR ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Instructor</small>
        <h2>研修講師について</h2>
      </div>
      <div class="card fade-up" style="max-width:800px; margin:0 auto; display:flex; align-items:center; gap:32px; text-align:left;">
        <div class="instructor-img">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
        </div>
        <div style="flex:1;">
          <small style="display:block; color:var(--sea); font-weight:700; margin-bottom:4px;">株式会社コールテン代表</small>
          <h3>向 雅也</h3>
          <p class="mini" style="margin-top:12px;">
            企業・自社でのAI導入実績あり。現場で使える形への落とし込みを得意とします。<br>
            フリーランス歴10年・コーチ歴3年・日本語教師歴を含む指導歴5年。<br>
            「わかりやすく教える」ことへの徹底したこだわりを、法人研修にも活かします。
          </p>
        </div>
      </div>
    </section>


    <!-- ===== FAQ ===== -->
    <section class="container faq" style="background:#fff;">
      <div class="section-head fade-up">
        <small>FAQ</small>
        <h2>よくあるご質問</h2>
      </div>
      <div class="faq-items fade-up">
        <details open>
          <summary>何名から対応可能ですか？</summary>
          <p>2名から対応可能です。少人数のキーパーソン育成から、部門単位・全社向けまで、規模に合わせてプログラムを設計します。</p>
        </details>
        <details>
          <summary>オンライン研修は可能ですか？</summary>
          <p>はい、オンライン対応も可能です。ただし、AIを実際に触りながら学ぶ内容が多いため、対面のほうが定着率は高い傾向があります。ハイブリッド形式のご相談も承ります。</p>
        </details>
        <details>
          <summary>研修内容はカスタマイズできますか？</summary>
          <p>はい、すべてカスタマイズ前提です。事前のヒアリングで業種・業務フロー・チームの課題をお聞きし、現場に合った内容に設計します。「既製品の研修を流す」ことはしていません。</p>
        </details>
        <details>
          <summary>費用の目安はどのくらいですか？</summary>
          <p>研修の種類・期間・人数・カスタマイズの度合いによって異なります。まずは<a href="/contact">お問い合わせフォーム</a>からご相談ください。ヒアリングの上、お見積もりをお出しします。</p>
        </details>
        <details>
          <summary>研修後のフォローアップはありますか？</summary>
          <p>はい。研修の「やりっぱなし」を防ぐため、定期的なフォローアップを設けています。さらに継続的な支援が必要な場合は、<a href="/services/advisory">AI顧問サービス</a>や<a href="/services/study/community">糸口会（コミュニティ）</a>での継続的なサポートも可能です。</p>
        </details>
        <details>
          <summary>どの業種に対応していますか？</summary>
          <p>業種は問いません。これまでサービス業・教育・士業・NPOなど幅広い業種の方にご利用いただいています。AIは業種を問わず「言葉を扱う仕事」全般に活用できるため、現場の業務に合わせた設計を行います。</p>
        </details>
        <details>
          <summary>社員のITリテラシーが低くても大丈夫ですか？</summary>
          <p>はい、まったく問題ありません。コールテンの研修は「AIを触ったことがない」方を前提に設計しています。代表のMasayaは日本語教師・コーチ出身で、「わかりやすく伝える」ことに徹底的にこだわっています。</p>
        </details>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="bg-contact">
      <div class="container">
        <div class="section-head fade-up">
          <small>Contact</small>
          <h2>まずはお気軽にご相談を</h2>
          <p>費用・内容・日程など、まずはヒアリングからです。<br>押し売りはしません。</p>
        </div>
        <div class="card fade-up" style="max-width:560px; margin:0 auto; text-align:center;">
          <p class="mini" style="margin-bottom:24px;">コンタクトページよりお問い合わせください。</p>
          <a class="btn" href="/contact">相談・お問い合わせはこちら →</a>
        </div>
      </div>
    </section>

    <section class="bg-other">
      <div class="container" style="text-align:center;">
        <p style="color:var(--text-light); margin-bottom:16px; font-size:14px;">AI講座の個人向けプログラムはこちら</p>
        <a class="btn secondary" href="/services/study/">コールテンのAI講座トップへ →</a>
      </div>
    </section>

  </main>
</Layout>

<style>
section { padding: 100px 0; position: relative; }
.section-head { text-align: center; margin-bottom: 64px; }
.section-head small {
  display: inline-block; color: var(--accent); font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 14px;
  font-family: "Space Grotesk", sans-serif; font-size: 12px;
}
.section-head p { max-width: 560px; margin: 0 auto; color: var(--text-light); line-height: 1.8; }

.bg-gradient-soft { background: linear-gradient(180deg, var(--cream) 0%, #f1f7f5 100%); }
.bg-contact { background: linear-gradient(135deg, #f0f7f4 0%, #e6f3ed 100%); }
.bg-other { background: #f7faf9; padding: 48px 0; }

/* Hero */
.hero {
  padding: 130px 0 110px;
  background-color: var(--cream);
  background-image:
    radial-gradient(circle, rgba(212,160,77,0.25) 1.5px, transparent 2px),
    radial-gradient(circle, rgba(22,97,78,0.12) 1.5px, transparent 2px);
  background-size: 40px 40px; background-position: 0 0, 20px 20px;
  text-align: center; position: relative; overflow: hidden;
}
.hero::before {
  content: ""; position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2316614e' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  opacity: 0.4; mask-image: linear-gradient(to bottom, black 0%, transparent 80%);
  -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 80%); pointer-events: none;
}
.hero-glow {
  position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%);
  width: 700px; height: 500px;
  background: radial-gradient(ellipse, rgba(22,97,78,0.05) 0%, transparent 70%);
  pointer-events: none; z-index: 0;
}
.hero-inner { display: flex; flex-direction: column; align-items: center; gap: 0; position: relative; z-index: 1; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,0.92); border: 1px solid rgba(22,97,78,0.15);
  border-radius: 99px; padding: 7px 18px;
  font-size: 11.5px; font-weight: 600; color: var(--sea); margin-bottom: 36px;
  font-family: "Space Grotesk", sans-serif; letter-spacing: 0.08em; text-transform: uppercase;
  box-shadow: 0 2px 12px rgba(22,97,78,0.07), inset 0 1px 0 rgba(255,255,255,0.9);
}
.eyebrow-dot {
  width: 7px; height: 7px; background: var(--accent); border-radius: 50%; flex-shrink: 0;
  box-shadow: 0 0 0 2px rgba(212,160,77,0.25); animation: pulse-dot 2.4s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 0 2px rgba(212,160,77,0.25); }
  50% { box-shadow: 0 0 0 6px rgba(212,160,77,0.08); }
}
.eyebrow-sep { opacity: 0.2; font-weight: 300; }
.hero h1 {
  display: flex; flex-direction: column; align-items: center; gap: 4px; margin-bottom: 0;
  background: none; -webkit-text-fill-color: initial; -webkit-background-clip: initial; background-clip: initial; text-shadow: none;
}
.h1-pre { display: block; font-size: clamp(1rem,2vw,1.25rem); font-weight: 400; color: var(--text-light); letter-spacing: 0.2em; font-family: "Noto Sans JP", sans-serif; line-height: 1; margin-bottom: 4px; }
.h1-main { display: block; font-size: clamp(2.8rem,8vw,5.6rem); font-weight: 700; color: var(--ink); line-height: 1.05; letter-spacing: 0.01em; position: relative; }
.h1-main mark { background: none; color: var(--sea); position: relative; display: inline-block; }
.h1-main mark::after { content: ''; position: absolute; bottom: 2px; left: -2px; right: -2px; height: 10px; background: linear-gradient(90deg, var(--accent) 0%, var(--orange) 100%); opacity: 0.35; border-radius: 4px; z-index: -1; }
.h1-post { display: block; font-size: clamp(1.4rem,3vw,2.4rem); font-weight: 700; letter-spacing: 0.04em; line-height: 1.2; background: linear-gradient(135deg, var(--ink) 0%, var(--sea) 70%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-top: 2px; }
.hero-ornament { display: flex; align-items: center; justify-content: center; gap: 14px; margin: 32px auto 24px; max-width: 220px; }
.orn-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(212,160,77,0.5), transparent); }
.orn-mark { color: var(--accent); font-size: 11px; opacity: 0.7; }
.hero p.lead { font-size: clamp(1rem,1.8vw,1.15rem); color: var(--text); max-width: 500px; margin: 0 auto 32px; line-height: 2.1; }
.hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

/* Card */
.card { background: #fff; border: 1px solid rgba(22,97,78,0.08); border-radius: 24px; padding: 40px; box-shadow: 0 2px 12px rgba(5,32,24,0.04); display: flex; flex-direction: column; }
.card .mini { font-size: 15px; color: var(--text-light); line-height: 1.8; }

/* For whom */
.forwhom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; max-width: 760px; margin: 0 auto; }
.forwhom-item { display: flex; align-items: flex-start; gap: 12px; background: #fff; border: 1px solid rgba(22,97,78,0.1); border-radius: 16px; padding: 20px 24px; box-shadow: 0 2px 8px rgba(5,32,24,0.03); }
.fw-check { flex-shrink: 0; width: 22px; height: 22px; background: var(--sea); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; margin-top: 2px; }
.forwhom-item p { font-size: 15px; line-height: 1.7; color: var(--text); margin: 0; }

/* Programs */
.programs-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; max-width: 960px; margin: 0 auto; }
.program-card { background: #fff; border: 1px solid rgba(22,97,78,0.1); border-radius: 24px; padding: 32px 28px; box-shadow: 0 2px 12px rgba(5,32,24,0.04); position: relative; transition: all 0.3s ease; display: flex; flex-direction: column; gap: 12px; }
.program-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(5,32,24,0.08); }
.program-card-featured { border-color: rgba(22,97,78,0.25); box-shadow: 0 8px 32px rgba(22,97,78,0.1); }
.program-featured-label { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--sea); color: #fff; font-size: 11px; font-weight: 700; padding: 4px 14px; border-radius: 99px; font-family: "Space Grotesk", sans-serif; letter-spacing: 0.05em; white-space: nowrap; }
.program-icon { font-size: 32px; }
.program-tag { display: inline-block; background: rgba(22,97,78,0.07); color: var(--sea); border-radius: 99px; padding: 3px 12px; font-size: 11px; font-weight: 700; font-family: "Space Grotesk", sans-serif; width: fit-content; }
.program-card h3 { font-size: 17px; font-weight: 700; color: var(--ink); margin: 0; }
.program-meta { display: flex; gap: 12px; flex-wrap: wrap; }
.program-meta span { font-size: 12px; color: var(--text-light); }
.program-card .mini { font-size: 13px; color: var(--text-light); line-height: 1.7; }
.program-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; margin-top: auto; }
.program-list li { font-size: 13px; color: var(--text); padding-left: 16px; position: relative; line-height: 1.6; }
.program-list li::before { content: '›'; position: absolute; left: 0; color: var(--sea); font-weight: 700; }

/* Flow */
.flow-steps { max-width: 600px; margin: 0 auto; display: flex; flex-direction: column; }
.flow-item { display: flex; gap: 20px; align-items: flex-start; background: #fff; border: 1px solid rgba(22,97,78,0.08); border-radius: 20px; padding: 24px 28px; box-shadow: 0 2px 8px rgba(5,32,24,0.03); }
.flow-num { flex-shrink: 0; font-family: "Space Grotesk", sans-serif; font-size: 22px; font-weight: 700; color: var(--sea); opacity: 0.35; line-height: 1; padding-top: 3px; width: 32px; }
.flow-body strong { display: block; font-size: 16px; margin-bottom: 6px; color: var(--ink); }
.flow-body .mini { font-size: 14px; color: var(--text-light); line-height: 1.7; margin: 0; }
.flow-arrow { text-align: center; font-size: 20px; color: var(--sea); opacity: 0.3; margin: 6px 0 6px 16px; }

/* Instructor */
.instructor-img { flex-shrink: 0; width: 100px; height: 100px; border-radius: 50%; overflow: hidden; border: 4px solid #fff; box-shadow: 0 8px 20px rgba(0,0,0,0.1); background: #eee; }
