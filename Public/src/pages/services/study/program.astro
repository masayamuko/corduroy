---
import Layout from '../../../layouts/Layout.astro';

const title = "3ヶ月AIプログラム｜AI講座（福岡）｜株式会社コールテン";
const description = "第二の自分を作るところから始まる、3ヶ月でAIを使いこなすプログラム。月1講座×3回＋作業会＋Discordサポート。108,000円。福岡・対面開催。";

// パッケージ スタート期
const startDates = [
  { period: '2026 夏期', month: '6月', startDate: '2026.06.06', day: '土', time: '10:00-13:00', label: '第二の自分作り講座', remaining: '受付中' },
  { period: '2026 秋期', month: '9月', startDate: '2026.09.05', day: '土', time: '10:00-13:00', label: '第二の自分作り講座', remaining: '受付中' },
  { period: '2026 冬期', month: '12月', startDate: '2026.12.05', day: '土', time: '10:00-13:00', label: '第二の自分作り講座', remaining: '受付中' },
];
---

<Layout title={title} description={description} canonicalUrl="https://www.corduroy.co.jp/services/study/program/" ogUrl="https://www.corduroy.co.jp/services/study/program/">
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "3ヶ月AI活用プログラム",
        "description": "第二の自分を作るところから始まる、3ヶ月でAIを使いこなすプログラム。月1講座×3回＋作業会＋Discordサポート。",
        "provider": {
          "@type": "Organization",
          "name": "株式会社コールテン",
          "sameAs": "https://www.corduroy.co.jp/"
        },
        "offers": {
          "@type": "Offer",
          "price": "108000",
          "priceCurrency": "JPY"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/"},
          {"@type": "ListItem", "position": 2, "name": "サービス", "item": "https://www.corduroy.co.jp/services/"},
          {"@type": "ListItem", "position": 3, "name": "AI講座", "item": "https://www.corduroy.co.jp/services/study/"},
          {"@type": "ListItem", "position": 4, "name": "3ヶ月プログラム"}
        ]
      }
    </script>
  </Fragment>

  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="container hero-inner">
        <div class="fade-up">

          <!-- 眉上バッジ -->
          <div class="hero-eyebrow">
            <span class="eyebrow-dot"></span>
            <span>3ヶ月AI活用プログラム</span>
            <span class="eyebrow-sep">|</span>
            <span>福岡・対面 · 少人数制</span>
          </div>

          <!-- 3段組タイポグラフィ -->
          <h1>
            <span class="h1-pre">3ヶ月で、</span>
            <span class="h1-main">AIを<mark>使いこなせる</mark></span>
            <span class="h1-post">自分になる。</span>
          </h1>

          <!-- 区切りオーナメント -->
          <div class="hero-ornament">
            <span class="orn-line"></span>
            <span class="orn-mark">✦</span>
            <span class="orn-line"></span>
          </div>

          <p class="lead">
            「なんとなく使っている」から卒業して、<br>
            <b>自分専用のAIと一緒に働く</b>感覚を手に入れる3ヶ月。
          </p>

          <div class="hero-cta">
            <a class="btn" href="#program">プログラムの内容を見る</a>
            <a class="btn secondary" href="/services/study/trial">無料体験会に参加する →</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== FOR WHO ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>For You</small>
          <h2>こんな方へ</h2>
        </div>
        <div class="forwhom-grid fade-up">
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p>AIに興味はあるが、<b>使い続けられていない</b></p>
          </div>
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p><b>自分専用のAI</b>を育てて、仕事をラクにしたい</p>
          </div>
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p>独学ではなく<b>体系的に・正しく</b>身につけたい</p>
          </div>
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p>同じ熱量の仲間と<b>オフラインで継続</b>したい</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== PROGRAM ===== -->
    <section id="program" class="container">
      <div class="section-head fade-up">
        <small>Program</small>
        <h2>3ヶ月プログラムの全体像</h2>
        <p>月1本の講座を3ヶ月かけて積み上げ、<br>作業会とDiscordサポートで確実に定着させます。</p>
      </div>

      <!-- Roadmap -->
      <div class="roadmap fade-up">
        <div class="roadmap-item">
          <div class="roadmap-month">Month 1</div>
          <div class="roadmap-card">
            <div class="roadmap-icon">🤝</div>
            <div class="roadmap-tool-badge">
              <span class="tool-icon">🤖</span> ChatGPT を使用
            </div>
            <h3>第二の自分を作る</h3>
            <p class="mini">自分の価値観・判断軸・口癖をAIに覚え込ませ、「自分専用AI」を育てます。AIとの壁打ちが格段に深くなります。</p>
            <a href="/services/study/SecondME" class="link-btn">講座詳細を見る →</a>
          </div>
        </div>

        <div class="roadmap-arrow">↓</div>

        <div class="roadmap-item">
          <div class="roadmap-month">Month 2</div>
          <div class="roadmap-card">
            <div class="roadmap-icon">🌱</div>
            <div class="roadmap-tool-badge roadmap-tool-badge--multi">
              <span class="tool-icon">🔄</span> ChatGPT・Gemini・Claude など汎用スキル
            </div>
            <h3>AIの基礎を固める</h3>
            <p class="mini">AIの仕組みや得意・不得意を整理し、思い通りの回答を引き出す型を身につけます。<b>どのAI・LLMにも応用できる</b>普遍的なベースを作ります。</p>
            <a href="/services/study/basicAI" class="link-btn">講座詳細を見る →</a>
          </div>
        </div>

        <div class="roadmap-arrow">↓</div>

        <div class="roadmap-item">
          <div class="roadmap-month">Month 3</div>
          <div class="roadmap-card">
            <div class="roadmap-icon">🔨</div>
            <div class="roadmap-tool-badge roadmap-tool-badge--claude">
              <span class="tool-icon">⚡</span> Claude Code を使用
            </div>
            <h3>AIで何かを作る</h3>
            <p class="mini">Claude Codeを使い、ウェブサイトやツールをAIと一緒に実際に作ります。「知識がなくても作れた」という自信が、AI活用をさらに加速させます。</p>
            <a href="/services/study/AIdeWEB" class="link-btn">講座詳細を見る →</a>
          </div>
        </div>
      </div>

      <!-- Plus -->
      <div class="plus-section fade-up">
        <div class="plus-title">＋ パッケージに含まれるもの</div>
        <div class="plus-grid">
          <div class="plus-item">
            <div class="plus-icon">☀️</div>
            <div>
              <strong>作業会（月1回）</strong>
              <p class="mini">水曜夜 or 土曜朝のどちらか選択。黙々と作業しながら、わからないことをその場で聞けます。</p>
            </div>
          </div>
          <div class="plus-item">
            <div class="plus-icon">💬</div>
            <div>
              <strong>Discord サポート</strong>
              <p class="mini">講座外でも質問・相談OK。オンラインで気軽につながれるコミュニティです。</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== PRICE ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Price</small>
          <h2>価格・お申し込み</h2>
        </div>

        <div class="price-card fade-up">
          <div class="price-label">3ヶ月AI活用プログラム</div>
          <div class="price-amount">¥108,000<span class="price-tax">（税込）</span></div>
          <div class="price-includes">
            <span>✓ 月1講座 × 3回</span>
            <span>✓ 作業会 月1回（3ヶ月分）</span>
            <span>✓ Discord サポート</span>
          </div>
          <div class="price-note">
            ※ スタートは「第二の自分作り講座」がある月。年4回（3・6・9・12月）のご参加タイミングがあります。
          </div>
          <a class="btn price-btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">
            LINEで無料説明会を見て申し込む
          </a>
          <p class="price-sub">まずは無料説明会（動画）→ 無料体験会 → 申し込みの流れです</p>
        </div>

        <!-- Start Dates -->
        <div class="section-head fade-up" style="margin-top:64px; margin-bottom:32px;">
          <small>Next Start</small>
          <h2 style="font-size:28px;">次回スタート日程</h2>
        </div>
        <div class="start-dates fade-up">
          {startDates.map((s) => (
            <div class="start-item">
              <div class="start-period">{s.period}</div>
              <div class="start-info">
                <span class="start-month">{s.month}スタート</span>
                <span class="start-date">{s.startDate}（{s.day}） {s.time}</span>
                <span class="start-course">第1講座：{s.label}</span>
              </div>
              <span class="start-badge">{s.remaining}</span>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ===== FLOW ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Flow</small>
        <h2>参加までの流れ</h2>
      </div>
      <div class="flow-steps fade-up">
        <div class="flow-step">
          <div class="flow-num">01</div>
          <div class="flow-content">
            <strong>LINE登録</strong>
            <p class="mini">LINEを登録すると、無料説明会の動画をご覧いただけます。</p>
          </div>
        </div>
        <div class="flow-arrow">↓</div>
        <div class="flow-step">
          <div class="flow-num">02</div>
          <div class="flow-content">
            <strong>無料説明会（動画）を視聴</strong>
            <p class="mini">プログラムの内容・価格・スタート日程をわかりやすく説明しています。いつでも、何度でも見られます。</p>
          </div>
        </div>
        <div class="flow-arrow">↓</div>
        <div class="flow-step">
          <div class="flow-num">03</div>
          <div class="flow-content">
            <strong>無料体験会に参加（福岡・対面）</strong>
            <p class="mini">1時間のデモ&amp;セミナー。AIを実際に体験し、「自分にもできる」という感覚を持ち帰ってください。</p>
            <a href="/services/study/trial" class="link-btn" style="margin-top:8px;">体験会の詳細を見る →</a>
          </div>
        </div>
        <div class="flow-arrow">↓</div>
        <div class="flow-step">
          <div class="flow-num">04</div>
          <div class="flow-content">
            <strong>3ヶ月プログラムに申し込む</strong>
            <p class="mini">体験会後、その場でも・後日LINEからでも申し込めます。108,000円（税込）。</p>
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top:40px;" class="fade-up">
        <a class="btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">LINEで無料説明会を見る</a>
      </div>
    </section>


    <!-- ===== INSTRUCTOR ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Instructor</small>
          <h2>講師について</h2>
        </div>
        <div class="card fade-up" style="max-width:860px; margin:0 auto; display:flex; align-items:center; gap:32px; text-align:left;">
          <div class="instructor-image">
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                 alt="向 雅也"
                 style="width:100%; height:100%; object-fit:cover;">
          </div>
          <div style="flex:1;">
            <small style="display:block; color:var(--sea); font-weight:700; margin-bottom:4px;">株式会社コールテン代表</small>
            <h3>向 雅也</h3>
            <p class="mini" style="margin-top:12px;">
              企業導入・自社導入の実績があり、現場で使える形に落とし込んでいます。<br>
              フリーランス歴10年、コーチ歴3年、日本語教師歴を含む指導歴5年。<br>
              「わかりやすく教える」ことを大切に、実務に落とし込めるAI活用を丁寧に伴走します。
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== VOICES ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Voices</small>
        <h2>参加者の声</h2>
      </div>
      <div class="voices-box fade-up">
        <ul class="voices-list">
          <li class="voices-item">
            <span class="voices-icon">💬</span>
            <div class="voices-text">触ったことはあるけど活用できていなかったが、講座の型で仕事に使える感覚が出た。</div>
          </li>
          <li class="voices-item">
            <span class="voices-icon">💬</span>
            <div class="voices-text">AIへの指示が曖昧だったと気づけた。考え方を整えたら結果が安定した。</div>
          </li>
          <li class="voices-item">
            <span class="voices-icon">💬</span>
            <div class="voices-text">一人だと続かなかったけど、作業会で作業が進むようになった。</div>
          </li>
          <li class="voices-item">
            <span class="voices-icon">💬</span>
            <div class="voices-text">自分の言葉がAIに伝わる感覚が出て、壁打ちが楽になった。</div>
          </li>
        </ul>
      </div>
      <div class="fade-up" style="display:grid; gap:24px; max-width:900px; margin:0 auto;">
        <a href="/voices/takaro" class="card" style="display:block; text-decoration:none; color:inherit;">
          <div style="display:flex; gap:20px; align-items:center;">
            <div style="flex-shrink:0;">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png"
                   alt="中野たかろーさん" style="width:80px; height:80px; border-radius:50%; object-fit:cover;">
            </div>
            <div style="flex:1;">
              <div style="margin-bottom:8px;">
                <span style="display:inline-block; padding:4px 10px; border-radius:8px; background:#e8f4f0; color:#0f3d2e; font-size:11px; font-weight:700;">Interview</span>
              </div>
              <h3 style="font-size:18px; margin:0 0 8px 0; color:var(--ink);">「検索ツール」から「第二の自分」へ</h3>
              <p style="font-size:14px; color:#335649; margin:0; line-height:1.6;">
                フリーランス・中野たかろーさん｜ChatGPTを単なる検索ツールとして使っていた状態から、価値観やクセまで学習させた「第二の自分」として活用するまでの変革ストーリー。
              </p>
            </div>
          </div>
        </a>
      </div>
    </section>


    <!-- ===== FAQ ===== -->
    <section class="container faq">
      <div class="section-head fade-up">
        <small>FAQ</small>
        <h2>よくあるご質問</h2>
      </div>
      <div class="faq-items fade-up">
        <details open>
          <summary>AI初心者でも参加できますか？</summary>
          <p class="mini">はい、大丈夫です。<a href="/services/study/basicAI">基礎講座</a>はブラウザでの対話から始めます。初めての方も安心して受講できます。まずは<a href="/services/study/">無料動画講座</a>で雰囲気を知るのもおすすめです。</p>
        </details>
        <details>
          <summary>3ヶ月の途中から参加できますか？</summary>
          <p class="mini">プログラムは「<a href="/services/study/SecondME">第二の自分作り</a>」からスタートする設計のため、途中参加はお受けしていません。次のスタート時期（年4回）にご参加ください。</p>
        </details>
        <details>
          <summary>オンライン参加はできますか？</summary>
          <p class="mini">講座・作業会ともに福岡市内での対面開催が中心です。オンライン開催は準備中ですので、遠方の方はLINEにてお問い合わせください。</p>
        </details>
        <details>
          <summary>パソコンは必要ですか？</summary>
          <p class="mini">はい、講座では実際に操作を行うため、PC（Windows/Mac）の持参をお願いしています。タブレットやスマホのみでは受講が難しい内容が含まれます。</p>
        </details>
        <details>
          <summary>無料体験会だけ参加できますか？</summary>
          <p class="mini">もちろん参加できます。「まず雰囲気を見たい」「自分に合うか確かめたい」という方のための<a href="/services/study/trial">体験会</a>です。体験会後の申し込みは任意です。</p>
        </details>
        <details>
          <summary>3ヶ月プログラムの費用はいくらですか？</summary>
          <p class="mini">108,000円（税込）です。月1講座×3回・作業会・Discordサポートがすべて含まれます。詳しい内容は<a href="/services/study/trial">無料体験会</a>でもご案内していますので、お気軽にご参加ください。</p>
        </details>
        <details>
          <summary>3つの講座を個別に受けることもできますか？</summary>
          <p class="mini">はい、<a href="/services/study/basicAI">AI基礎講座</a>・<a href="/services/study/SecondME">第二の自分作り</a>・<a href="/services/study/AIdeWEB">AIでWEB作り</a>はそれぞれ単体でも受講できます。ただし、3つをセットで学ぶ方が理解が深まるため、プログラムでの受講をおすすめしています。</p>
        </details>
        <details>
          <summary>途中で辞めることはできますか？</summary>
          <p class="mini">原則として3ヶ月を通して受講いただく前提のプログラムです。やむを得ない事情がある場合はLINEにてご相談ください。</p>
        </details>
        <details>
          <summary>受講後のサポートはありますか？</summary>
          <p class="mini">はい、プログラム修了後は<a href="/services/study/community">AIコミュニティ「糸口会」</a>に参加して、仲間と一緒に学び続けることができます。さらに深い活用を目指す方には<a href="/services/advisory">AI顧問</a>による個別伴走もご用意しています。</p>
        </details>
        <details>
          <summary>同じ講座を再受講できますか？</summary>
          <p class="mini">はい、受講済みの講座に再参加することも可能です。復習として参加される方もいらっしゃいます。詳しくはLINEにてお問い合わせください。</p>
        </details>
      </div>
    </section>


    <!-- ===== TRIAL CTA ===== -->
    <section id="trial" class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Free Trial</small>
          <h2>まず、体験してみてください。</h2>
          <p>無料体験会では、AIのデモと「第二の自分」の実例を1時間で体感できます。<br>「自分にもできる」という自信を持って帰ってください。</p>
        </div>
        <div class="card fade-up" style="max-width:640px; margin:0 auto; text-align:center;">
          <div style="font-size:48px; margin-bottom:16px;">🌱</div>
          <h3>無料体験会（福岡・対面）</h3>
          <p class="mini" style="margin-bottom:8px;">AIデモ ＋ 第二の自分デモ ＋ プログラム案内</p>
          <p class="mini" style="margin-bottom:24px;">参加無料 / 月1回開催 / 福岡市内</p>
          <a class="btn" href="/services/study/trial">体験会の日程・詳細を見る →</a>
        </div>
      </div>
    </section>


    <!-- ===== LINE CTA ===== -->
    <section class="bg-contact">
      <div class="container">
        <div class="section-head fade-up">
          <small>LINE</small>
          <h2>まずはLINE登録から</h2>
          <p>無料説明会（動画）をご覧いただけます。<br>無理な勧誘はありません。いつでも気軽にどうぞ。</p>
        </div>
        <div class="card fade-up" style="max-width:640px; margin:0 auto; text-align:center;">
          <a class="btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer"
             style="margin-top:8px;">LINE登録で無料説明会を見る</a>
        </div>
      </div>
    </section>

    <!-- ===== OTHER SERVICES ===== -->
    <section class="bg-other">
      <div class="container">
        <div class="section-head fade-up">
          <small>Other Services</small>
