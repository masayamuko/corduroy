---
import Layout from '../../../layouts/Layout.astro';

const title = "3ヶ月でAI活用を学ぶプログラム｜AI講座（福岡）｜株式会社コールテン";
const description = "ChatGPT・Codexを使い、3ヶ月で『AIと共に生きる自分』になるプログラム。第二の自分作り → AI理解 → AIで作る、の3ヶ月。月1講座×3回＋作業会＋Discordサポート。110,000円（税込）。福岡・対面開催。";
const ogImage = "https://res.cloudinary.com/dg3mdcuju/image/upload/w_1200,h_630,c_fill,g_center,e_brightness:-15/v1765686550/Facebook_Image_20_usvjlj.jpg";

// パッケージ スタート期（2026年6月開講 / 土曜クラス・水曜クラスの2系統）
type CohortSession = { date: string; time?: string; topic: string };
type Cohort = {
  id: string;
  period: string;
  label: string;
  weekday: string;
  remaining: string;
  startDate: string;       // 表示用（例: '6/6（土）'）
  startISO: string;        // 開講日（ISO 8601・Asia/Tokyo）
  deadlineISO: string;     // 申込締切（開講1週間前 23:59 JST）
  deadlineLabel: string;   // 表示用締切（例: '5/30（土）23:59'）
  sessions: CohortSession[];
};

const cohorts: Cohort[] = [
  {
    id: 'sat-2026-06',
    period: '2026 夏期',
    label: '土曜クラス',
    weekday: '土曜朝',
    remaining: '受付中',
    startDate: '6/6（土）',
    startISO: '2026-06-06T10:00:00+09:00',
    deadlineISO: '2026-05-30T23:59:59+09:00',
    deadlineLabel: '5/30（土）23:59',
    sessions: [
      { date: '6/6（土）', time: '10:00-13:00', topic: '第二の自分作り' },
      { date: '7/4（土）', topic: 'AIでサイト作り' },
      { date: '8/1（土）', topic: 'AI基礎講座' },
    ],
  },
  {
    id: 'wed-2026-06',
    period: '2026 夏期',
    label: '水曜クラス',
    weekday: '水曜夜',
    remaining: '受付中',
    startDate: '6/10（水）',
    startISO: '2026-06-10T19:00:00+09:00',
    deadlineISO: '2026-06-03T23:59:59+09:00',
    deadlineLabel: '6/3（水）23:59',
    sessions: [
      { date: '6/10（水）', time: '19:00-22:00', topic: 'AIでサイト作り' },
      { date: '7/8（水）', topic: 'AI基礎講座' },
      { date: '8/12（水）', topic: '第二の自分作り' },
    ],
  },
];
---

<Layout title={title} description={description} ogImage={ogImage} canonicalUrl="https://www.corduroy.co.jp/services/study/program/" ogUrl="https://www.corduroy.co.jp/services/study/program/">
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "3ヶ月AI活用プログラム",
        "description": "第二の自分を作るところから始まる、3ヶ月で『AIと共に生きる自分』になるプログラム。月1講座×3回＋作業会＋Discordサポート。",
        "provider": {
          "@type": "Organization",
          "name": "株式会社コールテン",
          "sameAs": "https://www.corduroy.co.jp/"
        },
        "offers": {
          "@type": "Offer",
          "price": "110000",
          "priceCurrency": "JPY"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/"},
          {"@type": "ListItem", "position": 2, "name": "サービス", "item": "https://www.corduroy.co.jp/services/"},
          {"@type": "ListItem", "position": 3, "name": "AI講座", "item": "https://www.corduroy.co.jp/services/study/"},
          {"@type": "ListItem", "position": 4, "name": "3ヶ月プログラム"}
        ]
      }
    </script>
  </Fragment>

  <main>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-glow"></div>
      <div class="container hero-inner">
        <div class="fade-up">

          <!-- 眉上バッジ -->
          <div class="hero-eyebrow">
            <span class="eyebrow-dot"></span>
            <span>3ヶ月AI活用プログラム</span>
            <span class="eyebrow-sep">|</span>
            <span>福岡・対面 · 少人数制</span>
          </div>

          <!-- 3段組タイポグラフィ -->
          <h1>
            <span class="h1-pre">3ヶ月で、</span>
            <span class="h1-main">AIと<mark>共に生きる</mark></span>
            <span class="h1-post">自分になる。</span>
          </h1>

          <!-- 区切りオーナメント -->
          <div class="hero-ornament">
            <span class="orn-line"></span>
            <span class="orn-mark">✦</span>
            <span class="orn-line"></span>
          </div>

          <p class="lead">
            「なんとなく使っている」から卒業して、<br>
            <b>AIと自分の言葉で対話できる</b>感覚を手に入れる3ヶ月。
          </p>

          <div class="hero-cta">
            <a class="btn" href="#program">プログラムの内容を見る</a>
            <a class="btn secondary" href="#flow">参加までの流れを見る →</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== FOR WHO ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>For You</small>
          <h2>こんな方へ</h2>
        </div>
        <div class="forwhom-grid fade-up">
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p>AIに興味はあるが、<b>使い続けられていない</b></p>
          </div>
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p><b>自分専用のAI</b>を育てて、仕事をラクにしたい</p>
          </div>
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p>独学ではなく<b>体系的に・正しく</b>身につけたい</p>
          </div>
          <div class="forwhom-item">
            <span class="forwhom-check">✔</span>
            <p>同じ熱量の仲間と<b>オフラインで継続</b>したい</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== BEFORE / AFTER ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Before &rarr; After</small>
        <h2>3ヶ月後の自分</h2>
        <p>ただ「AIに詳しい」になるのではなく、<br><b>AIが自分の一部</b>として動き出している。それが3ヶ月後の景色です。</p>
      </div>

      <div class="ba-grid fade-up">
        <div class="ba-card ba-before">
          <div class="ba-tag">Before</div>
          <h3>今のあなた</h3>
          <ul>
            <li>ChatGPTを開いても何を聞けばいいか迷う</li>
            <li>返ってきた答えが「なんかズレてる」と感じる</li>
            <li>気がつくと使わなくなって、また検索に戻っている</li>
            <li>「結局AIで何ができるんだろう」が止まらない</li>
          </ul>
        </div>

        <div class="ba-arrow">→</div>

        <div class="ba-card ba-after">
          <div class="ba-tag ba-tag--after">After（3ヶ月後）</div>
          <h3>AIと共に生きる自分</h3>
          <ul>
            <li><b>第二の自分</b>として育てたAIパートナーが、あなたの言葉と価値観を覚えている</li>
            <li>AIの<b>得意・不得意がわかる</b>から、頼り方・任せ方が自然にわかる</li>
            <li>そのAIパートナーと一緒に、<b>ウェブサイトやツールを実際に作れる</b>ようになっている</li>
            <li>「AIをどう使うか」ではなく、<b>「AIと一緒に何をするか」</b>で発想できる</li>
          </ul>
        </div>
      </div>

      <div class="ba-note fade-up">
        <span class="ba-note-icon">⚙️</span>
        <p>
          ※ 本プログラムで主に使用するAIは <b>ChatGPT</b> です。<br>
          ChatGPT契約者が使える <b>Codex</b>（コード生成・実行ツール）も合わせて活用し、第三段階の「AIと一緒に作る」を実現します。Claude / Gemini への応用は基礎講座で触れます。
        </p>
      </div>
    </section>


    <!-- ===== PROGRAM ===== -->
    <section id="program" class="container">
      <div class="section-head fade-up">
        <small>Program</small>
        <h2>3ヶ月プログラムの全体像</h2>
        <p>月1本の講座を3ヶ月かけて積み上げ、<br>作業会とDiscordサポートで確実に定着させます。</p>
      </div>

      <!-- Roadmap -->
      <div class="roadmap fade-up">
        <div class="roadmap-item">
          <div class="roadmap-month">Month 1</div>
          <div class="roadmap-card">
            <div class="roadmap-icon">🤝</div>
            <div class="roadmap-tool-badge">
              <span class="tool-icon">🤖</span> ChatGPT を使用
            </div>
            <h3>第二の自分を作る</h3>
            <p class="mini">自分の価値観・判断軸・口癖をAIに覚え込ませ、「自分専用AI」を育てます。AIとの壁打ちが格段に深くなります。</p>
          </div>
        </div>

        <div class="roadmap-arrow">↓</div>

        <div class="roadmap-item">
          <div class="roadmap-month">Month 2</div>
          <div class="roadmap-card">
            <div class="roadmap-icon">🌱</div>
            <div class="roadmap-tool-badge">
              <span class="tool-icon">🤖</span> ChatGPT を使用（基礎は他AIにも応用可）
            </div>
            <h3>AIの基礎を固める</h3>
            <p class="mini">AIの仕組みや得意・不得意を整理し、思い通りの回答を引き出す型を身につけます。本プログラムではChatGPTを使いますが、<b>Claude / Gemini など他のLLMにも応用できる</b>普遍的なベースを作ります。</p>
          </div>
        </div>

        <div class="roadmap-arrow">↓</div>

        <div class="roadmap-item">
          <div class="roadmap-month">Month 3</div>
          <div class="roadmap-card">
            <div class="roadmap-icon">🔨</div>
            <div class="roadmap-tool-badge roadmap-tool-badge--claude">
              <span class="tool-icon">⚡</span> ChatGPT + Codex を使用
            </div>
            <h3>AIで何かを作る</h3>
            <p class="mini">ChatGPT契約で使える <b>Codex</b>（コード生成・実行ツール）を活用し、ウェブサイトやツールをAIと一緒に実際に作ります。「知識がなくても作れた」という自信が、AI活用をさらに加速させます。</p>
          </div>
        </div>
      </div>

      <!-- Plus -->
      <div class="plus-section fade-up">
        <div class="plus-title">＋ パッケージに含まれるもの</div>
        <div class="plus-grid">
          <div class="plus-item">
            <div class="plus-icon">☀️</div>
            <div>
              <strong>作業会（月1回）</strong>
              <p class="mini">水曜夜 or 土曜朝のどちらか選択。黙々と作業しながら、わからないことをその場で聞けます。</p>
            </div>
          </div>
          <div class="plus-item">
            <div class="plus-icon">💬</div>
            <div>
              <strong>Discord サポート</strong>
              <p class="mini">講座外でも質問・相談OK。オンラインで気軽につながれるコミュニティです。</p>
            </div>
          </div>
        </div>

        <div class="plus-continue">
          <div class="plus-continue-icon">🌿</div>
          <div class="plus-continue-body">
            <strong>修了後も続けたい方へ：糸口会 継続参加（任意）</strong>
            <p class="mini">3ヶ月プログラム修了後、希望者は<a href="/services/study/community">AIコミュニティ「糸口会」</a>に<b>月5,000円</b>で継続参加できます。月1回の作業会＋Discordで、学び続ける環境を維持できます。</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== PRICE ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Price</small>
          <h2>価格・お申し込み</h2>
        </div>

        <div class="price-card fade-up">
          <div class="price-label">3ヶ月AI活用プログラム</div>
          <div class="price-amount">¥110,000<span class="price-tax">（税込）</span></div>
          <div class="price-includes">
            <span>✓ 月1講座 × 3回</span>
            <span>✓ 作業会 月1回（3ヶ月分）</span>
            <span>✓ Discord サポート</span>
          </div>
          <div class="price-note">
            ※ 2026年6月開講は土曜クラス／水曜クラスの2系統。次の開講予定は別途LINEでご案内します。
          </div>
          <a class="btn price-btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">
            LINE登録して「説明会」と送る
          </a>
          <p class="price-sub">LINEで「説明会」と送信 → 無料説明会（動画）が届きます → そのままLINEでお申し込みください</p>
        </div>

        <!-- Start Dates -->
        <div class="section-head fade-up" style="margin-top:64px; margin-bottom:32px;">
          <small>Next Start</small>
          <h2 style="font-size:28px;">スタート日程（2026年6月開講）</h2>
          <p>土曜朝クラス／水曜夜クラスのどちらかを選んでご参加ください。<br>初回は時間帯を明記、第2回・第3回は日付のみ表示（時間は回によって変動する場合があります／詳細はLINEでご案内）。</p>
        </div>
        <div class="cohort-grid fade-up">
          {cohorts.map((c) => (
            <div class="cohort-card" data-cohort-id={c.id} data-deadline={c.deadlineISO} data-start={c.startISO}>
              <div class="cohort-header">
                <div class="cohort-period">{c.period}</div>
                <div class="cohort-label">{c.label}</div>
                <div class="cohort-weekday">{c.weekday}</div>
                <span class="cohort-badge" data-cohort-badge>{c.remaining}</span>
              </div>

              <div class="cohort-countdown" data-cohort-countdown>
                <div class="cd-label">申込締切</div>
                <div class="cd-deadline">{c.deadlineLabel}</div>
                <div class="cd-remaining">
                  <span class="cd-num" data-cohort-days>—</span>
                  <span class="cd-unit">日</span>
                </div>
                <div class="cd-sub" data-cohort-sub>開講まで残り—</div>
              </div>

              <ol class="cohort-sessions">
                {c.sessions.map((s, i) => (
                  <li class="cohort-session">
                    <span class="cohort-round">第{i + 1}回</span>
                    <span class="cohort-date">{s.date}</span>
                    {s.time && <span class="cohort-time">{s.time}</span>}
                    <span class="cohort-topic">{s.topic}</span>
                  </li>
                ))}
              </ol>

              <a class="cohort-cta" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">
                LINEで申し込む →
              </a>
            </div>
          ))}
        </div>

        <script is:inline>
          // クラス別カウントダウン（クライアント側で残日数を表示）
          (function () {
            const fmtJSTDate = (iso) => {
              const d = new Date(iso);
              const m = d.getMonth() + 1;
              const day = d.getDate();
              return `${m}/${day}`;
            };
            const update = () => {
              const now = Date.now();
              document.querySelectorAll('[data-cohort-id]').forEach((card) => {
                const deadlineEl = card.querySelector('[data-cohort-days]');
                const subEl = card.querySelector('[data-cohort-sub]');
                const badgeEl = card.querySelector('[data-cohort-badge]');
                const cdBox = card.querySelector('[data-cohort-countdown]');
                if (!deadlineEl || !subEl) return;

                const deadlineISO = card.getAttribute('data-deadline');
                const startISO = card.getAttribute('data-start');
                if (!deadlineISO || !startISO) return;

                const deadlineMs = new Date(deadlineISO).getTime();
                const startMs = new Date(startISO).getTime();
                const dayMs = 86400000;

                const daysToDeadline = Math.ceil((deadlineMs - now) / dayMs);
                const daysToStart = Math.ceil((startMs - now) / dayMs);

                if (daysToDeadline > 0) {
                  deadlineEl.textContent = String(daysToDeadline);
                  subEl.textContent = `開講まで残り ${Math.max(daysToStart, 0)}日`;
                  if (daysToDeadline <= 7 && cdBox) cdBox.classList.add('cd--urgent');
                } else if (daysToStart > 0) {
                  deadlineEl.textContent = '締切';
                  subEl.textContent = `開講まで残り ${daysToStart}日（締切後はお問い合わせください）`;
                  if (badgeEl) {
                    badgeEl.textContent = '締切';
                    badgeEl.classList.add('cohort-badge--closed');
                  }
                  if (cdBox) cdBox.classList.add('cd--closed');
                } else {
                  deadlineEl.textContent = '—';
                  subEl.textContent = '開講中／次回はLINEでお問い合わせください';
                  if (badgeEl) {
                    badgeEl.textContent = '開講中';
                    badgeEl.classList.add('cohort-badge--running');
                  }
                  if (cdBox) cdBox.classList.add('cd--closed');
                }
              });
            };
            update();
            // 1時間おきに更新（長時間開きっぱなしの場合に備える）
            setInterval(update, 3600 * 1000);
          })();
        </script>
      </div>
    </section>


    <!-- ===== FLOW ===== -->
    <section id="flow" class="container">
      <div class="section-head fade-up">
        <small>Flow</small>
        <h2>参加までの流れ</h2>
        <p>すべてLINEで完結します。対面の体験会や、外部フォームの記入は不要です。</p>
      </div>
      <div class="flow-steps fade-up">
        <div class="flow-step">
          <div class="flow-num">01</div>
          <div class="flow-content">
            <strong>LINE登録</strong>
            <p class="mini">下のボタンから公式LINEを友だち追加してください。</p>
          </div>
        </div>
        <div class="flow-arrow">↓</div>
        <div class="flow-step">
          <div class="flow-num">02</div>
          <div class="flow-content">
            <strong>「説明会」とメッセージを送る</strong>
            <p class="mini">LINEのトーク画面で「<b>説明会</b>」とそのまま送信。3ヶ月プログラムの無料説明会（動画）が自動で届きます。</p>
          </div>
        </div>
        <div class="flow-arrow">↓</div>
        <div class="flow-step">
          <div class="flow-num">03</div>
          <div class="flow-content">
            <strong>無料説明会（動画）を視聴</strong>
            <p class="mini">プログラム内容・カリキュラム・スタート日程・料金をわかりやすくお伝えします。いつでも・何度でも見直せます。</p>
          </div>
        </div>
        <div class="flow-arrow">↓</div>
        <div class="flow-step">
          <div class="flow-num">04</div>
          <div class="flow-content">
            <strong>LINEで参加申し込み → スタート</strong>
            <p class="mini">LINEで土曜クラス／水曜クラスのご希望を返信ください。お支払い案内とあわせて初回日程をお送りします。</p>
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top:40px;" class="fade-up">
        <a class="btn" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer">LINE登録して「説明会」と送る</a>
      </div>
    </section>


    <!-- ===== INSTRUCTOR ===== -->
    <section class="bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Instructor</small>
          <h2>講師について</h2>
        </div>
        <div class="card fade-up" style="max-width:860px; margin:0 auto; display:flex; align-items:center; gap:32px; text-align:left;">
          <div class="instructor-image">
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                 alt="向 雅也"
                 style="width:100%; height:100%; object-fit:cover;">
          </div>
          <div style="flex:1;">
            <small style="display:block; color:var(--sea); font-weight:700; margin-bottom:4px;">株式会社コールテン代表</small>
            <h3>向 雅也</h3>
            <p class="mini" style="margin-top:12px;">
              企業導入・自社導入の実績があり、現場で使える形に落とし込んでいます。<br>
              フリーランス歴10年、コーチ歴3年、日本語教師歴を含む指導歴5年。<br>
              「わかりやすく教える」ことを大切に、実務に落とし込めるAI活用を丁寧に伴走します。
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ===== ACCESS ===== -->
    <section class="container">
      <div class="section-head fade-up">
        <small>Access</small>
        <h2>会場のご案内</h2>
