---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="AIサービス一覧｜無料動画講座・AI講座・AI顧問・法人研修｜株式会社コールテン"
  description="無料動画講座、AI講座、AI顧問、法人研修、コミュニティまで。AIとの関係性を育てるサービスを株式会社コールテンが提供します。"
  canonicalUrl="https://www.corduroy.co.jp/services/"
  ogUrl="https://www.corduroy.co.jp/services/"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "サービス一覧", "item": "https://www.corduroy.co.jp/services/" }
    ]
  }
  </script>

  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": "AIコミュ力サービス",
        "serviceType": "AI講座・AI顧問・法人研修・コミュニティ",
        "provider": { "@id": "https://www.corduroy.co.jp/#organization" },
        "url": "https://www.corduroy.co.jp/services/",
        "areaServed": "JP",
        "description": "AIとの関係性を育てる、本質的な学びと伴走。無料動画講座・AI講座・AI顧問・法人研修・糸口会(コミュニティ)を提供。"
      },
      {
        "@type": "ItemList",
        "name": "コールテンが提供するAIサービス",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "無料動画講座", "url": "https://lin.ee/tDuJPjc" },
          { "@type": "ListItem", "position": 2, "name": "AI講座（3ヶ月プログラム）", "url": "https://www.corduroy.co.jp/services/study/program/" },
          { "@type": "ListItem", "position": 3, "name": "AI顧問", "url": "https://www.corduroy.co.jp/services/advisory/" },
          { "@type": "ListItem", "position": 4, "name": "法人研修", "url": "https://www.corduroy.co.jp/services/study/corporate/" },
          { "@type": "ListItem", "position": 5, "name": "糸口会（コミュニティ）", "url": "https://www.corduroy.co.jp/services/study/community/" },
          { "@type": "ListItem", "position": 6, "name": "無料体験会", "url": "https://www.corduroy.co.jp/services/study/trial/" }
        ]
      }
    ]
  }
  </script>

  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "AIの知識がなくても大丈夫ですか？",
        "acceptedAnswer": { "@type": "Answer", "text": "はい。コールテンの講座は「AIの使い方」ではなく「AIとの付き合い方」を学ぶものです。専門知識は必要ありません。スマホでLINEが使える方なら、どなたでも始められます。まずは無料体験会で気軽に触れてみてください。" }
      },
      {
        "@type": "Question",
        "name": "どんな業種・職種でも活用できますか？",
        "acceptedAnswer": { "@type": "Answer", "text": "はい。AIコミュ力は特定のツールや業界に依存しない、コミュニケーションの基礎スキルです。経営者、フリーランス、会社員など、さまざまな方にご活用いただいています。利用者の声もぜひ参考にしてみてください。" }
      },
      {
        "@type": "Question",
        "name": "無料動画講座だけでも学べますか？",
        "acceptedAnswer": { "@type": "Answer", "text": "はい。まずは動画講座でAIコミュ力の基本を掴んでいただけます。その上で、より深く学びたい方には3ヶ月プログラムやAI顧問などのサービスもご用意しています。" }
      },
      {
        "@type": "Question",
        "name": "他のAI講座との違いは何ですか？",
        "acceptedAnswer": { "@type": "Answer", "text": "多くのAI講座は「ツールの操作方法」や「プロンプトのテクニック」を教えます。コールテンは、プロコーチ出身の代表が「AIとの関係性」そのものを育てるアプローチ。一時的なスキルではなく、自走できる土台をつくります。" }
      },
      {
        "@type": "Question",
        "name": "受講後、すぐにAIを活用できるようになりますか？",
        "acceptedAnswer": { "@type": "Answer", "text": "「すぐに完璧に」というより、「少しずつ関係性が育っていく」イメージです。人間関係と同じで、焦らず続けることで、気づけば自然にAIと協力できるようになっています。学んだあとも糸口会（コミュニティ）で継続的にサポートしています。" }
      },
      {
        "@type": "Question",
        "name": "コールテンの講座はオンラインですか？",
        "acceptedAnswer": { "@type": "Answer", "text": "無料動画講座はLINEでどこからでも受講可能です。AI講座や体験会は対面が中心ですが、オンライン対応が可能な場合もあります。AI顧問は完全オンライン対応です。" }
      },
      {
        "@type": "Question",
        "name": "どのくらいの期間で変化を感じられますか？",
        "acceptedAnswer": { "@type": "Answer", "text": "個人差はありますが、多くの方が2〜3週間ほどで「AIとのやり取りが楽しくなってきた」と実感されています。3ヶ月プログラムで体系的に学ぶと、より確実に変化を感じていただけます。" }
      },
      {
        "@type": "Question",
        "name": "法人・チームでの導入は可能ですか？",
        "acceptedAnswer": { "@type": "Answer", "text": "はい。法人研修ではチーム全体でAIコミュ力を高める支援を行っています。また、AI顧問として継続的に伴走するプランもあります。お気軽にお問い合わせください。" }
      },
      {
        "@type": "Question",
        "name": "「AIコミュ力」は本やYouTubeで学べますか？",
        "acceptedAnswer": { "@type": "Answer", "text": "AIコミュ力はコールテンが日々の実践から磨いてきた独自の概念です。一般的なAI本やYouTubeとは異なり、「自己開示」「AI理解」「環境づくり」の3つを体系化しています。まずは無料動画講座で触れてみてください。" }
      },
      {
        "@type": "Question",
        "name": "糸口会（コミュニティ）と講座の違いは？",
        "acceptedAnswer": { "@type": "Answer", "text": "AI講座は体系的に学ぶ場、糸口会は学んだあとも実践を続ける場です。月2回の作業会とDiscordで、仲間と一緒にAI活用を習慣にしていきます。「学んで終わり」にしたくない方におすすめです。" }
      },
      {
        "@type": "Question",
        "name": "まずは話を聞いてみたいのですが",
        "acceptedAnswer": { "@type": "Answer", "text": "もちろん大歓迎です。お問い合わせページからお気軽にご連絡ください。無理な勧誘は一切いたしません。「こんなこと聞いていいのかな」というレベルでも大丈夫です。" }
      },
      {
        "@type": "Question",
        "name": "コールテンを「卒業」するって、どういうこと？",
        "acceptedAnswer": { "@type": "Answer", "text": "コールテンのゴールは、お客さまがAIと自分の力で前に進めるようになること。コーチにとって最高の成果はクライアントがコーチを必要としなくなることです。依存させるのではなく、自走できる状態を一緒に目指します。" }
      }
    ]
  }
  </script>

  <main id="main-content">

    <!-- =====================================================
      01. HERO
    ===================================================== -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="fade-up">
          <small>What We Believe</small>
          <h1>AI活用のすべては、<br>AIとの<span class="highlight">「関係性」</span>にある。</h1>
          <p class="hero-lead">AIコミュ力を磨く、本質的な学びを提供。</p>
          <div class="hero-cta">
            <a class="btn-line" href="https://lin.ee/tDuJPjc" target="_blank" rel="noopener noreferrer"
             aria-label="無料動画講座を受ける（LINEが新しいタブで開きます）"
               data-ga-event="cta_click" data-ga-label="services_hero_line">
              <span class="line-icon-sm">LINE</span>
              無料動画講座を受ける
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- =====================================================
      02. 共感 — よくある思い込み
    ===================================================== -->
    <section class="empathy-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>Does This Sound Familiar?</small>
          <h2><span class="empathy-h2-sub">こんな</span><span class="empathy-h2-emph">「思い込み」</span><br><span class="empathy-h2-sub">ありませんか？</span></h2>
        </div>
        <div class="empathy-list">
          <div class="empathy-item fade-up">
            <div class="empathy-icon" aria-hidden="true">?</div>
            <div class="empathy-body">
              <p class="empathy-myth">「プロンプトを工夫すれば、もっといい答えが返ってくるはず」</p>
              <p class="empathy-truth">もちろんプロンプトも大事。でも実は、もっと手前——あなた自身をAIに伝えること——に力を入れた方が、結果が大きく変わることが多いんです。</p>
            </div>
          </div>
          <div class="empathy-item fade-up">
            <div class="empathy-icon" aria-hidden="true">?</div>
            <div class="empathy-body">
              <p class="empathy-myth">「AIには正解の使い方がある」</p>
              <p class="empathy-truth">人によってAIとの付き合い方はまったく違います。「正解」を探すより、自分に合ったスタイルを育てていく方が近道かもしれません。</p>
            </div>
          </div>
          <div class="empathy-item fade-up">
            <div class="empathy-icon" aria-hidden="true">?</div>
            <div class="empathy-body">
              <p class="empathy-myth">「もっと高機能なAIを使えばうまくいく」</p>
              <p class="empathy-truth">ツールを変えても、関係性が変わらなければ、本質的な変化は起きにくいものです。</p>
            </div>
          </div>
          <div class="empathy-item fade-up">
            <div class="empathy-icon" aria-hidden="true">?</div>
            <div class="empathy-body">
              <p class="empathy-myth">「AIは指示すれば動く便利な道具」</p>
              <p class="empathy-truth">道具としても優秀。でもそれだけだと、AIの本当の力を引き出しきれていないかもしれません。</p>
            </div>
          </div>
          <div class="empathy-item fade-up">
            <div class="empathy-icon" aria-hidden="true">?</div>
            <div class="empathy-body">
              <p class="empathy-myth">「使いこなせない自分が悪い」</p>
              <p class="empathy-truth">「使いこなす」というフレーム自体を、一度手放してみませんか？</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- =====================================================
      03. 転換 — 使い方 < 関係性
    ===================================================== -->
    <section class="shift-section">
      <div class="container">
        <div class="shift-box fade-up">
          <small>A Different Approach</small>
          <div class="shift-heading">
            <span class="shift-small">使い方を学ぶ</span>
            <span class="shift-symbol">&lt;</span>
            <span class="shift-large">関係性を育てる。</span>
          </div>
          <div class="shift-body">
            <p>「使いこなそう」と力むのをやめて、<br>AIとの"関係性"に目を向けた人たちは、<br>驚くほど自然に、楽しみながらAIを活用しています。</p>
            <p>大事なのは、高度なテクニックではありません。<br>人間関係と同じように、<strong>お互いを知り、歩み寄ること</strong>。</p>
            <p>コールテンはこれを<strong>「AIコミュ力」</strong>と呼んでいます。</p>
          </div>
        </div>
      </div>
    </section>


    <!-- =====================================================
      03B. 関係性を育てると、こうなる（成長セクション）
    ===================================================== -->
    <section class="growth-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>What Happens Next</small>
          <h2>関係性を育てると、<br>こうなる。</h2>
        </div>
        <div class="growth-steps fade-up">
          <div class="growth-step">
            <div class="step-num">STEP 1</div>
            <h3>まず、楽しくなる。<br>そして、自然と続く。</h3>
            <img class="step-image"
                 src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777289588/corduroy/services/growth-step1.jpg"
                 alt="カフェのテーブルで楽しそうに両手を広げて熱中して話すテトと、優しく聞き入るTiki。関係性を育てると対話が楽しみに変わる様子"
                 loading="lazy" width="1280" height="720" />
            <p>関係性に目を向けると、AIとの対話は「作業」から「楽しみ」へ変わります。<br>
            楽しいから、自然と毎日触りたくなる。<br>
            そうやって、AI活用が <strong>生活に定着</strong> していきます。</p>
          </div>
          <div class="growth-step">
            <div class="step-num">STEP 2</div>
            <h3>そして、できることが<br>どんどん広がっていく。</h3>
            <img class="step-image"
                 src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777289592/corduroy/services/growth-step2.jpg"
                 alt="中央に並ぶテトとTikiの周囲に思考・学習・挑戦・成長の4要素が放射状に広がるインフォグラフィック。関係性を育てるとできることが広がっていく様子"
                 loading="lazy" width="1280" height="720" />
            <ul class="step-list">
              <li><strong>思考が深まる</strong>：AIと考える前提で物事を見られるようになる。</li>
              <li><strong>学習速度が上がる</strong>：AIと一緒に学ぶから、独学より圧倒的に速い。</li>
              <li><strong>やれることが増える</strong>：AIと分担できるから、新しい挑戦に時間が使える。</li>
              <li><strong>AIがあなた専用に育つ</strong>：使い続けるほど、AIがあなたを理解する相棒になる。</li>
            </ul>
          </div>
        </div>
      </div>
    </section>


    <!-- =====================================================
      04. AIコミュ力 3つのカギ
    ===================================================== -->
    <section id="ai-comm" class="comm-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>AI Communication Skills</small>
          <h2>"AIコミュ力"を育む<br>3つのポイント</h2>
        </div>

        <!-- 三角ダイアグラム -->
        <div class="skill-diagram fade-up">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777289594/corduroy/services/triangle-diagram-v4.jpg"
               alt="AIコミュ力の3つのポイント: 自己開示（AIに自分を伝える）、AI理解（AIの特性を知る）、環境づくり（互いにとって良い環境を追求）"
               loading="lazy" width="1280" height="720" class="skill-img" />
        </div>

        <!-- 1: 自己開示 -->
        <div class="comm-block fade-up">
          <img class="comm-illustration"
               src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_make_transparent/f_webp,q_auto:good/v1777256057/corduroy/services/key1-self-disclosure.png"
               alt="テト（人）が「僕はテト、ボードゲームが大好き！」と話し、Tiki（AI）が「へぇ、ボードゲームが好きなんだね？」と聞くイラスト"
               loading="lazy" width="1280" height="720" />
          <div class="comm-header">
            <span class="comm-num">1</span>
            <h3>AIに自分を知ってもらう</h3>
            <span class="comm-tag">#自己開示</span>
          </div>
          <div class="comm-two-col">
            <div class="comm-col human">
              <div class="comm-label">人間関係では</div>
              <p>自分のことを知ってくれている旧友や家族は、あなたに合った対応を自然と知っている。でも初対面の人は、あなたの好みや考え方がわからないから、距離感をつかむのに時間がかかってスムーズにいきにくいよね。</p>
            </div>
            <div class="comm-eq" aria-hidden="true">≒</div>
            <div class="comm-col ai">
              <div class="comm-label">AIも似てる</div>
              <p>AIも、毎回"初対面"にならないように、自分の情報を継続的にインプットして教え続けてあげる。価値観、仕事のスタイル、好みの表現——伝え続けるほど、AIの返答は"あなた専用"に育っていきます。</p>
            </div>
          </div>
        </div>

        <!-- 2: AI理解 -->
        <div class="comm-block fade-up">
          <img class="comm-illustration"
               src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_make_transparent/f_webp,q_auto:good/v1777256060/corduroy/services/key2-ai-understanding.png"
               alt="テト（人）が「Tikiって、どんなことが得意なの？」と尋ね、Tiki（AI）が「短く具体的に伝えてくれると、得意なことが活きるよ」と答えるイラスト"
               loading="lazy" width="1280" height="720" />
          <div class="comm-header">
            <span class="comm-num">2</span>
            <h3>AIのことを知る</h3>
            <span class="comm-tag">#AI理解</span>
          </div>
          <div class="comm-two-col">
            <div class="comm-col human">
              <div class="comm-label">人間関係では</div>
              <p>相手のことを知らなければ、どう接していいかわからない。「どうしたら仕事しやすい？」「何が得意で、何が苦手？」——相手を理解することが、良いコミュニケーションの第一歩。</p>
            </div>
            <div class="comm-eq" aria-hidden="true">≒</div>
            <div class="comm-col ai">
              <div class="comm-label">AIも似てる</div>
              <p>ChatGPTはどういう仕組みで動いているの？ なぜこういう時こう返してくれなかったの？ どうしたら仕事しやすい？——AIの特性を学び、理解していく。相手を知ることで、ぐっと付き合いやすくなります。</p>
            </div>
          </div>
        </div>

        <!-- 3: 環境づくり -->
        <div class="comm-block fade-up">
          <img class="comm-illustration"
               src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_make_transparent/f_webp,q_auto:good/v1777256062/corduroy/services/key3-environment.png"
               alt="テト（人）が「気持ちよく働ける場、一緒に作ろう！」と話し、Tiki（AI）が「うん、一緒に育てたいな」と返すイラスト"
               loading="lazy" width="1280" height="720" />
          <div class="comm-header">
            <span class="comm-num">3</span>
            <h3>お互いが心地よく働ける環境をつくる</h3>
            <span class="comm-tag">#環境づくり</span>
          </div>
          <div class="comm-two-col">
            <div class="comm-col human">
              <div class="comm-label">人間関係では</div>
              <p>お互いのことを知った上で、二人とも気持ちよく過ごせる環境を整えていく。相手の好みも尊重し、自分の快適さも大切にする。それが長く続く関係の基盤になる。</p>
            </div>
            <div class="comm-eq" aria-hidden="true">≒</div>
            <div class="comm-col ai">
              <div class="comm-label">AIも似てる</div>
              <p>AIはMarkdownが読みやすい。でも人間には見にくいこともある。ならAIへのインプットはMarkdownで、人間が見るものはブラウザで見やすい形にする。チャットだけだと文脈を忘れてしまうから、ファイルに自分の情報を残していく。お互いが仕事しやすい環境を、一緒につくっていきます。</p>
            </div>
          </div>
        </div>

      </div>
    </section>


    <!-- =====================================================
      05. こう変わります — フェーズ別
    ===================================================== -->
    <section class="transform-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>Transformation</small>
          <h2>こう変わります。</h2>
        </div>
        <div class="phase-list">
          <div class="phase-item fade-up">
            <div class="phase-num">1</div>
            <div class="phase-content">
              <p class="phase-before">「AIって結局よくわからない」</p>
              <span class="phase-arrow" aria-hidden="true">→</span>
              <p class="phase-after">「こういう仕組みなんだ、面白い」</p>
            </div>
          </div>
          <div class="phase-item fade-up">
            <div class="phase-num">2</div>
            <div class="phase-content">
              <p class="phase-before">「うまく使えない、どうしよう」</p>
              <span class="phase-arrow" aria-hidden="true">→</span>
              <p class="phase-after">「AIと一緒にやるの、楽しい」</p>
            </div>
          </div>
          <div class="phase-item fade-up">
            <div class="phase-num">3</div>
            <div class="phase-content">
              <p class="phase-before">「便利だけど、なくても困らない」</p>
              <span class="phase-arrow" aria-hidden="true">→</span>
              <p class="phase-after">「いないと不安になるくらいの相棒」</p>
            </div>
          </div>
          <div class="phase-item fade-up">
