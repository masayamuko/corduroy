---
import Layout from '../../layouts/Layout.astro';

// お知らせ記事リスト（新しい順）
// 新しい記事を追加するときは、このリストの先頭に追加し、
// 対応する個別ページ（src/pages/news/<slug>.astro）も必要なら作成する。
const posts = [
  {
    slug: 'welcome',
    date: '2026-04-17',
    category: 'お知らせ',
    title: 'お知らせページを新設しました',
    excerpt: 'コールテンから皆さまへのお知らせ・活動報告・学びをまとめる場を新設しました。小さな動きもコツコツ共有していきます。',
    external: false,
  },
];

const title = "お知らせ｜株式会社コールテン";
const description = "コールテンからのお知らせ・活動報告・AI活用に関する気づきを発信しています。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://corduroy.co.jp/news/"
  ogUrl="https://corduroy.co.jp/news/"
  ogType="website"
>
  <main>
    <section class="hero">
      <div class="container">
        <div class="fade-up" style="text-align:center;">
          <span class="eyebrow">NEWS</span>
          <h1>お知らせ</h1>
          <p class="lead">
            コールテンからのお知らせ・活動報告・AI活用にまつわる気づきを、少しずつ共有していきます。<br>
            <span class="mini-note">紹介限定・長期前提でやっている会社なので、発信はゆっくりペースです。</span>
          </p>
        </div>
      </div>
    </section>

    <section class="container" style="padding-top:20px; padding-bottom:120px;">
      <div class="posts-list fade-up">
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>まだ投稿はありません。</p>
          </div>
        ) : (
          posts.map((post) => (
            <a
              href={post.external ? post.slug : `/news/${post.slug}`}
              class="post-card"
              target={post.external ? '_blank' : '_self'}
              rel={post.external ? 'noopener noreferrer' : undefined}
            >
              <div class="post-meta">
                <time class="post-date">{post.date}</time>
                <span class="post-cat">{post.category}</span>
              </div>
              <h2 class="post-title">{post.title}</h2>
              <p class="post-excerpt">{post.excerpt}</p>
              <span class="post-link">続きを読む →</span>
            </a>
          ))
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    padding: 130px 0 60px;
    background: linear-gradient(180deg, var(--cream) 0%, #f0f7f4 100%);
    text-align: center;
  }
  .eyebrow {
    display: inline-block;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.2em;
    font-size: 12px;
    font-family: "Space Grotesk", sans-serif;
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: clamp(36px, 5vw, 54px);
    margin-bottom: 20px;
  }
  .hero .lead {
    max-width: 560px;
    margin: 0 auto;
    color: var(--text-light);
    line-height: 2;
  }
  .mini-note {
    font-size: 13px;
    color: var(--text-light);
    opacity: 0.75;
  }

  .posts-list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .post-card {
    display: block;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 28px 32px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 10px rgba(5,32,24,0.04);
    transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(5,32,24,0.08);
    border-color: rgba(22,97,78,0.18);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
  }
  .post-date {
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }
  .post-cat {
    display: inline-block;
    background: rgba(22,97,78,0.08);
    color: var(--sea);
    border-radius: 99px;
    padding: 3px 11px;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .post-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.5;
    margin: 0 0 10px;
  }
  .post-excerpt {
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.85;
    margin: 0 0 14px;
  }
  .post-link {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    color: var(--sea);
    font-family: "Space Grotesk", sans-serif;
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-light);
  }

  @media (max-width: 640px) {
    .hero { padding: 88px 16px 40px; }
    .post-card { padding: 22px 22px; }
    .post-title { font-size: 17px; }
  }
</style>
