---
import Layout from '../../layouts/Layout.astro';
import { departments, graduates, upcoming, totalActiveMembers } from '../../data/members';

const title = "メンバー紹介｜株式会社コールテン";
const description = "コールテンは、代表の向とAI社員たちがチームを組む、ちょっと変わった会社です。";

const totalMembers = totalActiveMembers;
const heroDashboardImage = 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png';
---

<Layout title={title} description={description} canonicalUrl="https://www.corduroy.co.jp/members/" ogUrl="https://www.corduroy.co.jp/members/">
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/"},
          {"@type": "ListItem", "position": 2, "name": "メンバー紹介"}
        ]
      }
    </script>
  </Fragment>

  <main id="top">

    <!-- Hero -->
    <section class="members-hero">
      <div class="members-hero-bg" aria-hidden="true"></div>
      <div class="members-hero-overlay" aria-hidden="true"></div>
      <div class="container">
        <div class="fade-up members-hero-inner">
          <small class="eyebrow">Members</small>
          <h1>チームメンバー紹介</h1>
          <p class="lead">コールテンは、<strong>代表の向と、AI社員{totalMembers}名＋COS Tiki</strong>がチームを組む、ちょっと変わった会社です。</p>
          <div class="hero-stats">
            <div class="stat-item">
              <span class="stat-num">{totalMembers}</span>
              <span class="stat-label">AI社員</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-num">1</span>
              <span class="stat-label">COS（Tiki）</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-num">1</span>
              <span class="stat-label">人間の代表</span>
            </div>
          </div>
          <div class="hero-disclosure">
            <a href="#ai-disclosure" class="hero-disclosure-link">※ 本ページのメンバーは全員AI社員です（詳細）</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Hero Video: AI team intro -->
    <section class="hero-video-section">
      <div class="container">
        <div class="hero-video fade-up">
          <p class="hero-video-eyebrow">この動画は、コールテンのAIチームが作りました</p>
          <h2 class="hero-video-title">AI社員チームと一緒に作った、チーム紹介ムービー</h2>
          <div class="hero-video-frame">
            <iframe
              src="https://www.youtube-nocookie.com/embed/K_UWvzIuAP4?rel=0&modestbranding=1"
              title="コールテンのAIチーム紹介ムービー"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              referrerpolicy="strict-origin-when-cross-origin"
            ></iframe>
          </div>
          <p class="hero-video-caption">
            企画・台本・映像生成・ナレーション・編集まで、すべて<strong>AI社員チーム</strong>が分担して作りました。AI活用の雰囲気を、36秒でつかめるはずです。
          </p>
        </div>
      </div>
    </section>

    <!-- Intro -->
    <section class="members-intro">
      <div class="container">
        <div class="intro-grid fade-up">
          <div class="intro-text">
            <small class="eyebrow">About the team</small>
            <h2>自立・改善する<br />AI社員の組織。</h2>
            <p>コールテンでは業務ごとにAIエージェント（AI社員）を設計し、メインのエージェント（COS: Tiki）が仕事を割り振って進めています。この仕組みを見ていただくだけでも、AI活用の具体的なイメージが掴めるはずです。</p>
            <p>朝のブリーフィング、議事録の構造化、請求書の発行、コードのレビュー、SNS投稿のドラフト——それぞれの仕事に「一番向いた性格と得意分野」を持つAI社員が、代表・人間スタッフと連携して動いています。</p>
            <a href="/members/about/" class="btn secondary">AI社員の仕組みを詳しく →</a>
          </div>
          <div class="intro-points">
            <div class="point">
              <div class="point-icon-row">
                <svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                <div class="point-num">01</div>
              </div>
              <h3>専門特化</h3>
              <p>業務領域・性格・判断基準を明確に持つ。AI社員{totalMembers}名＋COS Tikiが、それぞれの専門で動く。</p>
            </div>
            <div class="point">
              <div class="point-icon-row">
                <svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 2.5-1.3 4.8-3.5 6v1.5a1.5 1.5 0 0 1-1.5 1.5h-4a1.5 1.5 0 0 1-1.5-1.5V15c-2.2-1.2-3.5-3.5-3.5-6a7 7 0 0 1 7-7z"/><path d="M9.5 19h5"/><path d="M10 21h4"/><path d="M12 2v3"/><path d="M4.2 5.2l2.1 2.1"/><path d="M19.8 5.2l-2.1 2.1"/></svg>
                <div class="point-num">02</div>
              </div>
              <h3>記憶を持つ</h3>
              <p>過去のやりとり・判断履歴をメモリとして蓄積。使うほど精度が上がる。</p>
            </div>
            <div class="point">
              <div class="point-icon-row">
                <svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-3-3.87"/><path d="M7 21v-2a4 4 0 0 1 3-3.87"/><circle cx="12" cy="7" r="4"/><path d="M5.7 17.3a9 9 0 0 1 0-10.6"/><path d="M18.3 6.7a9 9 0 0 1 0 10.6"/></svg>
                <div class="point-num">03</div>
              </div>
              <h3>人間と協業</h3>
              <p>最終判断は代表・人間が行い、AI社員は情報整理・ドラフト・監視を担う。</p>
            </div>
            <div class="point">
              <div class="point-icon-row">
                <svg class="point-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6"/><path d="M2.5 16A10 10 0 0 1 5.6 5.6"/><path d="M21.5 8A10 10 0 0 1 18.4 18.4"/></svg>
                <div class="point-num">04</div>
              </div>
              <h3>常に改善</h3>
              <p>フィードバックを蓄積し、毎週の振り返りで少しずつ賢くなる仕組み。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- これは遊びじゃない（ハーネス最適化の意義） -->
    <section class="harness-section">
      <div class="container">
        <div class="harness-grid fade-up">
          <div class="harness-left">
            <small class="eyebrow">Why characters?</small>
            <h2>キャラクター化は、<span class="hl">出力精度</span>と<span class="hl">人の認知</span>、両方のための設計。</h2>
            <p>AI社員に名前・性格・価値観を与えるのは、<strong>出力精度を安定させる</strong>ためと、<strong>人間が扱いやすくする</strong>ための両方を兼ねた設計です。役割・判断基準・口調を明確にすることで生成AIの出力がブレにくくなり、同時に擬人化することで愛着と使いやすさが生まれ、人と例えて考えるほうが判断も自然になります（このアプローチは認知科学の論文でも効果が示されています）。</p>
            <p>そして重要なのは、<strong>「ハーネスエンジニアリング（Harness Engineering）」</strong> の本質は<strong>フィードバックループを回せること</strong>です。同じ業務を繰り返しても品質がブレにくい理由の一つがここにあり、このループがあるからこそ、人間が都度手を入れなくてもAI側で精度の高いアウトプットに近づいていきます。</p>
          </div>
          <div class="harness-right">
            <div class="harness-card">
              <div class="harness-step">
                <div class="harness-step-head">
                  <svg class="harness-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 3v18"/><path d="M3 9h6"/><path d="M3 15h6"/></svg>
                  <div class="harness-step-num">01</div>
                </div>
                <h3>役割の明確化</h3>
                <p>「何を判断し、何を判断しないか」を明文化。曖昧さを削る。</p>
              </div>
              <div class="harness-step">
                <div class="harness-step-head">
                  <svg class="harness-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                  <div class="harness-step-num">02</div>
                </div>
                <h3>性格による一貫性</h3>
                <p>語り口・優先順位・好みを固定し、毎回の出力にブレを出さない。</p>
              </div>
              <div class="harness-step">
                <div class="harness-step-head">
                  <svg class="harness-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6"/><path d="M2.5 16A10 10 0 0 1 5.6 5.6"/><path d="M21.5 8A10 10 0 0 1 18.4 18.4"/></svg>
                  <div class="harness-step-num">03</div>
                </div>
                <h3>ループで自動改善</h3>
                <p>出力 → 評価 → 反映 のループが回るから、人手を介さなくても品質が育つ。</p>
              </div>
              <div class="harness-step">
                <div class="harness-step-head">
                  <svg class="harness-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M21 3l-8.5 8.5"/><path d="M3 3l8.5 8.5"/><path d="M3 21l8.5-8.5"/><path d="M21 21l-8.5-8.5"/><path d="M16 21h5v-5"/><path d="M8 21H3v-5"/></svg>
                  <div class="harness-step-num">04</div>
                </div>
                <h3>生成と評価の分離</h3>
                <p>作る人と見る人を別AIに分ける。ダブルチェックで見落としを防ぐ。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 組織図 -->
    <section class="org-section bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Organization</small>
          <h2>組織図</h2>
          <p>代表の向のもとに、AI社員{totalMembers}名＋COS Tikiが在籍しています。<br />各部門は部門代表がTiki（COS）との窓口になり、チーム内の振り分けを担います。</p>
        </div>

        <div class="org-chart fade-up">
          <div class="org-ceo">
            <div class="org-card org-ceo-card">
              <div class="org-card-role">代表取締役</div>
              <div class="org-card-name">向 雅也（Masaya Muko）</div>
              <div class="org-card-note mini">人間 / 最終判断者</div>
            </div>
          </div>

          <div class="org-line-down" aria-hidden="true"></div>

          <div class="org-cos">
            <div class="org-card org-cos-card">
              <div class="org-card-role">COS（Chief of Staff）</div>
              <div class="org-card-name">Tiki</div>
              <div class="org-card-note mini">全社横断・ルーティング担当</div>
            </div>
          </div>

          <div class="org-line-down" aria-hidden="true"></div>

          <div class="org-departments">
            {departments.map((dept) => {
              const deptMembers = dept.members.filter((m) => m.id !== 'exec-cos');
              return (
                <div class="org-dept" style={`--dept-color: ${dept.color};`}>
                  <div class="org-dept-header">
                    <span class="org-dept-dot"></span>
                    <h4>{dept.name}</h4>
                    <span class="org-dept-count">{deptMembers.length}名</span>
                  </div>
                  <ul class="org-dept-members">
                    {deptMembers.map((m) => (
                      <li>
                        <span class="org-member-name">{m.name}</span>
                        <span class="org-member-role mini">{m.role}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- Working Dashboard -->
    <section class="dashboard-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>Working Now</small>
          <h2>実際に働いている様子</h2>
          <p>社内ダッシュボードで、各AI社員が部屋の中で仕事をしています。<br />メールを届けたり、会議に集まったり、休憩したり——実際の業務の動きをリアルタイムで可視化しています。</p>
        </div>

        <div class="dashboard-gallery fade-up">
          <div class="dashboard-frame dashboard-main">
            <div class="dashboard-label">社内ダッシュボード：オフィス全景</div>
            <div class="dashboard-image-wrap">
              <img src="/assets/images/members/office_overview.png" alt="各部屋でAI社員たちが稼働中のオフィス全景" width="1371" height="738" loading="lazy" />
            </div>
            <div class="dashboard-caption">
              <span>経営企画室 / マーケ / 開発 / 営業 / CS / プロダクト / 業務推進 / 経理 / 法務の各部門が同じフロアに。キャラクターがMTG・メール配信・チェック作業をリアルタイムで動き回ります。</span>
            </div>
          </div>
          <p class="dashboard-note mini">※ 社内向けダッシュボードはピクセルアート風UIで稼働中。将来的に各部屋別キャプチャ・動画も掲載予定です。</p>
        </div>
      </div>
    </section>

    <!-- Members by Department -->
    <section class="members-directory bg-gradient-soft">
      <div class="container">
        <div class="section-head fade-up">
          <small>Directory</small>
          <h2>部門別メンバー一覧</h2>
          <p>AI社員{totalMembers}名＋COS Tiki。それぞれの得意分野・性格・趣味まで掲載しています。<br /><small class="mini">カードをマウスオーバー（スマホはタップ）すると詳しいプロフィールが開きます。</small></p>
        </div>

        {departments.map((dept) => (
          <div class="dept-block fade-up" style={`--dept-color: ${dept.color};`}>
            <div class="dept-header">
              <div class="dept-title">
                <span class="dept-dot"></span>
                <h3>{dept.name}</h3>
                <span class="dept-count">{dept.members.length}名</span>
              </div>
              <p class="dept-summary mini">{dept.summary}</p>
            </div>

            <div class="meishi-grid">
              {dept.members.map((member) => (
                <article class="meishi" tabindex="0" role="button" aria-pressed="false" aria-label={`${member.name}（${member.role}）の名刺。詳細を表示するにはホバーまたはタップ`}>
                  <div class="meishi-inner">
                    <!-- 表面 -->
                    <div class="meishi-front">
                      <span class="meishi-ai-badge">AI</span>
                      <div class="meishi-card-header">
                        <img class="meishi-logo" src="/favicon.svg" alt="コールテンロゴマーク" width="128" height="128" loading="lazy" />
                        <div class="meishi-company">
                          <div class="meishi-company-name">株式会社コールテン</div>
                          <div class="meishi-dept-label">{dept.name}</div>
                        </div>
                      </div>
                      <div class="meishi-body">
                        <div class={`meishi-avatar ${member.avatar ? 'has-photo' : ''}`} style={member.avatar ? `background: linear-gradient(135deg, ${dept.color}22, ${dept.color}44);` : `background: linear-gradient(135deg, ${dept.color}33, ${dept.color}66);`}>
                          {member.avatar ? (
                            <img src={member.avatar} alt={`${member.name}のアバター`} width="80" height="80" loading="lazy" />
                          ) : (
                            <span class="meishi-emoji">{member.emoji}</span>
                          )}
                        </div>
                        <div class="meishi-identity">
                          <div class="meishi-role">{member.role}{member.badge && <span class="meishi-badge">{member.badge}</span>}</div>
                          <h4 class="meishi-name">{member.name}</h4>
                          <div class="meishi-skills">
                            {member.skills.slice(0, 2).map((s) => (
                              <span class="meishi-skill">{s}</span>
                            ))}
                          </div>
                        </div>
                      </div>
                      <div class="meishi-hint" aria-hidden="true">裏面 ›</div>
                    </div>

                    <!-- 裏面 -->
                    <div class="meishi-back">
                      <div class="meishi-back-scroll">
                        <div class="meishi-back-header">
                          <span class="meishi-back-name">{member.name}</span>
                          <span class="meishi-back-role">{member.role}</span>
                        </div>
                        <div class="meishi-back-block">
                          <div class="meishi-back-label">得意分野</div>
                          <div class="meishi-back-skills">
                            {member.skills.map((s) => (
                              <span class="meishi-skill alt">{s}</span>
                            ))}
                          </div>
                        </div>
                        <div class="meishi-back-block">
                          <div class="meishi-back-label">性格・人となり</div>
                          <p class="meishi-back-text">{member.personality}</p>
                        </div>
                        <div class="meishi-back-row">
                          <div class="meishi-back-cell">
                            <div class="meishi-back-label">大切にしてるもの</div>
                            <div class="meishi-back-value">{member.philosophy}</div>
                          </div>
                          <div class="meishi-back-cell">
                            <div class="meishi-back-label">趣味</div>
                            <div class="meishi-back-value">{member.hobby}</div>
                          </div>
                        </div>
                        <div class="meishi-back-block">
                          <div class="meishi-back-label">社内での役回り</div>
                          <p class="meishi-back-text">{member.team_role}</p>
                        </div>
                        <div class="meishi-back-block">
                          <div class="meishi-back-label">飲み会での役回り</div>
                          <p class="meishi-back-text">{member.party}</p>
                        </div>
                        <div class="meishi-back-block source">
                          <div class="meishi-back-label">前職</div>
                          <p class="meishi-back-text small">{member.previous_job}</p>
                        </div>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 求人中 -->
    <section class="upcoming-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>Recruiting</small>
          <h2>求人中</h2>
          <p>代表の向が間に入って進めています。<br />リクエストはお気軽にどうぞ（こんな役割の社員が欲しい、など）。</p>
        </div>

        <div class="upcoming-grid fade-up">
          {upcoming.map((u) => (
            <div class="upcoming-card">
              <span class="coming-tag">募集中</span>
              <h3>{u.name}</h3>
              <div class="upcoming-role">{u.role}</div>
              <p class="mini">{u.note}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 卒業メンバー -->
    <section class="graduates-section">
      <div class="container">
        <div class="section-head fade-up">
          <small>Alumni</small>
          <h2>卒業メンバー</h2>
          <p>2026年6月の組織再編で、{graduates.length}名のAI社員が役割を仲間に引き継いで卒業しました。<br />それぞれの仕事は、いまもチームの中で生きています。</p>
        </div>

        <div class="graduates-grid fade-up">
          {graduates.map((g) => (
            <div class="graduate-card">
              <div class="graduate-head">
                <span class="graduate-emoji" aria-hidden="true">{g.emoji}</span>
                <div class="graduate-identity">
                  <div class="graduate-name">{g.name}</div>
                  <div class="graduate-role">{g.role}</div>
                </div>
              </div>
              <p class="graduate-handover">{g.handover}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- AI Disclosure（法的開示） -->
    <section id="ai-disclosure" class="legal-notice-section">
      <div class="container">
        <div class="legal-notice fade-up">
          <div class="legal-icon">ℹ️</div>
          <div class="legal-text">
            <strong>本ページに掲載のメンバーについて（AI社員に関するご案内）</strong>
            <p>本ページでご紹介する「AI社員」は、株式会社コールテンが独自に構築・運用する<strong>AIエージェント（生成AIを基盤とするバーチャルスタッフ）</strong>です。人間の従業員ではありません。</p>
