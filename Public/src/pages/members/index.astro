  .meishi {
    /* aspect-ratio は .meishi-front 側に移譲（v5 normal flow 設計） */
    cursor: pointer;
    outline: none;
    position: relative;
    /* タップ判定の安定化（公式 MDN/WebKit ベスト・プラクティス） */
    -webkit-tap-highlight-color: transparent;
    /* WebKit の 300ms タップ遅延を解消（fast-tap 最適化） */
    touch-action: manipulation;
    /* テキスト選択暴発を防ぐ（タップ→選択カーソル防止） */
    user-select: none;
    -webkit-user-select: none;
  }
  /* 全子孫要素にも適用（iOS Safari でカード内テキストの長タップ選択を抑止） */
  .meishi-front,
  .meishi-front *,
  .meishi-back,
  .meishi-back * {
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
  }
  .meishi:focus-visible {
    box-shadow: 0 0 0 3px var(--accent);
  }
  /* meishi-inner は構造的には残す（HTML互換）。height:100% は外す（natural flow） */
  .meishi-inner {
    position: relative;
    width: 100%;
    border-radius: 10px;
  }
  /* v5 設計: 絶対配置を完全廃止し、normal flow + display 切替に
     真因: absolute の入れ子で親が collapse → 裏面が見えなくなる
     公式: developer.mozilla.org/en-US/docs/Web/CSS/transition-behavior */
  .meishi-front,
  .meishi-back {
    /* normal flow で配置（absolute廃止） */
    position: relative;
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #fff;
    box-shadow:
      2px 3px 0 rgba(0, 0, 0, 0.04),
      4px 6px 0 rgba(0, 0, 0, 0.03),
      8px 14px 22px rgba(5, 32, 24, 0.12);
  }
  /* タップ判定を .meishi 親に集約 */
  .meishi-front *,
  .meishi-back * {
    pointer-events: none;
  }
  /* 表面（初期表示） */
  .meishi-front {
    display: flex;
    pointer-events: auto;
  }
  /* 裏面（初期非表示） */
  .meishi-back {
    display: none;
