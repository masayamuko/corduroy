  /* meishi-inner は構造的には残す（HTML互換）。height:100% は外す（natural flow） */
  .meishi-inner {
    position: relative;
    width: 100%;
    border-radius: 10px;
  }
  /* v5 設計: 絶対配置を完全廃止し、normal flow + display 切替に
     真因: absolute の入れ子で親が collapse → 裏面が見えなくなる
     公式: developer.mozilla.org/en-US/docs/Web/CSS/transition-behavior */
  .meishi-front,
  .meishi-back {
    /* normal flow で配置（absolute廃止） */
    position: relative;
    width: 100%;
    border: 1px solid var(--line);
