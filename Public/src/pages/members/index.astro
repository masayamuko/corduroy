  .meishi {
    /* aspect-ratio は .meishi-front 側に移譲（v5 normal flow 設計） */
    cursor: pointer;
    outline: none;
    position: relative;
    /* タップ判定の安定化（公式 MDN/WebKit ベスト・プラクティス） */
    -webkit-tap-highlight-color: transparent;
    /* WebKit の 300ms タップ遅延を解消（fast-tap 最適化） */
    touch-action: manipulation;
    /* テキスト選択暴発を防ぐ（タップ→選択カーソル防止） */
    user-select: none;
    -webkit-user-select: none;
  }
  /* 全子孫要素にも適用（iOS Safari でカード内テキストの長タップ選択を抑止） */
  .meishi-front,
  .meishi-front *,
