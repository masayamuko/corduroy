<script>
  // 名刺: タップ/クリックでflip切替（シンプル版）
  // 3D 廃止 + opacity 切替方式に伴い、click ハンドラー1本だけのシンプル設計に戻す
  const cards = document.querySelectorAll<HTMLElement>('.meishi');
  const syncPressed = (card: HTMLElement) => {
    card.setAttribute('aria-pressed', card.classList.contains('flipped') ? 'true' : 'false');
  };
  const flip = (card: HTMLElement) => {
    card.classList.toggle('flipped');
    syncPressed(card);
  };
  cards.forEach((card) => {
    card.addEventListener('click', () => flip(card));
    card.addEventListener('keydown', (e) => {
      const key = (e as KeyboardEvent).key;
      if (key === 'Enter' || key === ' ') {
        e.preventDefault();
        flip(card);
      }
    });
  });
</script>
