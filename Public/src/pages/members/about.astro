                <div class="flow-arrow" aria-hidden="true">→</div>
                <div class="flow-node flow-node-review"><div class="flow-node-role">担当AI社員</div><div class="flow-node-name">該当者へ</div></div>
                <div class="flow-arrow" aria-hidden="true">→</div>
                <div class="flow-node-group">
                  <div class="flow-node"><div class="flow-node-role">メモリ</div><div class="flow-node-name">学習蓄積</div></div>
                  <div class="flow-node"><div class="flow-node-role">ガイドライン</div><div class="flow-node-name">反映</div></div>
                </div>
