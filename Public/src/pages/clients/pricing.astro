<script>
  // ===== 根拠・ポジション表示の3パターン切替（検討用） =====
  const root = document.getElementById('pp-root');
  document.querySelectorAll('.picker-chips .chip').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.picker-chips .chip').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      root?.setAttribute('data-pattern', btn.getAttribute('data-p') || 'A');
    });
  });

  // ===== 料金シミュレーター =====
  const yen = (n: number) => '¥' + n.toLocaleString('ja-JP');
  let mode = 'monthly';

  function calc() {
    let init = 0;
    let monthly = 0;
    // CMSはサイト制作選択時のみ有効（計算前に状態を確定させる）
    const siteSelected = [...document.querySelectorAll<HTMLInputElement>('input[name="site"][data-init]')].some(
      (r) => r.checked && r.getAttribute('data-init') !== '0'
    );
    const cms = document.getElementById('sim-cms') as HTMLInputElement | null;
    if (cms) {
      cms.disabled = !siteSelected;
      if (!siteSelected) cms.checked = false;
    }
    // 初期費用: checkbox / radio (data-init)
    document.querySelectorAll<HTMLInputElement>('.pp-sim input[data-init]').forEach((input) => {
      if (!input.checked || input.disabled) return;
      let price = parseInt(input.getAttribute('data-init') || '0', 10);
      const qtyId = input.getAttribute('data-qty');
      if (qtyId) {
        const q = document.getElementById('qty-' + qtyId) as HTMLInputElement | null;
        price *= Math.max(1, parseInt((q && q.value) || '1', 10));
      }
      init += price;
    });
    // 月額: radio (data-monthly)
    document.querySelectorAll<HTMLInputElement>('.pp-sim input[data-monthly]').forEach((input) => {
      if (input.checked) monthly += parseInt(input.getAttribute('data-monthly') || '0', 10);
    });

    const initEl = document.getElementById('sim-init');
    const monEl = document.getElementById('sim-monthly');
    const monLabel = document.getElementById('sim-monthly-label');
    if (initEl) initEl.textContent = yen(init);
    if (monEl && monLabel) {
      if (mode === 'yearly') {
        monLabel.textContent = '月額 合計（年間換算）';
        monEl.textContent = yen(monthly * 12) + ' /年';
      } else {
        monLabel.textContent = '月額 合計';
        monEl.textContent = yen(monthly) + ' /月';
      }
    }
  }

  document.querySelectorAll('.pp-sim input').forEach((el) => {
    el.addEventListener('change', calc);
    el.addEventListener('input', calc);
  });
  document.querySelectorAll('.sim-tbtn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sim-tbtn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      mode = btn.getAttribute('data-mode') || 'monthly';
      calc();
    });
  });
  calc();
</script>

