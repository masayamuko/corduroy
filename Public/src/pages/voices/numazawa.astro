---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: '/blog/shu-interview-dx-commissioner/',
    date: '2026-03-12',
    category: 'インタビュー',
    title: '行政書士がDX推進副委員長に —— AI活用が仕事を変えた実話',
    excerpt: '行政書士のしゅうへいさんが、AI活用をきっかけにDX推進副委員長に就任。士業の業界にAIを持ち込み、研修設計や組織改革を進める実話。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png',
  },
  {
    slug: '/blog/shu-interview-coaching/',
    date: '2026-03-05',
    category: 'インタビュー',
    title: '「3時間が一瞬で過ぎる」—— AIコーチングで内省の回転数が変わった',
    excerpt: 'コーチングが好きだったけど手軽に回せなかった行政書士のしゅうへいさん。AIで客観視される経験を通じて、内省の回転数が劇的に変わった。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png',
  },
  {
    slug: '/blog/shu-ai-advisory/',
    date: '2026-04-01',
    category: '活動報告',
    title: '行政書士のしゅうへいさんにAI顧問契約をいただきました',
    excerpt: 'しゅう行政書士事務所のしゅうへいさんに、3ヶ月のお試しAI顧問契約をいただきました。一人で仕事をしている士業の方がAIエージェントでチーム化していく第一歩をサポートしています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
  },
];
---

<Layout
    title="しゅうへいさん｜クライアントさまの声｜株式会社コールテン"
    description="行政書士会のDX推進副委員長就任・AI開発会社への転身・内省の回転数アップ。SHU行政書士事務所のしゅうへいさんがAI伴走で実現した変化と、士業×AIの最前線をご紹介します。"
    canonicalUrl="https://www.corduroy.co.jp/voices/numazawa/"
    ogUrl="https://www.corduroy.co.jp/voices/numazawa/"
    ogType="profile"
>
    <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
        { "@type": "ListItem", "position": 2, "name": "クライアントさまの声", "item": "https://www.corduroy.co.jp/voices/" },
        { "@type": "ListItem", "position": 3, "name": "しゅうへいさん" }
      ]
    }
    </script>

    <main>
        <!-- ===== ヒーロー ===== -->
        <section class="hero">
            <div class="container">
                <div class="hero-inner fade-up">
                    <div class="hero-avatar">
                        <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png"
                            alt="しゅうへいさん">
                    </div>
                    <div class="hero-text">
                        <span class="eyebrow">CLIENT VOICE</span>
                        <h1>しゅうへいさん</h1>
                        <p class="hero-sub">SHU行政書士事務所 / 行政書士 / DX推進副委員長</p>
                        <div class="hero-tags">
                            <span class="hero-tag">AI顧問</span>
                            <span class="hero-tag">AI講座</span>
                            <span class="hero-tag">士業DX推進</span>
                        </div>
                    </div>
                </div>
                <div class="hero-stats fade-up">
                    <div class="stat-chip"><strong>就任</strong><span>DX推進副委員長</span></div>
                    <div class="stat-chip"><strong>転身</strong><span>AI開発会社へ</span></div>
                    <div class="stat-chip"><strong>UP</strong><span>内省の回転数</span></div>
                </div>
            </div>
        </section>

        <!-- ===== Before / After ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:40px;">
            <div class="article-content">
                <div class="section-head fade-up">
                    <small>Before / After</small>
                    <h2>コールテンでのAI学習による変化</h2>
                    <p>AI講座とAI顧問の伴走を通じて起きた変化を一目で。</p>
                </div>

                <p class="ba-meta fade-up">※ AI講座受講・AI顧問伴走を通じた個別事例です。再現を保証するものではありません。</p>

                <div class="before-after fade-up">
                    <div class="ba-card ba-before">
                        <span class="ba-label">Before</span>
                        <ul>
                            <li>ChatGPTを「検索の代わり」としてしか使えていない</li>
                            <li>AIの嘘に振り回され、信頼しきれない</li>
                            <li>コーチングは好きだが手軽に回せず、内省が深まらない</li>
                            <li>士業・行政書士業界へのAI浸透方法が見えない</li>
                        </ul>
                    </div>
                    <div class="ba-arrow" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="13 6 19 12 13 18"/>
                        </svg>
                    </div>
                    <div class="ba-card ba-after">
                        <span class="ba-label">After</span>
                        <ul>
                            <li>価値観・思考のクセを教え込んだ「第二の自分」が相棒に</li>
                            <li>AIコーチングで「3時間が一瞬」の没入と内省の回転数が劇的UP</li>
                            <li>行政書士会のDX推進副委員長に就任し、組織改革を主導</li>
                            <li>AI開発会社へ転身、士業×AIの最前線で活動</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== 本人証言（主役） ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:40px;">
            <div class="testimonial fade-up">
                <div class="testimonial-mark">“</div>
                <p class="testimonial-quote">上司に「AIと対話して進めて」と言われた時、第二の自分づくりで染み付いたやり方が、そのまま強みになりました。コールテンで学んだのは「ツールの使い方」ではなく、AIと向き合う姿勢そのもの。だから、新しい現場でも応用が利くんです。</p>
                <div class="testimonial-by">
                    <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん">
                    <div>
                        <p class="testimonial-name">しゅうへいさん</p>
                        <p class="testimonial-role">SHU行政書士事務所 / 行政書士 / DX推進副委員長</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== この事例から学べること ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:40px;">
            <div class="learn-block fade-up">
                <span class="learn-eyebrow">この事例が刺さる方</span>
                <h2 class="learn-title">こんな悩みがある方の参考になります</h2>
                <ul class="learn-list">
                    <li><strong>士業・専門家</strong>として、業務にAIをどう組み込めるかを真剣に検討している</li>
                    <li>ChatGPTの嘘に懲りて距離を置いていたが、<strong>本当は使いこなしたい</strong></li>
                    <li><strong>コーチング・内省習慣</strong>がある方で、AIで内省の回転数を上げたい</li>
                    <li>個人の活用に留まらず、<strong>業界・組織のDX推進</strong>まで広げたい</li>
                </ul>
            </div>
        </section>

        <!-- ===== ストーリー（吹き出し付き） ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:60px;">
            <div class="article-content">
                <div class="section-head fade-up">
                    <small>Story</small>
                    <h2>受講前から現在までの伴走</h2>
                </div>

                <!-- 受講前の課題 -->
                <div class="fade-up">
                    <h3>🎯 受講前の課題</h3>
                    <p>
                        行政書士として一人で事務所を運営するなかで、ChatGPTは触っていたものの「検索の代わり」止まり。AIの嘘に振り回された経験から、信頼しきれず距離を置いていた時期もありました。
                    </p>
                    <div class="dialog">
                        <div class="bubble right">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん">
                                <span class="name-tag">しゅうへい</span>
                            </div>
                            <div class="bubble-text">最初は ChatGPT を検索の代わりに使っていた感じで。聞いても適当な答えが返ってくることがあって、信頼しきれなかったんです。コーチングは好きだったので、AIで何かできないかなとは思ってたんですけど、入り口が分からなくて。</div>
                        </div>
                        <div class="bubble">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
                                <span class="name-tag">代表 向</span>
                            </div>
                            <div class="bubble-text">そうでしたね。しゅうへいさんはもともと内省・コーチングへの関心が高い方ですから、AIを「もう一人の対話相手」として迎え入れる素地は十分にあったと思います。だからこそ、その入り口を一緒に作りたいと思いました。</div>
                        </div>
                    </div>
                </div>

                <!-- AI講座での学び -->
                <div class="fade-up">
                    <h3>💡 AI講座での学び</h3>
                    <p>
                        コールテンのAI講座で、生成AIの仕組み・嘘の見抜き方・「第二の自分」を育てるワークを学習。価値観や思考のクセまで教え込むことで、AIが「対話の相棒」に変化していきました。
                    </p>
                    <div class="dialog">
                        <div class="bubble right">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん">
                                <span class="name-tag">しゅうへい</span>
                            </div>
                            <div class="bubble-text">「第二の自分」のワークが衝撃でした。価値観や思考のクセを教え込んだら、AIが客観視してくれるようになって。コーチングが好きだったのに手軽に回せなかったのが、AIで一気に回せるようになりました。3時間が一瞬で過ぎるんです。</div>
                        </div>
                        <div class="bubble">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
                                <span class="name-tag">代表 向</span>
                            </div>
                            <div class="bubble-text">あの没入感はすごいですよね。検索の道具ではなく、自分の思考をブーストしてくれる相棒として使えるようになった瞬間に、しゅうへいさんの世界が一気に広がっていったのを感じました。</div>
                        </div>
                    </div>
                </div>

                <!-- AI顧問での実践と業界DX -->
                <div class="fade-up">
                    <h3>🤝 AI顧問での実践と業界DX</h3>
                    <p>
                        AI講座での学びをきっかけに、しゅうへいさんは行政書士会のDX推進副委員長に就任。さらにAI開発会社への転身も果たされました。コールテンとしては、AI講座から AI 顧問への伴走を通じて、学んだ「AIと向き合う姿勢」が組織や業界に広がっていく過程をサポートしています。
                    </p>
                    <div class="dialog">
                        <div class="bubble right">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん">
                                <span class="name-tag">しゅうへい</span>
                            </div>
                            <div class="bubble-text">行政書士会のDX推進副委員長になって、士業の業界にAIを持ち込もうと動いています。さらにAI開発会社にも入って、上司から「AIと対話して進めて」と言われる場面でも、コールテンで染み付いたやり方がそのまま強みになっています。</div>
                        </div>
                        <div class="bubble">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
                                <span class="name-tag">代表 向</span>
                            </div>
                            <div class="bubble-text">個人の変化が、業界の変化に広がっていくプロセスを伴走させていただけるのは、こちらとしても本当にありがたい時間です。これからも士業×AIの最前線をしゅうへいさんと一緒に切り拓いていきたいと思います。</div>
                        </div>
                    </div>
                </div>

                <!-- 今後の展望 -->
                <div class="fade-up">
                    <h3>🚀 今後の展望</h3>
                    <p>
                        行政書士業界のDX推進、士業向けAI研修の設計、AI開発会社での実践——個人のAI活用が組織と業界へと広がっていくフェーズです。コールテンとしては、しゅうへいさんが士業×AIのロールモデルとして活躍されるよう、伴走を続けていきます。
                    </p>
                </div>
            </div>
        </section>

        <!-- ===== しゅうへいさんを知る ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:60px;">
            <div class="section-head fade-up" style="text-align:center; max-width:820px; margin:0 auto 24px;">
                <small>About Shuhei</small>
                <h2>しゅうへいさんをもっと知る</h2>
            </div>
            <div class="social-links fade-up">
                <!-- TODO: しゅうへいさんのSNS / SHU行政書士事務所 URL届き次第差し替え -->
                <div class="social-card coming-soon" aria-disabled="true">
                    <span class="social-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                    </span>
                    <div class="social-body">
                        <p class="social-platform">SHU行政書士事務所</p>
                        <p class="social-handle">Coming Soon</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== FAQ ===== -->
        <section class="container faq" style="padding-top:20px; padding-bottom:60px;">
            <div class="section-head fade-up" style="text-align:center; max-width:820px; margin:0 auto 32px;">
                <small>FAQ</small>
                <h2>よくあるご質問</h2>
            </div>
            <div class="faq-items fade-up">
                <details open>
                    <summary>しゅうへいさんのように、士業の方でもAI伴走は受けられますか？</summary>
                    <p>はい、士業・専門家の方も多く伴走させていただいています。しゅうへいさんのケースでは、個人の業務改善から組織のDX推進・業界への波及まで広がっていきました。一人事務所の方も、組織所属の方も、まずは個別にご相談ください。</p>
                </details>
                <details>
                    <summary>AIの嘘に懲りて距離を置いていたのですが、もう一度向き合えますか？</summary>
                    <p>むしろそういう方こそ伴走の効果が出ます。しゅうへいさんも当初は「信頼できない」と距離を置いていましたが、生成AIの仕組み・嘘の見抜き方を学び、価値観を教え込む型を実践することで、対話の相棒として使えるようになりました。</p>
                </details>
                <details>
                    <summary>「第二の自分」を育てるのにどれくらいかかりますか？</summary>
                    <p>使い始めて数週間で違いを感じる方が多いです。しゅうへいさんも、価値観や思考のクセを教え込むワークを通じて、内省の回転数が劇的に変わったと話されています。一気に作るのではなく、毎日の対話で育てていきます。</p>
                </details>
                <details>
                    <summary>個人の活用から組織・業界に広げていくにはどうすればいいですか？</summary>
                    <p>まず本人がAIを使いこなせるようになることが起点です。しゅうへいさんは、個人で身につけた「AIと向き合う姿勢」を行政書士会のDX推進・AI開発会社での実践に展開されました。コールテンでは、組織展開のフェーズでもご相談を受け付けています。</p>
                </details>
                <details>
                    <summary>士業以外の業種でも、しゅうへいさんと同じ変化は起きますか？</summary>
                    <p>はい。型は業種を問いません。しゅうへいさんの事例で起きた「検索→相棒」「内省の回転数UP」「組織への波及」は、教育・NPO・サービス業・クリエイティブなど幅広い領域でも再現されています。</p>
                </details>
            </div>
        </section>

        <!-- ===== 関連記事 ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:60px;">
            <div class="section-head fade-up" style="text-align:center; max-width:820px; margin:0 auto 32px;">
                <small>Related Articles</small>
                <h2>しゅうへいさん関連の記事</h2>
            </div>
            <div class="posts-list fade-up">
                {posts.map((post) => (
                    <a href={post.slug} class="post-card">
                        <div class="post-thumb">
                            <img src={post.thumbnail} alt="" width="120" height="120" loading="lazy" />
                        </div>
                        <div class="post-body">
                            <div class="post-meta">
                                <time class="post-date" datetime={post.date}>{post.date}</time>
                                <span class="post-cat">{post.category}</span>
                            </div>
                            <h2 class="post-title">{post.title}</h2>
                            <p class="post-excerpt">{post.excerpt}</p>
                            <span class="post-link">続きを読む →</span>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <!-- ===== 代表 向より ===== -->
        <section class="container" style="padding-top:0; padding-bottom:40px;">
            <div class="oshi-banner fade-up">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                    alt="向 雅也" class="oshi-avatar">
                <div class="oshi-body">
                    <p class="oshi-label">代表 向より</p>
                    <p class="oshi-text">しゅうへいさんは、もともと内省とコーチングを大切にされてきた方です。だからこそ、AIを「もう一人の対話相手」として迎え入れたとき、その変化のスピードが早かった。個人の変化が業界全体のDX推進へと広がっていく姿を、伴走者として一緒に見られているのは、コールテンとしても本当に光栄です。</p>
                </div>
            </div>
        </section>

        <!-- ===== CTA ===== -->
        <section id="contact" class="container" style="padding-bottom:100px">
            <div class="card fade-up cta-card">
                <h3>しゅうへいさんと同じように、AIと伴走したい方へ</h3>
                <p class="cta-lead">コールテンの伴走は紹介を優先していますが、ご紹介がない場合も状況に応じて個別に受け付けています。まずは最初の対話で、あなたの状況がしゅうへいさんの事例に近いかを一緒に確認しましょう。</p>
                <ul class="cta-points">
                    <li>対象: 士業・専門家・法人・個人事業主（業種不問）</li>
                    <li>形式: AI顧問（月次伴走）／AI講座（短期）／単発相談</li>
                    <li>初回返信目安: 2〜3営業日</li>
                </ul>
                <div class="cta-actions">
                    <a class="btn" href="/contact">自分も伴走を相談する</a>
                    <a class="btn secondary" href="/voices/">他のクライアントの声を見る</a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    /* ===== Hero ===== */
    .hero {
        padding: 60px 0 40px;
        background: linear-gradient(180deg, var(--cream) 0%, #f0f7f4 100%);
    }
    .hero-inner {
        display: flex;
        align-items: center;
        gap: 28px;
        max-width: 820px;
        margin: 0 auto;
    }
    .hero-avatar {
        flex-shrink: 0;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 3px solid #fff;
