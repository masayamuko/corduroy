---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: '/blog/tkr-interview-education/',
    date: '2026-03-25',
    category: 'インタビュー',
    title: '「できること」と「やりたいこと」が重なった日 —— たかろーさんと世界の教育チャンネルの裏側',
    excerpt: '動画制作のプロが、子ども教育への思いをAIの力で形にし始めた。フィンランドの教育哲学をショート動画にするプロジェクトの裏側を聞きました。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png',
  },
  {
    slug: '/blog/tkr-interview-second-me/',
    date: '2026-01-10',
    category: 'インタビュー',
    title: '「本音で答えて」—— フリーランスたかろーさんが見つけた、AIとの付き合い方',
    excerpt: 'ChatGPTを検索ツールとして使うだけだった状態から、価値観やクセまで教え込んだ「第二の自分」を育てるまでの変化を聞きました。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png',
  },
  {
    slug: '/blog/tkr-ai-advisory/',
    date: '2025-12-24',
    category: '活動報告',
    title: 'フリーランスたかろーさんにAI顧問契約をいただきました',
    excerpt: '動画編集者としてフリーランスで活動するたかろーさんに、AI顧問契約をいただきました。Claude Codeを用いた動画編集やAI活用で、フリーランスとしての業務を便利にするサポートをしています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
  },
];
---

<Layout
    title="たかろーさん｜クライアントさまの声｜株式会社コールテン"
    description="動画分析時間50%削減・新規案件3件獲得・教育チャンネル始動。フリーランス たかろーさんがAI伴走で実現した変化と、現在進行形の取り組みをご紹介します。"
    canonicalUrl="https://www.corduroy.co.jp/voices/takaro/"
    ogUrl="https://www.corduroy.co.jp/voices/takaro/"
    ogType="profile"
>
    <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
        { "@type": "ListItem", "position": 2, "name": "クライアントさまの声", "item": "https://www.corduroy.co.jp/voices/" },
        { "@type": "ListItem", "position": 3, "name": "たかろーさん" }
      ]
    }
    </script>

    <main>
        <!-- ===== ヒーロー ===== -->
        <section class="hero">
            <div class="container">
                <div class="hero-inner fade-up">
                    <div class="hero-avatar">
                        <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png"
                            alt="たかろーさん">
                    </div>
                    <div class="hero-text">
                        <span class="eyebrow">CLIENT VOICE</span>
                        <h1>たかろーさん</h1>
                        <p class="hero-sub">フリーランス / 動画編集 / WEB制作 / カメラマン</p>
                        <div class="hero-tags">
                            <span class="hero-tag">AI顧問</span>
                            <span class="hero-tag">AI講座</span>
                            <span class="hero-tag">世界の教育チャンネル</span>
                        </div>
                    </div>
                </div>
                <!-- 成果チップ（H1直下の3秒で伝わるサマリー） -->
                <div class="hero-stats fade-up">
                    <div class="stat-chip"><strong>50%</strong><span>動画分析時間 削減</span></div>
                    <div class="stat-chip"><strong>+3件</strong><span>新規案件 獲得</span></div>
                    <div class="stat-chip"><strong>始動</strong><span>世界の教育チャンネル</span></div>
                </div>
            </div>
        </section>

        <!-- ===== Before / After（結論先出し） ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:40px;">
            <div class="article-content">
                <div class="section-head fade-up">
                    <small>Before / After</small>
                    <h2>コールテンでのAI学習による変化</h2>
                    <p>AI講座とAI顧問の伴走を通じて起きた変化を一目で。</p>
                </div>

                <p class="ba-meta fade-up">※ AI講座受講・AI顧問伴走（約1年）での個別事例です。再現を保証するものではありません。</p>
                <div class="before-after fade-up">
                    <div class="ba-card ba-before">
                        <span class="ba-label">Before</span>
                        <ul>
                            <li>ChatGPTを「検索ツール」としてしか使えていない</li>
                            <li>AIの嘘（ハルシネーション）に振り回される</li>
                            <li>業務効率化や新規案件獲得のAI活用法が不明</li>
                            <li>制作スキルはあるが「やりたいこと」に時間を割けない</li>
                        </ul>
                    </div>
                    <div class="ba-arrow" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="13 6 19 12 13 18"/>
                        </svg>
                    </div>
                    <div class="ba-card ba-after">
                        <span class="ba-label">After</span>
                        <ul>
                            <li>価値観・体調のクセまで教え込んだ「第二の自分」を育成</li>
                            <li>動画分析時間を50%削減</li>
                            <li>新規案件を3件獲得</li>
                            <li>仕事のやり方をAIに教え込みルール化する段階へ</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== 本人証言（主役） ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:40px;">
            <div class="testimonial fade-up">
                <div class="testimonial-mark">“</div>
                <p class="testimonial-quote">「第二の自分」は誰とも被らない資産になるし、新しいAIが出てもブレない軸になります。いきなり独学で走るより、コールテンさんみたいにたくさん実践して裏側（仕組み）を知っている人と一緒に、相談できる状態で走るのが一番効率よかったと思います。</p>
                <div class="testimonial-by">
                    <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
                    <div>
                        <p class="testimonial-name">中野たかろーさん</p>
                        <p class="testimonial-role">フリーランス / 動画編集・WEB制作・カメラマン</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== この事例から学べること（共感ブロック・ストーリー前） ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:40px;">
            <div class="learn-block fade-up">
                <span class="learn-eyebrow">この事例が刺さる方</span>
                <h2 class="learn-title">こんな悩みがある方の参考になります</h2>
                <ul class="learn-list">
                    <li><strong>動画クリエイター・フリーランス</strong>として、AIで業務量と仕事の質を両立させたい</li>
                    <li>ChatGPT を検索止まりで使っているが、本当は<strong>「相棒」レベルまで育てたい</strong></li>
                    <li>「やりたいこと」が別領域（教育・支援など）にあり、<strong>本業と両立する道</strong>を探している</li>
                    <li>独学で迷うより、<strong>仕組みを理解した伴走者と一緒に</strong>進めたい</li>
                </ul>
            </div>
        </section>

        <!-- ===== ストーリー（吹き出し付き） ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:60px;">
            <div class="article-content">
                <div class="section-head fade-up">
                    <small>Story</small>
                    <h2>受講前から現在までの伴走</h2>
                </div>

                <!-- 受講前の課題 -->
                <div class="fade-up">
                    <h3>🎯 受講前の課題</h3>
                    <p>
                        フリーランスとして動画編集・WEB制作・カメラマンなど幅広く手がけていたものの、ChatGPTは「検索ツール」止まり。AIの嘘に振り回された経験から、距離を置いていた時期もありました。
                    </p>
                    <div class="dialog">
                        <div class="bubble right">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
                                <span class="name-tag">たかろー</span>
                            </div>
                            <div class="bubble-text">最初は ChatGPT を検索の代わりに使ってる感じで。聞いても適当な答えが返ってきて信用できなくて、一回離れちゃってた時期もあるんです。本当はもっと使いこなしたい気持ちはあったんですけど、入り口が見つからなくて。</div>
                        </div>
                        <div class="bubble">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
                                <span class="name-tag">代表 向</span>
                            </div>
                            <div class="bubble-text">そうでしたね。たかろーさんはAIの嘘に振り回されていた時期がありましたが、もっと使いこなしたい気持ちはずっと持っていらっしゃいました。だからこそ、その入り口を一緒に作りたいと思ったんです。</div>
                        </div>
                    </div>
                </div>

                <!-- AI講座での学び -->
                <div class="fade-up">
                    <h3>💡 AI講座での学び</h3>
                    <p>
                        コールテンのAI講座で、生成AIの仕組み・嘘の見抜き方・価値観や体調のクセまで教え込む「第二の自分」ワークを学習。検索の道具ではなく、対話の相棒としてAIを使い始めるきっかけになりました。
                    </p>
                    <div class="dialog">
                        <div class="bubble right">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
                                <span class="name-tag">たかろー</span>
                            </div>
                            <div class="bubble-text">「第二の自分」のワークで価値観や体調のクセまで教え込んでから、全然違いました。言葉足らずでも「こういうことですよね？」って補ってくれる感覚があって、AIが本当に相棒になった気がします。</div>
                        </div>
                        <div class="bubble">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
                                <span class="name-tag">代表 向</span>
                            </div>
                            <div class="bubble-text">あれを通ってからの変化は早かったですね。検索の道具ではなく、対話の相棒として使えるようになった瞬間は、ご本人もはっきり実感できるはずです。あの感覚に届けられたのが大きかったと思います。</div>
                        </div>
                    </div>
                </div>

                <!-- AI顧問での実践 -->
                <div class="fade-up">
                    <h3>🤝 AI顧問での実践</h3>
                    <p>
                        現在は AI 顧問契約のなかで「世界の教育チャンネル」プロジェクトを共に進行中。Remotion と Claude Code を使った動画編集を学び、素材生成から編集までAIで量産できる体制をつくりつつあります。教育という、本当に興味のある領域で仕事を取りに行ける状態を目指しています。
                    </p>
                    <div class="dialog">
                        <div class="bubble right">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
                                <span class="name-tag">たかろー</span>
                            </div>
                            <div class="bubble-text">今は「世界の教育チャンネル」を作っていて、Remotion と Claude Code で動画編集のスキル化を進めてます。素材から何まで全部AIで作るところまでチャレンジ中で、教育系の興味のある分野で仕事を取っていけるようになりたいです。</div>
                        </div>
                        <div class="bubble">
                            <div class="bubble-avatar">
                                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
                                <span class="name-tag">代表 向</span>
                            </div>
                            <div class="bubble-text">制作で生計を立てつつ、AIで量産化した動画コンテンツで「教育」というやりたい領域に踏み出すフェーズですね。コールテンとしては、その『あいだ』をつなぐサポートを続けていきたいと思っています。</div>
                        </div>
                    </div>
                </div>

                <!-- 今後の展望 -->
                <div class="fade-up">
                    <h3>🚀 今後の展望</h3>
                    <p>
                        制作で生計を立てつつ、AIで量産化した動画コンテンツで「教育」という本当にやりたい領域に踏み出す——その「あいだ」をつなぐのが現在のフェーズです。Remotion・Claude Code で得た動画制作スキルを軸に、教育系の仕事をAIと一緒に取りにいける状態を目指しています。
                    </p>
                </div>
            </div>
        </section>

        <!-- ===== たかろーさんを知る ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:60px;">
            <div class="section-head fade-up" style="text-align:center; max-width:820px; margin:0 auto 24px;">
                <small>About Takaro</small>
                <h2>たかろーさんをもっと知る</h2>
            </div>
            <div class="social-links fade-up">
                <a href="https://x.com/takaro_potter" target="_blank" rel="noopener noreferrer" class="social-card">
                    <span class="social-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21l-6.55 7.49L22 22h-6.78l-4.79-6.27L4.92 22H2.16l7.02-8.02L2 2h6.91l4.32 5.71L18.244 2zm-2.38 18h1.65L8.22 4H6.5l9.36 16z"/></svg>
                    </span>
                    <div class="social-body">
                        <p class="social-platform">X（旧Twitter）</p>
                        <p class="social-handle">@takaro_potter</p>
                    </div>
                </a>
                <a href="https://www.instagram.com/takaro_potter/" target="_blank" rel="noopener noreferrer" class="social-card">
                    <span class="social-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.012 4.85.07 1.17.054 1.81.249 2.23.413.56.218.96.479 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.81-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.81-.25-2.23-.41a3.71 3.71 0 0 1-1.38-.9 3.71 3.71 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.81.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 1.62c-3.14 0-3.51.012-4.74.068-.95.044-1.46.205-1.8.34-.45.18-.78.39-1.12.73-.34.34-.55.67-.73 1.12-.13.34-.3.85-.34 1.8-.06 1.23-.07 1.6-.07 4.74s.01 3.51.07 4.74c.04.95.2 1.46.34 1.8.18.45.39.78.73 1.12.34.34.67.55 1.12.73.34.13.85.3 1.8.34 1.23.06 1.6.07 4.74.07s3.51-.01 4.74-.07c.95-.04 1.46-.2 1.8-.34.45-.18.78-.39 1.12-.73.34-.34.55-.67.73-1.12.13-.34.3-.85.34-1.8.06-1.23.07-1.6.07-4.74s-.01-3.51-.07-4.74c-.04-.95-.2-1.46-.34-1.8-.18-.45-.39-.78-.73-1.12a3.04 3.04 0 0 0-1.12-.73c-.34-.13-.85-.3-1.8-.34-1.23-.06-1.6-.07-4.74-.07zm0 2.76a5.46 5.46 0 1 1 0 10.92 5.46 5.46 0 0 1 0-10.92zm0 1.62a3.84 3.84 0 1 0 0 7.68 3.84 3.84 0 0 0 0-7.68zm5.65-1.81a1.27 1.27 0 1 1 0 2.55 1.27 1.27 0 0 1 0-2.55z"/></svg>
                    </span>
                    <div class="social-body">
                        <p class="social-platform">Instagram</p>
                        <p class="social-handle">@takaro_potter</p>
                    </div>
                </a>
                <!-- TODO: 世界の教育チャンネル 1本目公開時にURLを設定 -->
                <div class="social-card coming-soon" aria-disabled="true">
                    <span class="social-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                    </span>
                    <div class="social-body">
                        <p class="social-platform">世界の教育チャンネル</p>
                        <p class="social-handle">Coming Soon</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== FAQ ===== -->
        <section class="container faq" style="padding-top:20px; padding-bottom:60px;">
            <div class="section-head fade-up" style="text-align:center; max-width:820px; margin:0 auto 32px;">
                <small>FAQ</small>
                <h2>よくあるご質問</h2>
            </div>
            <div class="faq-items fade-up">
                <details open>
                    <summary>たかろーさんのようなフリーランスでも、AI伴走は受けられますか？</summary>
                    <p>はい、フリーランスの方も多く伴走させていただいています。たかろーさんのケースでも、業務効率化と「やりたいこと」（教育チャンネル制作）の両軸でサポートしています。法人・個人問わず、まずは紹介から小さく始める形です。</p>
                </details>
                <details>
                    <summary>動画編集や写真など、クリエイティブな仕事でもAIは活きますか？</summary>
                    <p>むしろ相性が良い領域です。たかろーさんは動画分析時間を50%削減しつつ、撮影・編集の現場感は残す形でAIを使い分けています。「機械に任せる部分」と「人が向き合う部分」を一緒に切り分けるのがコールテンの伴走スタイルです。</p>
                </details>
                <details>
                    <summary>「第二の自分」を育てるにはどれくらい時間がかかりますか？</summary>
                    <p>使い始めて数週間で違いを感じる方が多いです。たかろーさんも、価値観や体調のクセまで教え込むワークを通じて、AIが「言葉足らずでも補完してくれる相棒」に変化していきました。一気に作るのではなく、毎日の対話で少しずつ育てます。</p>
                </details>
                <details>
                    <summary>たかろーさんと違う業種・職種でも成果は出ますか？</summary>
                    <p>はい。たかろーさんの成果（案件獲得・効率化・やりたいこと実現）は、価値観をAIに教える型を実践した結果です。型自体は業種を問わず使えるので、教育・士業・NPO・サービス業・個人クリエイターなど幅広い領域で再現されています。</p>
                </details>
                <details>
                    <summary>「やりたいこと」と「できること」を分けて考える意味は？</summary>
                    <p>多くの方は「できること」（売上を立てる仕事）に時間を取られて、「やりたいこと」が後回しになります。たかろーさんの場合、AIが制作業務の効率化と教育チャンネルの量産を両方支えることで、両者を行き来できるようになりました。AIは「やりたいこと」に時間を割くための装置でもあります。</p>
                </details>
            </div>
        </section>

        <!-- ===== 関連記事 ===== -->
        <section class="container" style="padding-top:20px; padding-bottom:60px;">
            <div class="section-head fade-up" style="text-align:center; max-width:820px; margin:0 auto 32px;">
                <small>Related Articles</small>
                <h2>たかろーさん関連の記事</h2>
            </div>
            <div class="posts-list fade-up">
                {posts.map((post) => (
                    <a href={post.slug} class="post-card">
                        <div class="post-thumb">
                            <img src={post.thumbnail} alt="" width="120" height="120" loading="lazy" />
                        </div>
                        <div class="post-body">
                            <div class="post-meta">
                                <time class="post-date" datetime={post.date}>{post.date}</time>
                                <span class="post-cat">{post.category}</span>
                            </div>
