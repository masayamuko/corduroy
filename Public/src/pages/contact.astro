---
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="ご相談・ご縁づくり｜株式会社コールテン"
    description="コールテンへのご相談はSNSのDMで受付中。紹介・興味領域のテーマは初回無料、有料相談（90分 30,000円）もご用意しています。"
    canonicalUrl="https://www.corduroy.co.jp/contact/"
    ogUrl="https://www.corduroy.co.jp/contact/"
>
    <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "ご相談・ご縁づくり",
      "description": "株式会社コールテンへのお問い合わせページ",
      "url": "https://www.corduroy.co.jp/contact",
      "mainEntity": {
        "@type": "Organization",
        "name": "株式会社コールテン",
        "url": "https://www.corduroy.co.jp/"
      }
    }
    </script>
    <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "ホーム",
          "item": "https://www.corduroy.co.jp/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "お問い合わせ",
          "item": "https://www.corduroy.co.jp/contact"
        }
      ]
    }
    </script>

    <main>
        <section class="hero">
          <div class="container hero-inner">
            <div class="hero-text fade-up">
              <small>CONTACT</small>
              <h1>ご相談・ご縁づくり</h1>
              <p class="hero-lead">数をこなすのではなく、<strong>ご縁を深く育てる</strong>関係性を大切にしています。<br>
              まずはLINEでお気軽にお声がけください。<br>
              お話できるのを楽しみにしています。</p>
            </div>
            <img class="hero-image fade-up"
                 src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777296405/corduroy/services/contact-hero.jpg"
                 alt="温かいカフェでテトとTikiが笑顔で歓迎するイラスト"
                 loading="eager" width="1366" height="768" />
          </div>
        </section>
    
        <!-- 個別相談（単独セクション・白背景） -->
        <section class="pricing-personal-section">
          <div class="container">
            <div class="pricing-personal-card fade-up">
              <img class="pricing-icon"
                   src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777296917/corduroy/services/icon-personal.jpg"
                   alt="湯気と葉とハートのお茶のイラスト" loading="lazy" width="200" height="200" />
              <div class="pricing-personal-text">
                <h3>個別相談</h3>
                <div class="price-main">30,000<span class="yen">円</span> <span class="tax">(税込)</span></div>
                <div class="price-sub">90分 / オンライン</div>
                <p class="price-desc">まずはここから。AI活用の方向性整理、業務改善の可能性、プロンプト設計の初期アドバイスなどを、必要な範囲でしっかりお手伝いします。</p>
              </div>
            </div>
          </div>
        </section>

        <!-- 大切にしていること（フルブリード #fbf9f5）— ご紹介+特定領域はこの中に -->
        <section class="values-section">
          <div class="container values-inner">
            <div class="values-head fade-up">
              <img class="value-mascot"
                   src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/tiki/tiki_bow.png"
                   alt="Tikiがお辞儀で迎えるイラスト"
                   loading="lazy" width="120" height="120" />
              <small>Our Values</small>
              <h2>大切にしていること</h2>
              <p class="values-lead">数をこなすのではなく、<strong>ご縁を深く育てる</strong>関係性を大切にしています。<br>価値観が重なるご縁を特に大切にし、安心して話せる空気と、小さく試せる設計を一緒につくります。</p>
            </div>

            <div class="values-cards fade-up">
              <div class="values-card">
                <img class="pricing-icon"
                     src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777297331/corduroy/services/icon-referral.png"
                     alt="コーラルと緑の輪が繋がるイラスト" loading="lazy" width="180" height="180" />
                <h3>ご紹介の方</h3>
                <div class="price-main">無料<span class="tax-light">／初回 60分</span></div>
                <p class="price-desc">既存のお客様やパートナー様からのご紹介の場合。紹介を通じて価値観が伝わっているご縁を何より大切にし、最初の60分で課題整理を行います。</p>
              </div>
              <div class="values-card">
                <img class="pricing-icon"
                     src="https://res.cloudinary.com/dg3mdcuju/image/upload/f_webp,q_auto:good/v1777297333/corduroy/services/icon-specific.png"
                     alt="ハート中心に多様な要素が広がるイラスト" loading="lazy" width="180" height="180" />
                <h3>特定領域のご相談</h3>
                <div class="price-main">無料<span class="tax-light">／初回 60分</span></div>
                <p class="price-desc">社会的養護、若者支援、教育、福祉、創作活動など。価値観の重なりから初回無料でお受けしています。まずはお気軽にご相談ください。</p>
              </div>
            </div>
          </div>
        </section>
    
        <section id="contact" class="bg-gradient-soft"
          style="background:linear-gradient(180deg, #fbfaf8 0%, #e6f3ed 100%); padding-top:100px;">
          <div class="container">
            <div style="display:flex; flex-direction:column; gap:60px; max-width:800px; margin:0 auto;">
    
              <div class="card fade-up"
                style="background:#fff; padding:40px; border:none; box-shadow:0 20px 60px rgba(0,0,0,.05);">
                <h3 style="margin-bottom:24px;">進め方の目安</h3>
                <div class="flow-list">
                  <div class="flow-item">
                    <div class="flow-num">1</div>
                    <div class="flow-content">
                      <strong>日程調整のご連絡</strong><br>
                      1–2営業日以内に、日程調整のご連絡を差し上げます。
                    </div>
                  </div>
                  <div class="flow-item">
                    <div class="flow-num">2</div>
                    <div class="flow-content">
                      <strong>事前ヒアリング</strong><br>
                      事前に相談内容をご連絡いただけましたら、より当日スムーズにご対応できます。
                    </div>
                  </div>
                  <div class="flow-item">
                    <div class="flow-num">3</div>
                    <div class="flow-content">
                      <strong>相談（対面 or オンライン通話）</strong><br>
                      時間いっぱい何でもご相談に乗ります。可能なものはその場でAIを操作しつつ作業対応も可能です。
                    </div>
                  </div>
                </div>
                <div style="margin-top:32px; text-align:center;">
                  <p class="mini" style="color:#335649; font-size:14px;">無理な営業は一切いたしません。<br>まずはお話できるのを楽しみにしています。</p>
                </div>
              </div>
    
              <div class="fade-up" style="max-width:560px; margin:0 auto; width:100%;">
                <h2 style="margin-bottom:24px;">LINE公式アカウントから<br>ご連絡ください</h2>
                <p style="margin-bottom:32px; line-height:1.8; color:#335649;">
                  現在、お問合せはLINE公式アカウントでお受けしています。<br>営業日２日以内を目安にご返信します。</p>
    
                <div style="display:flex; flex-direction:column; gap:16px;">
                  <a class="btn-line-contact" href="https://lin.ee/aQqPH7S" target="_blank" rel="noopener noreferrer"
                    data-ga-event="line_click" data-ga-label="contact_page_line">
                    <div class="btn-line-icon">LINE</div>
                    <div>
                      <div style="font-weight:700;">LINE公式アカウント</div>
                      <div style="font-size:13px; opacity:.9;">お気軽にお問い合わせください</div>
                    </div>
                    <div style="margin-left:auto;">→</div>
                  </a>
                </div>
    
                <div style="margin-top:32px; padding:24px; background:#fff; border-radius:16px; border:1px solid #eef2f0;">
                  <div style="font-weight:700; color:#124034; margin-bottom:12px;">相談前に共有いただけると嬉しいこと</div>
                  <ul style="margin:0; padding-left:20px; line-height:1.8; color:#335649; font-size:15px;">
                    <li>困っていること・叶えたいこと</li>
                    <li>ご予算や希望期間（ざっくりでOK）</li>
                    <li>社内の合意形成で気になる点</li>
                  </ul>
                </div>
    
                <div
                  style="margin-top:24px; padding:24px; background:#f9fafb; border-radius:16px; border:1px solid #e5e7eb;">
                  <div style="display:flex; align-items:flex-start; gap:12px;">
                    <div style="font-size:24px; flex-shrink:0;">☎️</div>
                    <div>
                      <div style="font-weight:700; color:#124034; margin-bottom:8px;">お電話について</div>
                      <p style="margin:0; line-height:1.8; color:#4b5563; font-size:14px;">
                        申し訳ございませんが、現在<strong style="color:#124034;">お電話でのお問い合わせには対応しておりません</strong>。<br><br>
                        営業電話が大変多いため、お電話にはAI音声で自動応答させていただいております。<br>
                        お客様からのご相談は公式LINEでしっかりとお伺いいたしますので、ぜひLINEからお声がけください。お待ちしております。
                      </p>
                    </div>
                  </div>
                </div>
              </div>
    
            </div>
          </div>
        </section>

        <section class="container faq" style="padding-top:80px; padding-bottom:80px;">
          <div class="section-head fade-up">
            <small>FAQ</small>
            <h2>よくあるご質問</h2>
          </div>
          <div class="faq-items fade-up">
            <details open>
              <summary>相談したら必ず契約しないといけませんか？</summary>
              <p>いいえ、まったくその必要はありません。「まずは話を聞いてみたい」だけでも大歓迎です。無理な営業は一切いたしません。お気軽にご連絡ください。</p>
            </details>
            <details>
              <summary>相談前に準備しておくことはありますか？</summary>
              <p>特別な準備は不要です。ただ、「困っていること」「叶えたいこと」「ご予算感」をざっくりでも共有いただけると、より実りのある時間になります。</p>
            </details>
            <details>
              <summary>オンラインでの相談はできますか？</summary>
              <p>はい、オンライン（Zoom等）で対応可能です。福岡県外の方もお気軽にご相談ください。<a href="/services/advisory">AI顧問</a>も完全オンライン対応しています。</p>
            </details>
            <details>
              <summary>個人でも相談できますか？</summary>
              <p>もちろんです。法人・個人問わずご利用いただけます。創作活動、フリーランス、副業でAIを活かしたい方など、個人の方も多くご相談いただいています。</p>
            </details>
            <details>
              <summary>無料で始められるものはありますか？</summary>
              <p>はい。LINEで受け取れる<a href="/services/">無料動画講座</a>と、対面の<a href="/services/study/trial">体験会</a>（3,000円）をご用意しています。まずは気軽にAIに触れてみてください。</p>
            </details>
            <details>
              <summary>相談後、どのようなサポートがありますか？</summary>
              <p>ご相談内容に応じて、最適なサービスをご案内します。継続的な伴走なら<a href="/services/advisory">AI顧問</a>、体系的に学びたいなら<a href="/services/study/program">3ヶ月プログラム</a>、仲間と一緒に実践するなら<a href="/services/study/community">糸口会</a>など、段階に合った形をご用意しています。</p>
            </details>
            <details>
              <summary>返信までどのくらいかかりますか？</summary>
              <p>営業日2日以内を目安にご返信しています。お急ぎの場合はその旨をLINEメッセージに添えていただけると助かります。</p>
            </details>
          </div>
        </section>
      </main>
</Layout>

<style>
    /* Hero */
    .hero {
      padding: 60px 24px 40px;
      background: linear-gradient(180deg, #fbfaf8 0%, var(--cream) 100%);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      top: -50px;
      right: -50px;
      width: 360px;
      height: 360px;
      background: radial-gradient(circle, rgba(228, 242, 234, 0.6) 0%, rgba(255, 255, 255, 0) 70%);
      z-index: 0;
      pointer-events: none;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      align-items: center;
      gap: 40px;
      min-height: 360px;
    }

    .hero-text { display: flex; flex-direction: column; gap: 18px; }
    .hero-text small {
      color: var(--sea);
      font-weight: 700;
      letter-spacing: 0.18em;
      font-family: "Space Grotesk", sans-serif;
      font-size: 12px;
    }
    .hero-text h1 {
      font-size: 34px;
      line-height: 1.4;
      margin: 0;
      color: var(--ink);
    }

    .hero-lead {
      font-size: 16px;
      line-height: 1.95;
      color: #335649;
      margin: 0;
    }
    .hero-lead strong { color: var(--sea); }

    .hero-image {
      width: 100%;
      height: auto;
      max-width: 640px;
      justify-self: end;
      border-radius: 20px;
      box-shadow: 0 16px 40px rgba(22, 97, 78, 0.12);
    }

    @media (max-width: 768px) {
      .hero { padding: 40px 24px 20px; }
      .hero-inner { grid-template-columns: 1fr; gap: 24px; min-height: auto; }
      .hero-image { order: -1; max-width: 100%; }
      .hero-text h1 { font-size: 26px; }
    }

    /* ============================================================
       個別相談 単独セクション（白背景）
    ============================================================ */
    .pricing-personal-section {
      padding: 60px 24px 50px;
      background: #fff;
    }
    .pricing-personal-card {
      max-width: 880px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 36px;
      align-items: center;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 40px 44px;
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.05);
    }
    .pricing-personal-card .pricing-icon {
      width: 100%;
      max-width: 200px;
      aspect-ratio: 1 / 1;
      object-fit: contain;
      justify-self: center;
    }
    .pricing-personal-text h3 {
      font-size: 24px;
      margin: 0 0 10px;
      color: var(--ink);
    }
    .pricing-personal-text .price-main {
      font-family: 'CraftMincho', serif;
      font-size: 36px;
      font-weight: 700;
      color: var(--ink);
      margin: 4px 0 6px;
    }
    .pricing-personal-text .price-main .yen { font-size: 18px; font-weight: normal; margin-left: 2px; }
    .pricing-personal-text .price-main .tax { font-size: 14px; font-weight: normal; margin-left: 4px; color: var(--text-light); }
    .pricing-personal-text .price-sub {
      font-size: 14px;
      color: var(--sea);
      font-weight: 700;
      margin-bottom: 14px;
    }
    .pricing-personal-text .price-desc {
      font-size: 15px;
      line-height: 1.85;
      color: #335649;
      margin: 0;
    }
    @media (max-width: 768px) {
      .pricing-personal-section { padding: 44px 24px 32px; }
      .pricing-personal-card {
        grid-template-columns: 1fr;
        padding: 32px 24px;
        gap: 16px;
        text-align: center;
      }
      .pricing-personal-text .price-desc { text-align: left; }
    }

    /* ============================================================
       大切にしていること（フルブリード #fbf9f5 単色）
       ご紹介の方+特定領域の方をこの中に内包
    ============================================================ */
    .values-section {
      padding: 80px 24px;
      background: #fbf9f5;
      text-align: center;
    }
    .values-inner {
      max-width: 1000px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 48px;
    }
    .values-head { display: flex; flex-direction: column; align-items: center; gap: 12px; max-width: 720px; }
    .values-section small {
      color: var(--accent);
      font-weight: 700;
      letter-spacing: 0.18em;
      font-family: "Space Grotesk", sans-serif;
      font-size: 11px;
      text-transform: uppercase;
    }
    .values-section h2 {
      font-size: 30px;
      margin: 0;
      color: var(--ink);
    }
    .values-lead {
      font-size: 16px;
      line-height: 1.95;
      color: #335649;
      margin: 8px 0 0;
    }
    .values-lead strong { color: var(--sea); }
    .value-mascot {
      display: block;
      width: 100px;
      height: auto;
      margin: 0 auto 4px;
    }

    .values-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      width: 100%;
    }
    .values-card {
      background: #fbf9f5;
      border: 1px solid #e6dfd2;
      border-radius: 24px;
      padding: 36px 28px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }
    .values-card:hover {
      transform: translateY(-3px);
      border-color: var(--sea);
      box-shadow: 0 10px 28px rgba(22, 97, 78, 0.08);
    }
    .values-card .pricing-icon {
      width: 100%;
      max-width: 160px;
      aspect-ratio: 1 / 1;
      object-fit: contain;
      margin-bottom: 8px;
    }
    .values-card h3 {
      font-size: 20px;
      margin: 8px 0 10px;
      color: var(--ink);
    }
    .values-card .price-main {
      font-family: 'CraftMincho', serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--ink);
      margin: 4px 0 14px;
    }
    .values-card .price-main .tax-light {
      font-size: 14px;
      font-weight: 500;
      color: var(--sea);
      margin-left: 6px;
    }
    .values-card .price-desc {
      font-size: 14px;
      line-height: 1.85;
      color: #335649;
      text-align: left;
      width: 100%;
      margin: 0;
    }
    @media (max-width: 768px) {
      .value-mascot { width: 80px; }
      .values-section { padding: 56px 24px; }
      .values-section h2 { font-size: 24px; }
      .values-cards { grid-template-columns: 1fr; gap: 18px; }
      .values-inner { gap: 36px; }
    }

    /* Cards */
    .card {
      background: #fff;
      border: 1px solid #eef2f0;
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, .02), 0 20px 45px rgba(0, 0, 0, .06);
      transition: .25s transform, .25s box-shadow;
      display: flex;
      flex-direction: column;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, .02), 0 28px 60px rgba(0, 0, 0, .09)
    }

    .price-card {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      height: 100%;
    }

    .price-main {
      font-family: 'CraftMincho', serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--ink);
      margin: 12px 0;
    }

    .price-sub {
      font-size: 14px;
      color: var(--sea);
      font-weight: 700;
      margin-bottom: 16px;
    }

    .price-desc {
      font-size: 15px;
      line-height: 1.75;
      color: #335649;
      text-align: left;
      width: 100%;
    }

    .grid {
      display: grid;
      gap: 24px
    }

    @media(min-width:860px) {
      .grid.cols-2 {
        grid-template-columns: 1fr 1fr
      }
    }

    /* Contact Flow */
    .flow-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 20px;
    }

    .flow-item {
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }

    .flow-num {
      flex-shrink: 0;
      width: 32px;
      height: 32px;
      background: var(--mint);
      color: var(--sea);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-family: 'Space Grotesk';
    }

    .flow-content {
      font-size: 15px;
      line-height: 1.7;
      color: #335649;
      padding-top: 2px;
    }

    .section-head {
      text-align: center;
    }

    .section-head h2 { margin-bottom: 16px; }
    .section-head p { color: var(--text-light); }

    .jp-kanji { font-size: 1em; }
    .jp-hiragana { font-size: 0.7em; }

    /* LINE Button */
    .btn-line-contact {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px;
      background: #06C755;
      color: #fff;
      border-radius: 20px;
      text-decoration: none;
      box-shadow: 0 8px 20px rgba(6, 199, 85, 0.25);
      transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
    }
