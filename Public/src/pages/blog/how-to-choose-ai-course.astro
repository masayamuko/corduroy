const description = "AI講座が増えすぎてどれを選べばいいかわからない方へ。初心者が失敗しないための5つの選び方ポイントを、AI講座を運営する株式会社コールテンがわかりやすく解説します。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/how-to-choose-ai-course/"
  ogUrl="https://www.corduroy.co.jp/blog/how-to-choose-ai-course/"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/how-to-choose-ai-course/#article",
