---
import Layout from '../../layouts/Layout.astro';

const title = "フリーランスたかろーさんにAI顧問契約をいただきました｜株式会社コールテン";
const description = "動画編集者としてフリーランスで活動するたかろーさんに、AI顧問契約をいただきました。Claude Codeを用いた動画編集やAI活用で、フリーランスとしての業務を便利にするサポートをしています。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://corduroy.co.jp/blog/tkr-ai-advisory/"
  ogUrl="https://corduroy.co.jp/blog/tkr-ai-advisory/"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://corduroy.co.jp/blog/tkr-ai-advisory/#article",
    "url": "https://corduroy.co.jp/blog/tkr-ai-advisory/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://corduroy.co.jp/blog/tkr-ai-advisory/"
    },
    "headline": "フリーランスたかろーさんにAI顧問契約をいただきました",
    "datePublished": "2025-12-24",
    "dateModified": "2025-12-24",
    "image": "https://corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://corduroy.co.jp/#organization"
    },
    "description": "動画編集者としてフリーランスで活動するたかろーさんに、AI顧問契約をいただきました。Claude Codeを用いた動画編集やAI活用で、フリーランスとしての業務を便利にするサポートをしています。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "フリーランスたかろーさんにAI顧問契約をいただきました" }
    ]
  }
  </script>

  <main>
    <article class="article">
      <div class="container">
        <nav class="breadcrumb fade-up">
          <a href="/">TOP</a>
          <span>/</span>
          <a href="/blog/">ブログ</a>
          <span>/</span>
          <span>tkr-ai-advisory</span>
        </nav>

        <header class="article-head fade-up">
          <div class="meta">
            <time class="date">2025-12-24</time>
            <span class="cat">活動報告</span>
          </div>
          <h1>フリーランスたかろーさんにAI顧問契約をいただきました</h1>
        </header>

        <section class="article-body fade-up">
          <div class="article-card">
            <p>
              動画編集者としてフリーランスで活動しているたかろーさんに、AI顧問契約をいただきました。
            </p>

            <h2>フリーランスの仕事をAIで便利に</h2>
            <p>
              たかろーさんは動画編集を中心に、写真やWeb制作などフリーランスとして幅広く活動されています。
              Claude Codeを用いた動画編集のワークフロー改善をはじめ、
              日々の業務のさまざまな場面でAIを活用していくためのサポートをさせていただいています。
            </p>
            <p>
              フリーランスの方にとって、AIは単なる効率化のツールではなく、
              自分専用のエージェントを育てて仕事を任せられるパートナーになれる存在です。
              たかろーさんも、そうしたAIとの付き合い方に共感してくださり、
              一緒に取り組んでいくことになりました。
            </p>

            <h2>AI活用の可能性を広げる</h2>
            <p>
              動画制作の現場では、台本の作成、テロップのルール化、素材の選定、
              さらにはプログラムを使った動画の量産まで、AIが関われる領域はたくさんあります。
              たかろーさんと一緒に、一つひとつ試しながら、
              フリーランスとしての働き方をAIでアップデートしていきます。
            </p>
          </div>
        </section>

        <aside class="related-links fade-up" style="max-width:720px; margin:40px auto 0; padding:24px; background:rgba(22,97,78,0.04); border-radius:12px;">
          <p style="font-weight:600; font-size:14px; color:var(--sea); margin-bottom:12px;">関連リンク</p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:8px;">
            <li><a href="/services/advisory/" class="btn secondary" style="font-size:13px; padding:6px 14px;">AI顧問サービス</a></li>
            <li><a href="/voices/takaro/" class="btn secondary" style="font-size:13px; padding:6px 14px;">たかろーさんの声</a></li>
          </ul>
        </aside>

        <div class="article-foot fade-up">
          <a href="/blog/" class="btn secondary">&larr; ブログ一覧に戻る</a>
          <a href="/services/advisory/" class="btn">AI顧問について</a>
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  .article {
    padding: 120px 0 100px;
    background: linear-gradient(180deg, var(--cream) 0%, #f0f7f4 100%);
  }
  .breadcrumb {
    display: flex;
    gap: 8px;
    font-size: 12.5px;
    color: var(--text-light);
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--sea); font-weight: 600; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb span { opacity: 0.5; }

  .article-head {
    max-width: 720px;
    margin: 0 auto 12px;
    text-align: left;
  }
  .meta {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 16px;
  }
  .date {
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }
  .cat {
    display: inline-block;
    background: rgba(22,97,78,0.08);
    color: var(--sea);
    border-radius: 99px;
    padding: 3px 11px;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .article-head h1 {
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.4;
  }

  .article-body {
    max-width: 720px;
    margin: 0 auto;
    line-height: 2.1;
    color: var(--text);
    font-size: 15.5px;
  }
  .article-card {
    background: #fff;
    border-radius: 24px;
    padding: 40px 48px;
    border: 1px solid var(--line);
    box-shadow: 0 4px 20px rgba(5,32,24,0.04);
  }
  .article-body h2 {
    font-size: 22px;
    margin-top: 48px;
    margin-bottom: 16px;
    padding-left: 14px;
    border-left: 4px solid var(--sea);
  }
  .article-body p { margin-bottom: 24px; }
  .article-body a {
    color: var(--sea);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(22,97,78,0.3);
    text-underline-offset: 3px;
  }
  .article-body a:hover {
    text-decoration-color: var(--sea);
  }

  .article-foot {
    max-width: 720px;
    margin: 60px auto 0;
    padding-top: 40px;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  @media (max-width: 640px) {
    .article { padding: 88px 0 60px; }
    .article-body { font-size: 15px; }
    .article-card { padding: 28px 24px; }
    .article-body h2 { font-size: 19px; margin-top: 36px; }
    .article-foot { justify-content: center; }
  }
</style>
