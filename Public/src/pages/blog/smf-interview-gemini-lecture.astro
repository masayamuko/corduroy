---
import Layout from '../../layouts/Layout.astro';

const title = "NPO法人でAI基礎講座をやってみた —— スマイリーフラワーズの共通言語づくり｜株式会社コールテン";
const description = "NPO法人スマイリーフラワーズでGeminiを使ったAI基礎講座を実施。チーム全員が同じ言葉でAIを語れるようになるまでの過程と、NPOでのAI導入の第一歩を紹介します。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/smf-interview-gemini-lecture/"
  ogUrl="https://www.corduroy.co.jp/blog/smf-interview-gemini-lecture/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/smf-interview-gemini-lecture/#article",
    "url": "https://www.corduroy.co.jp/blog/smf-interview-gemini-lecture/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/smf-interview-gemini-lecture/"
    },
    "headline": "NPO法人でAI基礎講座をやってみた —— スマイリーフラワーズの共通言語づくり",
    "datePublished": "2026-03-05",
    "dateModified": "2026-03-05",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Organization",
      "name": "NPO法人国際教育支援機構スマイリーフラワーズ"
    },
    "description": "NPO法人スマイリーフラワーズでGeminiを使ったAI基礎講座を実施。チーム全員が同じ言葉でAIを語れるようになるまでの過程と、NPOでのAI導入の第一歩を紹介します。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "AI基礎講座インタビュー" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "AI基礎講座の内容は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ChatGPT・Claude・Geminiなど主要AIツールの違いと使い分けを学んだ上で、Geminiを使って実際に業務に近いタスクを体験します。叩き台を作ってブラッシュアップする流れを全員で実践し、AIとの対話の基本を身につけます。"
        }
      },
      {
        "@type": "Question",
        "name": "NPOでのAI導入の第一歩は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "まずチーム全員のリテラシーを揃えることが第一歩です。スマイリーフラワーズでは基礎講座を通じて「AIに何ができて何ができないか」を全員が理解することで、導入への不安を解消し、共通の言葉で議論できるようになりました。"
        }
      },
      {
        "@type": "Question",
        "name": "何人から講座は実施できる？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "少人数でも実施可能です。スマイリーフラワーズでも少人数のチームで実施しました。むしろ少人数の方が、一人ひとりの理解度に合わせた進行ができるため効果的です。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png"
              alt="スマイリーフラワーズ"
              onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';"></div>
        </div>
        <h1>NPO法人でAI基礎講座をやってみた<br><span class="h1-sub">スマイリーフラワーズの共通言語づくり</span></h1>
        <div class="result-badges">
          <span class="result-badge">AI基礎講座</span>
          <span class="result-badge">共通言語</span>
          <span class="result-badge">NPO研修</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">研修 / AI導入</span>
        </div>
        <p>
          NPO法人スマイリーフラワーズで、チーム全員を対象にAI基礎講座を実施しました。「AIって結局なんなの？」を解消し、全員が同じ言葉でAIを語れるようになるまでの過程を紹介します。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今回はスマイリーフラワーズのみなさんに、AI講座のことを聞いていくよ。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png"
                alt="スマイリーフラワーズ"
                onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
            <h3 style="margin:2px 0 4px;">スマイリーフラワーズチーム</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              NPO法人国際教育支援機構スマイリーフラワーズのスタッフのみなさん。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">講座担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI基礎講座の企画・講師を担当。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入 -->
        <div class="narrative">
          <p>
            「全員が同じ言葉でAIを語れるようになったのが一番大きい」——講座を終えたスタッフの言葉だった。
          </p>
          <p>
            NPO法人スマイリーフラワーズでは、留学支援・若者育成・国際交流の現場でAIを活用するため、まずチーム全体のリテラシーを揃えることから始めた。Geminiを使ったハンズオン形式の基礎講座。その狙いと成果を聞いた。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== なぜAI講座をやることにしたか ===== -->
          <div class="section-label">なぜAI講座をやることにしたか</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AI講座をやろうと思ったきっかけは？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              一部のスタッフはAIを使い始めていたんですが、「何ができるか」の認識がバラバラで。ある人は「万能ツール」だと思っていて、ある人は「怖いもの」だと感じていて。その温度差を埋めたかったんです。
            </div>
          </div>

          <!-- ===== リテラシーを揃える ===== -->
          <div class="section-label">チーム全員のリテラシーを揃える</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              講座では最初に何をしたの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              まず「AIとは何か」の基本から。ChatGPT、Claude、Geminiの違いや、それぞれの得意分野を教えてもらいました。名前だけ聞いたことがあるけど違いがわからなかった人が多かったので、これだけでも発見がありました。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              なるほど。どのAIを使うかで結果も変わるもんね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              そうなんです。「全部同じでしょ？」と思っていたので、使い分けの基準がわかったのは大きかった。
            </div>
          </div>

          <!-- ===== Geminiで実際にやってみた ===== -->
          <div class="section-label">Geminiで実際にやってみた</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              実際のハンズオンではどんなことをしたの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              Geminiを使って、実際の業務に近いお題をやってみました。たとえばイベントの案内文を作るとか。まずAIに叩き台を出してもらって、それをブラッシュアップしていく流れを体験しました。
            </div>
          </div>

          <!-- ===== 叩き台をブラッシュアップ ===== -->
          <div class="section-label">叩き台を作ってブラッシュアップ</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AIの出力をそのまま使うんじゃなくて、叩き台として使う感じ？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              そうです。最初の出力は70点くらい。でもそこから「もっとカジュアルに」「この情報を追加して」と指示を重ねると、どんどん良くなる。その過程が面白かったし、「指示の出し方が大事」ということが体感できました。
            </div>
          </div>

          <!-- ===== 怖さの解消 ===== -->
          <div class="section-label">怖さの解消</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              講座を受ける前に「怖い」と感じていた人は、どう変わった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              「思ったより普通のツールだった」という声が多かったです。実際に触ってみると、間違えることもあるし、指示が曖昧だとちゃんと迷う。人間っぽいところがあるとわかると、怖さが和らぐんですね。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>講座で最も大きかった変化は、チーム内に「共通言語」ができたことだった。「プロンプト」「ハルシネーション」「叩き台」——こうした言葉を全員が同じ意味で使えるようになった。これは、この先AIを業務に組み込んでいく上での土台になる。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            「全員が同じ言葉でAIを語れるようになったのが<br>一番大きい」
          </blockquote>

          <!-- ===== 情報をMarkdownで整理する意味 ===== -->
          <div class="section-label">情報をMarkdownで整理する意味</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              講座の中で「Markdown」という形式の話も出たって聞いたけど？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              はい。情報を箇条書きや見出しで整理してからAIに渡すと、出力の精度が上がるという話でした。普段の業務メモにも使えるので、AI関係なく役立っています。
            </div>
          </div>

          <!-- ===== これからの展望 ===== -->
          <div class="section-label">これからの展望</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              講座を終えて、これからチームでどうAIを使っていきたい？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png" alt="スマイリーフラワーズ"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">SMFスタッフ</span>
            </div>
            <div class="bubble-text">
              まずは一人ひとりが日常業務で試してみること。メールの下書きとか、会議の議題整理とか、小さいところから。全員が基礎を知っている状態になったので、「こう使ったらうまくいった」を共有しやすくなりました。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              みなさん、ありがとうございました！チームで一緒に学ぶって、やっぱり大事だね。
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 担当コメント -->
    <section class="container" style="padding-top:40px; padding-bottom:40px;">
      <div class="voice-note fade-up" style="max-width:800px; margin:0 auto;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);"
              alt="向">
          <span class="note-name" style="margin:0">担当 向より</span>
        </div>
        AIの講座で一番大事なのは「全員で同じスタートラインに立つ」こと。ツールの使い方を教えるだけでなく、「AIに何ができて何ができないか」をチームで共有することで、その後の導入がスムーズになります。スマイリーフラワーズのみなさんは、講座後すぐに日常業務で試し始めてくれました。
      </div>
    </section>

    <!-- FAQ -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <div class="faq-section fade-up" style="max-width:760px; margin:0 auto;">
        <h2 class="faq-heading">よくある質問</h2>
        <details class="faq-item">
          <summary>AI基礎講座の内容は？</summary>
          <p>ChatGPT・Claude・Geminiなど主要AIツールの違いと使い分けを学んだ上で、Geminiを使って実際に業務に近いタスクを体験します。叩き台を作ってブラッシュアップする流れを全員で実践し、AIとの対話の基本を身につけます。</p>
        </details>
        <details class="faq-item">
          <summary>NPOでのAI導入の第一歩は？</summary>
