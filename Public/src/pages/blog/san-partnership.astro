---
import Layout from '../../layouts/Layout.astro';

const title = "株式会社スデニアルの佐野さんと定期ミーティングを開始しました｜株式会社コールテン";
const description = "2025年12月から株式会社スデニアルの佐野さんと毎週ミーティング。プロマーケター×AI活用で、本当に価値あるものを届けるための協業を模索しています。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/san-partnership/"
  ogUrl="https://www.corduroy.co.jp/blog/san-partnership/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp-san-partnership.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/san-partnership/#article",
    "url": "https://www.corduroy.co.jp/blog/san-partnership/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/san-partnership/"
    },
    "headline": "株式会社スデニアルの佐野さんと定期ミーティングを開始しました",
    "datePublished": "2025-12-01",
    "dateModified": "2025-12-01",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "description": "2025年12月から株式会社スデニアルの佐野さんと毎週ミーティング。プロマーケター×AI活用で、本当に価値あるものを届けるための協業を模索しています。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "株式会社スデニアルの佐野さんと定期ミーティングを開始しました" }
    ]
  }
  </script>

  <main>
    <article class="article">
      <div class="container">
        <nav class="breadcrumb fade-up">
          <a href="/">TOP</a>
          <span>/</span>
          <a href="/blog/">ブログ</a>
          <span>/</span>
          <span>san-partnership</span>
        </nav>

        <header class="article-head fade-up">
          <div class="meta">
            <time class="date">2025-12-01</time>
            <span class="cat">パートナー自慢</span>
          </div>
          <h1>株式会社スデニアルの佐野さんと定期ミーティングを開始しました</h1>
          <p class="article-lead">2025年12月から、プロマーケターである株式会社スデニアルの佐野さんと毎週ミーティングを行っています。マーケティングとAIを掛け合わせた共同サービスの開発や、クライアントへのAI活用提案など、本当に価値あるものを届けるための協業を進めています。</p>
        </header>

        <section class="article-body fade-up">
          <div class="article-card">
            <p>
              2025年12月から、<a href="https://www.sudeniaru.co.jp/" target="_blank" rel="noopener noreferrer">株式会社スデニアル</a>の佐野さんと毎週ミーティングをさせていただいています。
              共同でAI関連のサービスをつくれないか、佐野さんのクライアントさんに提案できるAIサポートの形がないか——
              そんなことを毎週話し合いながら、一緒に練っています。
            </p>

            <h2>プロマーケター × AI</h2>
            <p>
              佐野さんはもともと広告業界で活躍されていたプロのマーケターです。
              マーケティングの大切さを佐野さんから学ばせていただき、
              僕からはAIの可能性や楽しさを共有させていただいています。
            </p>
            <p>
              お互いの核で合っているのは、
              「本当に人にとって大事なものは何か」という問いです。
              表面上の薄っぺらいものやお金稼ぎのためのものではなく、
              本当に価値があるものを届けたい——そういう話をいつもしています。
            </p>

            <h2>ボードゲームとスマイリーフラワーズ</h2>
            <p>
              佐野さんとはお互いボードゲームが好きで仲良くなりました。
              そして、<a href="/blog/smf-partnership/">NPO法人スマイリーフラワーズ</a>という子どもの支援の場で知り合ったのがきっかけです。
              遊びの場と支援の場、その両方で繋がった縁が、
              いまこうしてビジネスの協業に発展しています。
            </p>
            <p>
              これからも毎週のミーティングを重ねながら、
              お互いの強みを活かしたサービスの形を模索していきます。
            </p>
          </div>
        </section>

        <aside class="related-links fade-up" style="max-width:720px; margin:40px auto 0; padding:24px; background:rgba(22,97,78,0.04); border-radius:12px;">
          <p style="font-weight:600; font-size:14px; color:var(--sea); margin-bottom:12px;">関連リンク</p>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; gap:8px;">
            <li><a href="/services/advisory/" class="btn secondary" style="font-size:13px; padding:6px 14px;">AI顧問サービス</a></li>
            <li><a href="/voices/sano/" class="btn secondary" style="font-size:13px; padding:6px 14px;">佐野さんの声</a></li>
          </ul>
        </aside>

        <div class="article-foot fade-up">
          <a href="/blog/" class="btn secondary">&larr; ブログ一覧に戻る</a>
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  .article {
    padding: 120px 0 100px;
    background: linear-gradient(180deg, var(--cream) 0%, #f0f7f4 100%);
  }
  .breadcrumb {
    display: flex;
    gap: 8px;
    font-size: 12.5px;
    color: var(--text-light);
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--sea); font-weight: 600; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb span { opacity: 0.5; }

  .article-head {
    max-width: 720px;
    margin: 0 auto 12px;
    text-align: left;
  }
  .meta {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 16px;
  }
  .date {
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }
  .cat {
    display: inline-block;
    background: rgba(22,97,78,0.08);
    color: var(--sea);
    border-radius: 99px;
    padding: 3px 11px;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .article-head h1 {
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.4;
  }
  .article-lead {
    font-size: 17px;
    line-height: 1.8;
    color: #555;
    margin-bottom: 32px;
    padding-left: 16px;
    border-left: 3px solid var(--accent, #d4a04d);
  }

  .article-body {
    max-width: 720px;
    margin: 0 auto;
    line-height: 2.1;
    color: var(--text);
    font-size: 15.5px;
  }
  .article-card {
    background: #fff;
    border-radius: 24px;
    padding: 40px 48px;
    border: 1px solid var(--line);
    box-shadow: 0 4px 20px rgba(5,32,24,0.04);
  }
  .article-body h2 {
    font-size: 22px;
    margin-top: 48px;
    margin-bottom: 16px;
    padding-left: 14px;
    border-left: 4px solid var(--sea);
  }
  .article-body p { margin-bottom: 24px; }
  .article-body a {
    color: var(--sea);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: rgba(22,97,78,0.3);
    text-underline-offset: 3px;
  }
  .article-body a:hover {
    text-decoration-color: var(--sea);
  }

  .article-foot {
    max-width: 720px;
    margin: 60px auto 0;
    padding-top: 40px;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  @media (max-width: 640px) {
    .article { padding: 88px 0 60px; }
    .article-body { font-size: 15px; }
    .article-card { padding: 28px 24px; }
    .article-body h2 { font-size: 19px; margin-top: 36px; }
    .article-foot { justify-content: center; }
  }
</style>
