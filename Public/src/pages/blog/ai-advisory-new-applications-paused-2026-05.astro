---
import Layout from '../../layouts/Layout.astro';

const isPublished = false;  // 公開時に true に変更（注: この記事は SEO 狙いではない「お知らせ」のため、isPublished=true にしても noindex は維持する）

const title = "【お知らせ】新規ご相談のお申し込み 一時停止｜株式会社コールテン";
const description = "コールテンの新規ご相談のお申し込みを2026年5月時点で一時停止しています。既存クライアントさんとの伴走・継続中のご相談・契約の更新・追加業務は、これまでどおり継続してサポートします。最初の数ヶ月はヒアリングと現場でのすり合わせに時間を使う仕事のため、いまいる方々への価値提供を優先する判断です。再開時は公式LINEで先にお知らせします。";
const canonicalUrl = "https://www.corduroy.co.jp/blog/ai-advisory-new-applications-paused-2026-05/";
const publishedAt = "2026-05-14";
const modifiedAt = "2026-05-14";

const faqItems = [
  {
    question: "新規お申し込みの再開は、いつごろの予定ですか？",
    answer: "明確な再開日は決めていません。直近で新しくお迎えしたクライアントさんたちの「初期段階」（クライアント理解・環境理解・設計）が落ち着いてきたタイミングで、状況を見ながら判断していきます。コールテンは代表ひとりが直接深く関わる伴走スタイルのため、同時に進められる新規立ち上げの数に上限があります。再開判断は無理のないペースで行い、再開時は公式LINEに登録いただいている方へ、サイトの告知より先にお伝えします。"
  },
  {
    question: "既存クライアントさんの紹介経由でも、待ちの枠はないですか？",
    answer: "原則として、紹介経由でも新規受付は一時停止しています。ただ、紹介でお話いただいたケースは個別に状況を伺ったうえで、後日のご案内枠に入れていただける場合があります。すぐ着手は難しい前提で、まずは公式LINEから状況をお聞かせいただけるとうれしいです。"
  },
  {
    question: "スポットの相談（単発）だけお願いするのもダメですか？",
    answer: "新規ご相談は基本的に一時停止していますが、すでにつながりのある方からの単発相談・1回の壁打ち・社内勉強会の講師などは、状況に応じて個別にご相談を受けることがあります。ご相談内容と希望時期を公式LINEからお知らせいただけると、対応可否をお返事します。確約はできない前提でお問い合わせください。"
  },
  {
    question: "AI講座やAIサイトリニューアルも止まっていますか？",
    answer: "新規のご相談・お申し込みについては、サービス全般を一時停止しています。AI顧問だけでなく、AI講座（3ヶ月プログラム／法人研修）と、AI時代のサイトリニューアルの新規ご相談も同様にお休みさせていただいています。ただし、すでに公開している無料動画講座のように、お申し込み不要で触れていただけるコンテンツについては、これまで通り公開を続けています。再開時はサービスごとに公式LINEで先にご案内します。"
  },
  {
    question: "いま契約している分の更新や、追加業務には影響ありますか？",
    answer: "影響ありません。既存クライアントさんの契約継続・更新・追加業務・スコープ調整は、これまでどおり個別にお話してご対応します。コールテンの今回の判断は「これから新しく契約をご検討いただく方の受け入れ」を止めるものです。"
  },
  {
    question: "公式LINEに登録すると、何が届きますか？",
    answer: "AI顧問の新規受付再開のお知らせを、サイト告知より先にお届けします。それ以外にも、コールテンが実際にどんな伴走をしているかの事例や、ふだんの業務に取り入れやすいAI活用の小さなTIPS、講座やイベントの先行案内などを月に数本のペースでお送りしています。配信頻度はそこまで多くないので、安心して登録してください。"
  }
];

const blogPosting = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  "url": canonicalUrl,
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
  "headline": "【お知らせ】新規ご相談のお申し込み 一時停止",
  "datePublished": publishedAt,
  "dateModified": modifiedAt,
  "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
  "author": { "@id": "https://www.corduroy.co.jp/members/masaya/#person" },
  "publisher": { "@id": "https://www.corduroy.co.jp/#organization" },
  "description": description,
  "keywords": ["AI顧問", "AIコモン", "新規受付停止", "コールテン", "AI伴走", "中小企業AI活用", "クライアント立ち上げ"]
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
    { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
    { "@type": "ListItem", "position": 3, "name": "新規ご相談のお申し込み 一時停止" }
  ]
};

const faqPage = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": `${canonicalUrl}#faq`,
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
};
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogUrl={canonicalUrl}
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  {/* この記事は時限的な「お知らせ」のため、公開後も noindex,nofollow を維持する。
     再開後は記事自体を残しつつ検索結果には出さない方針。
     ※ Masaya方針: SEO狙い記事の noindex は禁止だが、SEO狙いではない一時的お知らせは例外。 */}
  <meta slot="head" name="robots" content="noindex,nofollow" />
  {isPublished && (
    <Fragment slot="head">
      <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": [blogPosting, breadcrumb, faqPage] })} />
    </Fragment>
  )}

  <main>
    <article class="article">
      <div class="container">
        <nav class="breadcrumb fade-up">
          <a href="/">TOP</a>
          <span>/</span>
          <a href="/blog/">ブログ</a>
          <span>/</span>
          <span>ai-advisory-new-applications-paused-2026-05</span>
        </nav>

        <header class="article-head fade-up">
          <div class="meta">
            <time class="date">2026-05-14</time>
            <span class="cat">お知らせ</span>
          </div>
          <h1>【お知らせ】新規ご相談のお申し込み 一時停止</h1>
          <p class="article-lead">いつも株式会社コールテンを応援してくださり、ありがとうございます。本日は1点、サービス提供についてのお知らせです。<br><br>コールテンへの <strong>新規ご相談のお申し込みを、2026年5月時点で一時的に停止</strong>させていただいています。<br><br>はじめに大切なことをお伝えします。<strong>既存クライアントさんとの伴走、いまご相談いただいている案件、契約の継続・更新・追加業務、スコープの調整は、これまでどおり継続してサポートしていきます。</strong>定例ミーティングや日々のやり取り（Slack・LINE・メール）も、これまでどおり変わりません。「もう依頼できないのかな…」と心配された方、どうぞご安心ください。<br><br>今回お知らせするのは、あくまで <strong>「これから新規でご相談・ご契約をご検討いただく方の受け入れ」を一時的に止める</strong>、という話です。直近で新しくお迎えしたクライアントさんが続いており、その方たちと過ごす <strong>最初の数ヶ月のコミュニケーション</strong> に、ぼくの時間と頭を集中させるための判断です。<br><br>新規受付の再開時は、公式LINEに登録いただいているみなさまへ <strong>サイトの告知より先にお知らせ</strong>します。</p>
        </header>

        <section class="article-body fade-up">
          <div class="article-card">
            <h2>なぜ、いま新規受付を止めているのか</h2>
            <p>ありがたいことに、ここ最近のコールテンには、新規でAI顧問を導入いただくクライアントさんが続けてお越しくださっています。問い合わせ・紹介・既存クライアントさんからのご紹介と、入り口はさまざまですが、お声がけいただいた一社一社、本当に感謝しています。</p>
            <p>そのうえで、AI顧問は <strong>「契約してから最初の数ヶ月」の作り込み</strong>が、後の伴走の質を大きく左右する仕事です。ここを薄めて並列で進めてしまうと、「とりあえずAIっぽい話はしているけれど、現場に効いている感覚がない」という空気が漂いはじめます。それは、いま新しくコールテンを選んでくださった方への向き合い方として、ぼくたちのなかでどうしても許容できませんでした。</p>
            <p>結果として、<strong>「新規受付を一時的に止める」ことが、いま契約してくださっている方々に対して、いちばん誠実な選択</strong>だと考えてこの判断にいたりました。</p>

            <h2>コールテンが「初期段階」で実際にやっていること</h2>
            <p>「初期段階の作り込み」と書きましたが、具体的にどんなところに時間と頭を使っているのかを、できるだけ正直に書いておきます。コールテンが普段どんな仕事をしているか、中身を見ていただく機会にもなるかと思います。</p>
            <p>一言でいうと、コールテンが最初の数ヶ月にやっているのは、<strong>AIの話を進める前に、まず「人」を深く知ろうとすること</strong>です。AIの設計よりも先に、その方が普段どんな現場で、どんな仲間と、どんな言葉で仕事をしているかを、じっくり見せてもらいます。</p>
            <h3>1. 何時間もヒアリングして、価値観をすり合わせる</h3>
            <p>本当に何時間も、お話を聞かせていただきます。事業の歴史、いまの困りごと、現場で起きている感情の動き、これまで挑戦してうまくいかなかったこと、組織のなかで大事にしている言葉。AI設計の手前で、この <strong>「言葉と価値観のすり合わせ」</strong> が決まっていないと、その後に組むものが全部ずれていきます。</p>
            <p>同時に、社内ですでにある資料・議事録・サイト・SNSの過去投稿を、人間とAIエージェントの両方で読み込みます。「会社のこれまでの蓄積を、AIに正しく引き継ぐ」ための土台づくりです。</p>
            <h3>2. できる限り現場に入らせてもらう</h3>
            <p>可能な範囲で、実際の業務現場に同席させていただきます。会議に入る、店舗に立つ、教室の後ろで見学する、現場スタッフさんの一日に同行する。やり方はクライアントさんごとに違いますが、<strong>「ヒアリングだけだと出てこなかった大事なこと」が、現場に入ると見えてくる</strong>のは毎回そうです。</p>
            <p>誰がどんな表情で、どんな道具を使って、どんな順番で動いているのか。それをぼくの目で見ることが、何よりの設計材料になります。ここに丁寧に時間をかけられるかどうかで、最終的な設計とご案内の質が大きく変わります。</p>
            <h3>3. すり合わせを重ねて、設計とご案内に落としていく</h3>
            <p>ヒアリングと現場で得たものを、AIエージェントの設計・業務フロー設計・実際の運用ご案内に落としていきます。一度で決まることはなくて、「あ、いま少し違いますね」「もう一度聞かせてください」を何度も繰り返しながら作っていきます。コールテンでは <a href="/blog/general-second-self-guide/">「第二の自分」</a> として AI を育てる前提なので、立ち上がりの設計品質がそのまま中長期の運用品質に効いてきます。</p>
            <h3>つまり、最初の数ヶ月は徹底的に「人」が前面に出る仕事</h3>
            <p>ここがコールテンが他の AI 導入支援と一番違うところかもしれません。AIの話を先に進めず、まず <strong>コミュニケーションと人間関係を丁寧に作る</strong>。クライアントさんの言葉を、ぼくが借りてもいい関係になってから、はじめて設計を始める。そのぶん、ぼくの時間と頭の容量を結構持っていく工程でもあります。</p>
            <p>だからこそ、いま新しく契約してくださったクライアントさん、そしてすでにご相談をいただいている方々への価値提供を、いったんしっかり頑張りたい。新規ご相談の一時停止は、その判断です。</p>

            <h2>既存クライアントさんと、継続中のご相談には影響しません</h2>
            <p>大事なことなので、もう一度書きます。今回の停止は、あくまで <strong>「これから新規でご相談・ご契約をご検討いただく方の受け入れ」</strong> を一時的に止めるものです。以下のものには影響しません。</p>
            <ul>
              <li>既存のクライアントさんへの伴走（定例MTG・日々のSlack・LINE・メールでのご相談対応）</li>
              <li>すでに動き始めているプロジェクト・実装・現場同行</li>
              <li>既存契約の継続・更新・追加スコープのご相談</li>
              <li>過去にご相談をいただき、現在対応中の案件</li>
            </ul>
            <p>これまでどおり、責任を持って続けていきます。「自分のところはどうなる？」と思われた方は、いつもの連絡手段（Slack・LINE・メール）でそのまま聞いてください。これまでと変わらず、すぐにお返事します。</p>

            <h2>再開のお知らせは、公式LINEから先にお届けします</h2>
            <p>新規お申し込みの再開時期は、いま伴走している新規クライアントさんたちの初期段階が落ち着いてきたタイミングを目安に判断します。具体的な再開日が決まったら、まず <strong>公式LINEに登録いただいているみなさまへ、サイトでの告知より先にご案内</strong>します。</p>
            <p>「再開したらAI顧問を相談したい」「枠が空いたタイミングで話を聞きたい」という方は、いまのうちに公式LINEへ登録いただくのが、いちばん早い受け取り方になります。LINEでは、再開のお知らせのほかにも、コールテンが実際にどんな伴走をしているかの事例や、AI活用の入口になる小さなTIPS、講座・イベントの先行案内などをお届けしています。配信頻度は月に数本程度なので、ご安心ください。</p>

            <div class="contact-cta-box fade-up">
              <p class="contact-cta-lead">AI顧問の新規受付が再開したら、まずはLINEでお知らせします。気になっていた方は、ぜひこの機会にご登録ください。</p>
              <a class="btn-line-contact" href="https://lin.ee/aQqPH7S" target="_blank" rel="noopener noreferrer">
                公式LINEに登録する
              </a>
            </div>

            <h2>このお知らせのまとめ</h2>
            <ul>
              <li>2026年5月時点で、<strong>コールテンへの新規ご相談のお申し込みを一時停止</strong>しています。</li>
              <li>理由は、コールテンの仕事が <strong>最初の数ヶ月をコミュニケーションと人間関係に時間を割く</strong>性質のもので、いま新しくお迎えしているクライアントさん・ご相談中の方への価値提供に集中したいためです。</li>
              <li>既存のクライアントさん・継続中のご相談・契約更新には <strong>影響ありません</strong>。これまでどおりご相談ください。</li>
              <li>再開のお知らせは、<strong>公式LINE登録者の方へ、サイトより先に</strong>お届けします。</li>
            </ul>
            <p>「コールテンって普段どんな仕事をしているの？」を知りたい方は、ブログの <a href="/blog/?cat=パートナー自慢">パートナー自慢</a> や <a href="/blog/?cat=インタビュー">インタビュー</a> もぜひ覗いてみてください。AI顧問の現場感が、少しでも伝わるとうれしいです。</p>
          </div>
        </section>

        <section id="faq" class="container faq" style="padding-bottom:40px;">
          <div class="section-head fade-up">
            <small>FAQ</small>
            <h2>よくあるご質問</h2>
          </div>
          <p class="fade-up" style="text-align:center; max-width:640px; margin:0 auto 24px;">新規受付の一時停止について、お問い合わせいただきそうな項目をまとめました。気になるところから読んでください。</p>
          <div class="faq-items fade-up">
            <details open id="faq-1">
              <summary>新規お申し込みの再開は、いつごろの予定ですか？</summary>
              <p class="mini">明確な再開日は決めていません。直近で新しくお迎えしたクライアントさんたちの「初期段階」（クライアント理解・環境理解・設計）が落ち着いてきたタイミングで、状況を見ながら判断していきます。コールテンは代表ひとりが直接深く関わる伴走スタイルのため、同時に進められる新規立ち上げの数に上限があります。再開判断は無理のないペースで行い、再開時は公式LINEに登録いただいている方へ、サイトの告知より先にお伝えします。</p>
            </details>
            <details id="faq-2">
              <summary>既存クライアントさんの紹介経由でも、待ちの枠はないですか？</summary>
              <p class="mini">原則として、紹介経由でも新規受付は一時停止しています。ただ、紹介でお話いただいたケースは個別に状況を伺ったうえで、後日のご案内枠に入れていただける場合があります。すぐ着手は難しい前提で、まずは公式LINEから状況をお聞かせいただけるとうれしいです。</p>
            </details>
            <details id="faq-3">
              <summary>スポットの相談（単発）だけお願いするのもダメですか？</summary>
              <p class="mini">新規ご相談は基本的に一時停止していますが、すでにつながりのある方からの単発相談・1回の壁打ち・社内勉強会の講師などは、状況に応じて個別にご相談を受けることがあります。ご相談内容と希望時期を公式LINEからお知らせいただけると、対応可否をお返事します。確約はできない前提でお問い合わせください。</p>
            </details>
            <details id="faq-4">
              <summary>AI講座やAIサイトリニューアルも止まっていますか？</summary>
              <p class="mini">新規のご相談・お申し込みについては、サービス全般を一時停止しています。AI顧問だけでなく、AI講座（3ヶ月プログラム／法人研修）と、AI時代のサイトリニューアルの新規ご相談も同様にお休みさせていただいています。ただし、すでに公開している無料動画講座のように、お申し込み不要で触れていただけるコンテンツについては、これまで通り公開を続けています。再開時はサービスごとに公式LINEで先にご案内します。</p>
            </details>
            <details id="faq-5">
              <summary>いま契約している分の更新や、追加業務には影響ありますか？</summary>
              <p class="mini">影響ありません。既存クライアントさんの契約継続・更新・追加業務・スコープ調整は、これまでどおり個別にお話してご対応します。コールテンの今回の判断は「これから新しく契約をご検討いただく方の受け入れ」を止めるものです。</p>
            </details>
            <details id="faq-6">
              <summary>公式LINEに登録すると、何が届きますか？</summary>
              <p class="mini">AI顧問の新規受付再開のお知らせを、サイト告知より先にお届けします。それ以外にも、コールテンが実際にどんな伴走をしているかの事例や、ふだんの業務に取り入れやすいAI活用の小さなTIPS、講座やイベントの先行案内などを月に数本のペースでお送りしています。配信頻度はそこまで多くないので、安心して登録してください。</p>
            </details>
          </div>
        </section>

        <div class="contact-cta-box fade-up" style="margin-top: 48px;">
