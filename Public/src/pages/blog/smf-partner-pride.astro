        </aside>

        <div class="article-foot fade-up">
          <a href="/blog/" class="btn secondary">&larr; ブログ一覧に戻る</a>
          <a href="/blog/smf-partnership/" class="btn">SMFとの契約について</a>
        </div>
      </div>
    </article>
  </main>
</Layout>

