                  </tr>
                  <tr>
                    <td>Style-Bert-VITS2</td>
                    <td>無料（OSS）+ Colab Pro $10</td>
                    <td>OSSライセンス準拠</td>
                    <td>高</td>
                    <td>5〜30分</td>
