---
import Layout from '../../layouts/Layout.astro';

const title = "「置いていかれたくなかった」—— スマイリーフラワーズ窪田さんのAI顧問活用ストーリー｜株式会社コールテン";
const description = "NPO法人スマイリーフラワーズの窪田さんに、AI顧問導入のきっかけと変化を聞きました。業務理解に基づく提案で、ITに追われることなくDXを進められるようになったストーリー。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/smf-interview-kubota/"
  ogUrl="https://www.corduroy.co.jp/blog/smf-interview-kubota/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/smf-interview-kubota/#article",
    "url": "https://www.corduroy.co.jp/blog/smf-interview-kubota/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/smf-interview-kubota/"
    },
    "headline": "「置いていかれたくなかった」—— スマイリーフラワーズ窪田さんのAI顧問活用ストーリー",
    "datePublished": "2026-04-23",
    "dateModified": "2026-04-23",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Organization",
      "name": "NPO法人スマイリーフラワーズ"
    },
    "description": "NPO法人スマイリーフラワーズの窪田さんに、AI顧問導入のきっかけと変化を聞きました。業務理解に基づく提案で、ITに追われることなくDXを進められるようになったストーリー。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "窪田さんインタビュー" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "NPOにAI顧問は必要？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "人も予算も限られるNPOだからこそ、ツール選定の「ムダ」が大きな痛手になります。業務を理解した専門家が適切なタイミングで提案してくれることで、導入コストとミスマッチを最小限に抑えられます。"
        }
      },
      {
        "@type": "Question",
        "name": "AI顧問はどんなサポートをしてくれる？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "窪田さんの場合、業務フローの理解→最適なツール選定→一緒に試しながら導入→定着までの一連をサポートしています。「導入して終わり」ではなく、使いこなすところまで伴走します。"
        }
      },
      {
        "@type": "Question",
        "name": "ITに詳しくなくてもAI顧問を活用できる？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "むしろ「詳しくない」方にこそ価値があります。窪田さんも「最新ツールを追いきれない」という不安からスタートしましたが、業務理解に基づく提案により、ストレスなくDXを進められています。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png"
              alt="窪田さん"></div>
        </div>
        <h1>「置いていかれたくなかった」<br><span class="h1-sub">スマイリーフラワーズ窪田さんのAI顧問活用ストーリー</span></h1>
        <div class="result-badges">
          <span class="result-badge">導入のムダ削減</span>
          <span class="result-badge">DX推進中</span>
          <span class="result-badge">AI顧問継続</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">留学支援 / 社会的養護</span>
        </div>
        <p>
          NPOとして子どもたちの留学を支援するスマイリーフラワーズ。代表の窪田さんは「最新のIT/AIツールを追いきれない」不安を抱えていた。業務を理解した上でのAI顧問導入が、現場をどう変えたのかを聞きました。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>ここからはボクが、窪田さんに話を聞いていくね。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png"
                alt="窪田さん">
            <h3 style="margin:2px 0 4px;">窪田さん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              NPO法人スマイリーフラワーズ代表。留学支援と社会的養護の子どもたちの支援に取り組む。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として伴走サポートを担当しました。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入: in medias res -->
        <div class="narrative">
          <p>
            「置いていかれたくなかったんです」—— 窪田さんの言葉には、NPO運営者としてのリアルな焦りがにじんでいた。
          </p>
          <p>
            スマイリーフラワーズは、社会的養護の子どもたちを留学に送り出すために生まれたNPO。子どもたちの未来を開く仕事に向き合いながら、次々に現れるIT/AIツールの波にどう乗ればいいのか——その葛藤は小さくなかった。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== 「最新ツールに追いつけない」という不安 ===== -->
          <div class="section-label">「最新ツールに追いつけない」という不安</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              スマイリーフラワーズさんは留学支援のNPO。AIとは縁遠そうだけど、どうしてAI顧問を？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png" alt="窪田さん">
              <span class="name-tag">窪田さん</span>
            </div>
            <div class="bubble-text">
              最新のITツールがどんどん出てくるけど、追いきれないんです。何を導入すべきか、タイミングもわからなくて。ズレたツールを入れてしまうのが怖かった。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「ズレる」ってどういうこと？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png" alt="窪田さん">
              <span class="name-tag">窪田さん</span>
            </div>
            <div class="bubble-text">
              たとえば「みんなSlack使ってるから」で入れても、うちの業務に合わなかったら意味がないですよね。NPOは人も予算も限られるので、導入のムダが一番痛い。
            </div>
          </div>

          <!-- ===== 業務を理解した上での提案 ===== -->
          <div class="section-label">業務を理解した上での提案</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AI顧問を入れてみて、何が変わった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png" alt="窪田さん">
              <span class="name-tag">窪田さん</span>
            </div>
            <div class="bubble-text">
              一番大きいのは「業務を理解した上で提案してもらえる」こと。うちの仕事の流れをわかった上で、ピッタリなツールを、適切なタイミングで提案してくれる。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「適切なタイミング」って大事なの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png" alt="窪田さん">
              <span class="name-tag">窪田さん</span>
            </div>
            <div class="bubble-text">
              すごく大事です。忙しいときに新しいツールを入れても混乱するだけ。タイミングを見てもらえるから、置いていかれずに済んでいます。
            </div>
          </div>

          <!-- ===== 現場への波及 ===== -->
          <div class="section-label">現場への波及</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              具体的にはどんなツールを入れた？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png" alt="窪田さん">
              <span class="name-tag">窪田さん</span>
            </div>
            <div class="bubble-text">
              その場で一緒に試しながら導入するスタイルなので、手間が大きく減りました。「導入して終わり」じゃなくて、使いこなすところまで一緒にやってくれる。
            </div>
          </div>

          <!-- ナラティブ挿入: 背景の深掘り -->
          <div class="narrative-inline">
            <p>窪田さんが繰り返し言ったのは「ミスマッチの少なさ」だった。NPOの現場は一般企業とは違う。予算も人手も限られる中で、「合わないツール」を試す余裕はない。だからこそ、業務を深く理解した上での提案が効いている。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            業務を理解したうえでピッタリなツールを<br>適切なタイミングで提案してくれるので、<br>置いていかれずに済んでいます。
          </blockquote>

          <!-- ===== まとめ ===== -->
          <div class="section-label">AI顧問を検討している方へ</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              最後に、同じように「ITに追いつけない」と感じている人に一言あれば。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/kubota_smileyflowers.png" alt="窪田さん">
              <span class="name-tag">窪田さん</span>
            </div>
            <div class="bubble-text">
              一人で追いかけなくていいんだなって思えたのが一番大きいです。業務をわかってくれている人が隣にいてくれるだけで、安心して前に進める。自分たちの本業に集中できるようになりました。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              窪田さん、ありがとうございました！子どもたちの留学支援、これからも応援してるよ。
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 担当コメント -->
    <section class="container" style="padding-top:40px; padding-bottom:40px;">
      <div class="voice-note fade-up" style="max-width:800px; margin:0 auto;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);"
              alt="向">
          <span class="note-name" style="margin:0">担当 向より</span>
        </div>
        窪田さんと出会ったのは、スマイリーフラワーズの活動を知ったことがきっかけ。社会的養護の子どもたちを留学に送り出すという志に、純粋に心を動かされました。AI顧問として関わるなかで大事にしているのは、NPOの業務フローを理解してから提案すること。「最新だから」ではなく「窪田さんの現場に合うから」選ぶ。その姿勢は変えたくないです。
      </div>
    </section>

    <!-- FAQ -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <div class="faq-section fade-up" style="max-width:760px; margin:0 auto;">
        <h2 class="faq-heading">よくある質問</h2>
        <details class="faq-item">
          <summary>NPOにAI顧問は必要？</summary>
          <p>人も予算も限られるNPOだからこそ、ツール選定の「ムダ」が大きな痛手になります。業務を理解した専門家が適切なタイミングで提案してくれることで、導入コストとミスマッチを最小限に抑えられます。</p>
        </details>
        <details class="faq-item">
          <summary>AI顧問はどんなサポートをしてくれる？</summary>
          <p>窪田さんの場合、業務フローの理解→最適なツール選定→一緒に試しながら導入→定着までの一連をサポートしています。「導入して終わり」ではなく、使いこなすところまで伴走します。</p>
        </details>
        <details class="faq-item">
          <summary>ITに詳しくなくてもAI顧問を活用できる？</summary>
          <p>むしろ「詳しくない」方にこそ価値があります。窪田さんも「最新ツールを追いきれない」という不安からスタートしましたが、業務理解に基づく提案により、ストレスなくDXを進められています。</p>
        </details>
      </div>
    </section>

    <!-- 関連リンク -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <aside class="related-links fade-up" style="max-width:720px; margin:0 auto; padding:24px; background:rgba(22,97,78,0.04); border-radius:12px;">
        <p style="font-weight:600; font-size:14px; color:var(--sea); margin-bottom:12px;">関連コンテンツ</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
          <li><a href="/blog/smf-partner-pride/" style="font-size:13px; color:var(--sea);">スマイリーフラワーズを本気で応援する理由 →</a></li>
          <li><a href="/clients/smf/" style="font-size:13px; color:var(--sea);">スマイリーフラワーズさんの記事一覧 →</a></li>
          <li><a href="/services/advisory/" style="font-size:13px; color:var(--sea);">AI顧問サービスについて →</a></li>
        </ul>
      </aside>
    </section>

    <!-- CTA -->
    <section id="contact" class="container" style="padding-top:0; padding-bottom:100px;">
      <div class="card cta-card fade-up" style="max-width:720px;margin:0 auto;text-align:center">
        <h3>NPOの「本業に集中できる環境」をつくる</h3>
        <p class="mini" style="line-height:1.8;margin-top:12px;color:var(--text-light);">
          コールテンは、業務を理解した上で最適なツールを適切なタイミングで提案します。<br>
          「ITに追いつけない」不安を、安心に変えるサポートを。
        </p>
        <p class="mini" style="line-height:1.8;margin-top:14px;color:var(--text-light);">このケースで中心になっているのは<strong>AI顧問サービス</strong>です。NPO・一人法人の業務に寄り添った個別設計が強みです。</p>
        <div style="margin-top:16px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap; align-items:center;">
          <a class="btn" href="/services/advisory/">AI顧問サービスの詳細</a>
          <a class="btn secondary" href="/blog/">ブログ一覧に戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
    /* Hero */
    .hero {
        padding: 160px 0 32px;
        text-align: center;
        background: transparent;
    }
    .intro-section {
        padding-top: 0;
        margin-top: 0;
    }
    .hero-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        max-width: 800px;
        margin: 0 auto;
    }
    .h1-sub {
        font-size: clamp(18px, 2.5vw, 24px);
        font-weight: 600;
        display: block;
        margin-top: 8px;
        color: var(--text-light);
    }
    .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: center;
        justify-content: center;
        margin-top: 24px;
    }
    .tag {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 100px;
        background: var(--mint);
        color: var(--sea);
        font-weight: 700;
        font-size: 13px;
        border: 1px solid var(--line);
    }
    .pill {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 100px;
        background: #fff;
        border: 1px solid var(--line);
        font-weight: 700;
        font-size: 13px;
        color: var(--text-light);
    }
    .avatar-frame {
        width: 160px;
        height: 160px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: url('https://res.cloudinary.com/dg3mdcuju/image/upload/v1764661828/%E3%83%95%E3%83%AC%E3%83%BC%E3%83%A0_kyyx9d.png') center/contain no-repeat;
    }
    .avatar-lg {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        overflow: hidden;
        box-shadow: var(--shadow-md);
        background: #fff;
