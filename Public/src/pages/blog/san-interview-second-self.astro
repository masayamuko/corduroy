---
import Layout from '../../layouts/Layout.astro';

const title = "懐疑→確信 ——「第二の自分」を見つけた企画マンの転換｜株式会社コールテン";
const description = "AI懐疑派だった佐野さんが「第二の自分」という概念で腑に落ち、専門性と価値観を入れることでAIがパートナーに変わった転換点を語ります。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/san-interview-second-self/"
  ogUrl="https://www.corduroy.co.jp/blog/san-interview-second-self/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/san-interview-second-self/#article",
    "url": "https://www.corduroy.co.jp/blog/san-interview-second-self/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/san-interview-second-self/"
    },
    "headline": "懐疑→確信 ——「第二の自分」を見つけた企画マンの転換",
    "datePublished": "2026-04-08",
    "dateModified": "2026-04-08",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": [
      { "@type": "Person", "name": "佐野", "jobTitle": "代表", "worksFor": { "@type": "Organization", "name": "株式会社スデニアル" } }
    ],
    "description": "AI懐疑派だった佐野さんが「第二の自分」という概念で腑に落ち、専門性と価値観を入れることでAIがパートナーに変わった転換点を語ります。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "「第二の自分」を見つけた企画マンの転換" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "「第二の自分」とは？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AIに自分の専門知識・価値観・判断基準を入れることで、自分の思考を拡張するパートナーのように使う考え方です。単なるツールではなく、「自分ならこう考える」を一緒に回せる存在になります。"
        }
      },
      {
        "@type": "Question",
        "name": "AIパートナー化に必要な期間は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "佐野さんの場合、毎週のミーティングを数回重ねた段階で「第二の自分」としての手応えを感じ始めました。専門知識と価値観を段階的に入れていくことで、2〜3週間で変化を実感される方が多いです。"
        }
      },
      {
        "@type": "Question",
        "name": "専門知識がなくてもAIは使える？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "もちろん使えます。ただし、佐野さんが実感したように、自分の専門領域や価値観をAIに伝えることで回答の質が大きく変わります。専門知識がない分野でも、自分の「こだわり」や「判断基準」を入れるだけで、一般論とは違う回答が返ってきます。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png"
              alt="佐野さん"
              onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';"></div>
        </div>
        <h1>懐疑→確信<br><span class="h1-sub">「第二の自分」を見つけた企画マンの転換</span></h1>
        <div class="result-badges">
          <span class="result-badge">第二の自分</span>
          <span class="result-badge">AIパートナー化</span>
          <span class="result-badge">思考の拡張</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">マーケティング / 企画</span>
        </div>
        <p>
          「AIは使えない」——そう思い込んでいた佐野さんが、「第二の自分」という概念に出会い、AIとの関わり方が根本から変わった。専門性と価値観を入れた瞬間に起きた転換点を聞きました。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今回は佐野さんがAIに対する見方をガラッと変えたきっかけを聞いていくよ。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png"
                alt="佐野さん"
                onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
            <h3 style="margin:2px 0 4px;">佐野さん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              株式会社スデニアル代表。マーケティング・企画のプロフェッショナル。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として毎週のミーティングで伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入 -->
        <div class="narrative">
          <p>
            「正直、最初はAIに全然期待してなかった」——佐野さんはそう切り出した。
          </p>
          <p>
            マーケティングと企画の最前線で何十年も戦ってきた佐野さん。AIが話題になるずっと前から、現場の勘と経験で成果を出してきた。そんな佐野さんが「第二の自分」という言葉に出会い、AIとの関わり方が根本から変わった。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== AIへの懐疑 ===== -->
          <div class="section-label">AIへの懐疑——議事録しか使ってなかった</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              佐野さん、AI顧問を始める前はAIをどう思ってた？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              便利な文字起こしツールくらいの認識。ミーティングの議事録を要約させるくらいしか使ってなかった。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              それ以上は使おうと思わなかった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              試したんですよ。企画のアイデア出しとか。でも返ってくる答えが「どこかで聞いたことある話」ばかりで。自分の方が詳しいのに、なんでAIに聞かなきゃいけないんだって。
            </div>
          </div>

          <!-- ===== 「第二の自分」で腑に落ちた ===== -->
          <div class="section-label">「第二の自分」で腑に落ちた</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              そこから変わったきっかけは？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              向さんから「第二の自分」って言葉を聞いた時。AIをツールとして使うんじゃなくて、自分の分身として育てるっていう発想。それで一気に腑に落ちた。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「分身として育てる」って、具体的にどういうこと？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              自分の専門知識、判断基準、価値観——「佐野はこういう時にこう考える」っていうのをAIに入れていく。そうすると、ただの一般論じゃなくて「佐野っぽい答え」が返ってくるようになるんです。
            </div>
          </div>

          <!-- ===== 専門知識と価値観を入れる ===== -->
          <div class="section-label">専門知識と価値観を入れる</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「佐野っぽい答え」が返ってきた時、どう感じた？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              「おっ」って思いましたね。これは面白いぞって。それまで「AIに聞いてもしょうがない」って思ってたのが、「一緒に考えてる感覚」に変わった。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              ツールからパートナーに変わったんだね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              まさにそう。ツールだと「使う」「使わない」の二択じゃないですか。パートナーだと「一緒に考える」になる。そこが全然違う。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>佐野さんの表情が変わったのは「佐野っぽい答え」という言葉を口にした時だった。AIが一般論を返すだけの道具から、自分の思考を拡張するパートナーへ——その転換は、専門知識と価値観を入れるという一手間から始まった。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            「AIはツールというよりパートナー。<br>自分の価値観を入れた瞬間、<br>一緒に考えてる感じになった」
          </blockquote>

          <!-- ===== 仕事の進め方が変わった ===== -->
          <div class="section-label">仕事の進め方が変わった</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「第二の自分」を意識してから、仕事の進め方は変わった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              変わりましたね。企画を考える時に、まず自分で仮説を立てて、それをAIにぶつけるようになった。すると「佐野さんの視点だとこうだけど、こっちの切り口もあるよ」って返ってくる。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              壁打ち相手として使ってるんだ。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              壁打ちというか、もう一人の自分と会議してる感じ。しかもその「もう一人」は疲れないし、24時間いつでも付き合ってくれる。
            </div>
          </div>

          <!-- ===== 伝え方の設計 ===== -->
          <div class="section-label">伝え方の設計にもつながった</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              企画以外にも使い方は広がった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              「伝え方の設計」にもつながりましたね。自分が考えていることをクライアントにどう伝えるか、その構成をAIと一緒に練れるようになった。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              佐野さん、ありがとうございました！「第二の自分」の話、すごく分かりやすかった。
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 担当コメント -->
    <section class="container" style="padding-top:40px; padding-bottom:40px;">
      <div class="voice-note fade-up" style="max-width:800px; margin:0 auto;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);"
              alt="向">
          <span class="note-name" style="margin:0">担当 向より</span>
        </div>
        佐野さんは最初、AIに対してかなり懐疑的でした。でも「第二の自分」という切り口でスッと入ってきた。これは佐野さんに限らず、専門性が高い人ほど起きやすい変化です。AIに自分の知識と価値観を入れた瞬間、「使う」から「一緒に考える」に変わる。その転換を目の前で見られたのは、僕にとっても大きな発見でした。
      </div>
    </section>

    <!-- FAQ -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <div class="faq-section fade-up" style="max-width:760px; margin:0 auto;">
        <h2 class="faq-heading">よくある質問</h2>
        <details class="faq-item">
          <summary>「第二の自分」とは？</summary>
          <p>AIに自分の専門知識・価値観・判断基準を入れることで、自分の思考を拡張するパートナーのように使う考え方です。単なるツールではなく、「自分ならこう考える」を一緒に回せる存在になります。</p>
        </details>
        <details class="faq-item">
