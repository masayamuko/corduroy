---
import Layout from '../../layouts/Layout.astro';

const title = "クライアントの声 —— 議事録要約→シミュレーション高速化（BeforeAfter版）｜株式会社コールテン";
const description = "議事録要約しかできなかった頃とは別次元。シミュレーションを爆速で回せるようになり、提案の幅が一気に広がった。佐野さんのBeforeAfterを紹介します。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/san-interview-before-after/"
  ogUrl="https://www.corduroy.co.jp/blog/san-interview-before-after/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/san-interview-before-after/#article",
    "url": "https://www.corduroy.co.jp/blog/san-interview-before-after/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/san-interview-before-after/"
    },
    "headline": "クライアントの声 —— 議事録要約→シミュレーション高速化",
    "datePublished": "2026-04-15",
    "dateModified": "2026-04-15",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "佐野",
      "jobTitle": "代表"
    },
    "description": "議事録要約しかできなかった頃とは別次元。シミュレーションを爆速で回せるようになり、提案の幅が一気に広がった。佐野さんのBeforeAfterを紹介します。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "クライアントの声 —— 佐野さんBeforeAfter" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "AI顧問を始める前のAI活用はどの程度でしたか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "佐野さんの場合、ミーティングの議事録を要約させる程度でした。AIを「便利ツール」としてしか見ておらず、業務の本質的な部分には活かせていませんでした。"
        }
      },
      {
        "@type": "Question",
        "name": "AI顧問を始めてからどう変わりましたか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "マーケ施策のシミュレーションを高速に回せるようになり、仮説→検証→提案のサイクルが劇的に短縮されました。複数案をプロコン付きで即座に出せるようになり、提案の幅と質が同時に向上しています。"
        }
      },
      {
        "@type": "Question",
        "name": "AI顧問はどのくらいの頻度で利用していますか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "佐野さんは毎週1回の定期ミーティングを継続中です。その週のマーケ課題を共有し、AIを使ったシミュレーションの進め方を一緒に考えています。ミーティング以外の時間も、教わった活用法を自分で実践しています。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png"
              alt="佐野さん"
              onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';"></div>
        </div>
        <h1>クライアントの声<br><span class="h1-sub">議事録要約→シミュレーション高速化</span></h1>
        <div class="result-badges">
          <span class="result-badge">提案スピード向上</span>
          <span class="result-badge">外注コスト削減</span>
          <span class="result-badge">施策シミュレーション高速化</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">マーケティング / 企画</span>
        </div>
        <p>
          「議事録要約しかできなかった頃とは別次元」——AI顧問を通じて、佐野さんの仕事がどう変わったか。BeforeAfterで紹介します。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今回は佐野さんのBeforeAfterを紹介していくね。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png"
                alt="佐野さん"
                onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
            <h3 style="margin:2px 0 4px;">佐野さん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              株式会社スデニアル代表。マーケティング・企画のプロフェッショナル。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として毎週のミーティングで伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <div class="narrative">
          <p>
            マーケティングのプロである佐野さん。AIの使い方は「議事録の要約」止まりだった。
          </p>
          <p>
            コールテンとの毎週のミーティングをきっかけに、仮説→検証→提案のサイクルを爆速で回せるようになった。そのBeforeAfterを、佐野さん自身の言葉で振り返ってもらった。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== Before ===== -->
          <div class="section-label">Before: 議事録要約止まりのAI活用</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AI顧問を始める前は、AIをどう使ってた？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              ミーティングの議事録を要約させるくらい。正直、それ以上の使い道が見えてなかった。AIを「便利ツール」としてしか見てなかったですね。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              マーケの施策を考えるのには使ってなかった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              やろうとはしてたけど、検証が追いつかなかった。仮説を立てても、裏付けを取るのに時間がかかりすぎて。自分の頭の中か、外注に出すか。どっちも時間がかかる。
            </div>
          </div>

          <!-- ===== 転換点 ===== -->
          <div class="section-label">転換点: 毎週のミーティングが変えたもの</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              何がきっかけで変わったの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              毎週のAI顧問ミーティングで、「AIに何を聞けばいいか」を一緒に整理してもらったこと。それだけで使い方が全然変わった。
            </div>
          </div>

          <!-- ===== After ===== -->
          <div class="section-label">After: シミュレーションを爆速で回せる</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              今はどう使ってる？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              マーケ施策のシミュレーションを爆速で回せるようになった。複数パターンのプロコンを一気に出して、判断材料を揃える。以前は数日かかってた作業が数分で終わる。
            </div>
          </div>

          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              提案の幅が一気に広がりました。以前は「これでいく」と1案で進めがちだったのが、複数案をプロコン付きで出せるようになった。外注に頼っていた部分も自分で回せるようになって、コストも下がった。
            </div>
          </div>

          <div class="narrative-inline">
            <p>佐野さんのBeforeAfterが示しているのは、AIの活用は「何ができるか」だけでなく「どう使い方を覚えるか」が重要だということ。毎週のミーティングという伴走があったからこそ、「議事録要約」から「シミュレーション高速化」へ自然にステップアップできた。</p>
          </div>

          <blockquote class="pull-quote">
            「議事録要約しかできなかった頃とは別次元。<br>シミュレーションを爆速で回せるようになり、<br>提案の幅が一気に広がった」
          </blockquote>

          <!-- ===== これから ===== -->
          <div class="section-label">これからのAI活用</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              これからどう使っていきたい？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/sano_sudenial.png" alt="佐野さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">佐野さん</span>
            </div>
            <div class="bubble-text">
              マーケだけじゃなく、事業全体のシミュレーションに使いたいですね。新規事業の検証とか、チームの意思決定サポートとか。もう議事録止まりには戻れないです。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              佐野さん、ありがとうございました！BeforeAfter、すごい変化だったね。
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 担当コメント -->
    <section class="container" style="padding-top:40px; padding-bottom:40px;">
      <div class="voice-note fade-up" style="max-width:800px; margin:0 auto;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);"
              alt="向">
          <span class="note-name" style="margin:0">担当 向より</span>
        </div>
        佐野さんはプロのマーケター。だからこそ、AIの使い方が「議事録の要約」で止まっていたのがもったいなかった。毎週のミーティングで少しずつ「AIでシミュレーションを回す」やり方を一緒に作っていった結果、今では僕より使いこなしているかもしれません。BeforeAfterの差を見ると、伴走の価値を実感します。
      </div>
    </section>

    <!-- FAQ -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <div class="faq-section fade-up" style="max-width:760px; margin:0 auto;">
        <h2 class="faq-heading">よくある質問</h2>
        <details class="faq-item">
          <summary>AI顧問を始める前のAI活用はどの程度でしたか？</summary>
          <p>佐野さんの場合、ミーティングの議事録を要約させる程度でした。AIを「便利ツール」としてしか見ておらず、業務の本質的な部分には活かせていませんでした。</p>
        </details>
        <details class="faq-item">
          <summary>AI顧問を始めてからどう変わりましたか？</summary>
          <p>マーケ施策のシミュレーションを高速に回せるようになり、仮説→検証→提案のサイクルが劇的に短縮されました。複数案をプロコン付きで即座に出せるようになり、提案の幅と質が同時に向上しています。</p>
        </details>
        <details class="faq-item">
          <summary>AI顧問はどのくらいの頻度で利用していますか？</summary>
          <p>佐野さんは毎週1回の定期ミーティングを継続中です。その週のマーケ課題を共有し、AIを使ったシミュレーションの進め方を一緒に考えています。ミーティング以外の時間も、教わった活用法を自分で実践しています。</p>
        </details>
      </div>
    </section>

    <!-- 関連リンク -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <aside class="related-links fade-up" style="max-width:720px; margin:0 auto; padding:24px; background:rgba(22,97,78,0.04); border-radius:12px;">
        <p style="font-weight:600; font-size:14px; color:var(--sea); margin-bottom:12px;">関連コンテンツ</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
          <li><a href="/blog/san-interview-simulation/" style="font-size:13px; color:var(--sea);">「議事録の先」を見つけた日 —— マーケター佐野さんのAIシミュレーション活用術 →</a></li>
          <li><a href="/blog/san-interview-project-options/" style="font-size:13px; color:var(--sea);">「発注ありき」から「共創前提」へ →</a></li>
          <li><a href="/clients/san/" style="font-size:13px; color:var(--sea);">佐野さんの記事一覧 →</a></li>
          <li><a href="/services/advisory/" style="font-size:13px; color:var(--sea);">AI顧問サービスについて →</a></li>
        </ul>
      </aside>
    </section>

    <!-- CTA -->
    <section id="contact" class="container" style="padding-top:0; padding-bottom:100px;">
      <div class="card cta-card fade-up" style="max-width:720px;margin:0 auto;text-align:center">
        <h3>あなたのAI活用も「別次元」に</h3>
        <p class="mini" style="line-height:1.8;margin-top:12px;color:var(--text-light);">
          コールテンは、あなたの業務に合わせたAI活用を毎週のミーティングで伴走します。<br>
          まずは小さく試して、その効果を体感してみませんか？
        </p>
        <p class="mini" style="line-height:1.8;margin-top:14px;color:var(--text-light);">このケースで中心になっているのは<strong>AI顧問サービス</strong>です。毎週の定期ミーティングで、AIの使い方を一緒に磨いていきます。</p>
        <div style="margin-top:16px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap; align-items:center;">
          <a class="btn" href="/services/advisory/">AI顧問サービスの詳細</a>
          <a class="btn secondary" href="/blog/">ブログ一覧に戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
    .hero { padding: 160px 0 32px; text-align: center; background: transparent; }
    .intro-section { padding-top: 0; margin-top: 0; }
    .hero-inner { display: flex; flex-direction: column; align-items: center; gap: 24px; max-width: 800px; margin: 0 auto; }
    .h1-sub { font-size: clamp(18px, 2.5vw, 24px); font-weight: 600; display: block; margin-top: 8px; color: var(--text-light); }
    .meta { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: center; margin-top: 24px; }
    .tag { display: inline-block; padding: 8px 16px; border-radius: 100px; background: var(--mint); color: var(--sea); font-weight: 700; font-size: 13px; border: 1px solid var(--line); }
    .pill { display: inline-block; padding: 8px 16px; border-radius: 100px; background: #fff; border: 1px solid var(--line); font-weight: 700; font-size: 13px; color: var(--text-light); }
    .avatar-frame { width: 160px; height: 160px; margin: 0 auto; display: flex; align-items: center; justify-content: center; background: url('https://res.cloudinary.com/dg3mdcuju/image/upload/v1764661828/%E3%83%95%E3%83%AC%E3%83%BC%E3%83%A0_kyyx9d.png') center/contain no-repeat; }
