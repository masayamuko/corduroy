---
import Layout from '../../layouts/Layout.astro';

const title = "行政書士ネットワーク「オーラ」立ち上げ記 —— 外国人材支援の仕組みづくり｜株式会社コールテン";
const description = "「基準を持ったパートナーだからこそ、企業も外国人も安心できる」。行政書士の石井文美さんに、ネットワーク「オーラ」の立ち上げ背景と仕組みづくりを聞きました。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/aym-interview-aura-startup/"
  ogUrl="https://www.corduroy.co.jp/blog/aym-interview-aura-startup/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/aym-interview-aura-startup/#article",
    "url": "https://www.corduroy.co.jp/blog/aym-interview-aura-startup/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/aym-interview-aura-startup/"
    },
    "headline": "行政書士ネットワーク「オーラ」立ち上げ記 —— 外国人材支援の仕組みづくり",
    "datePublished": "2026-01-25",
    "dateModified": "2026-01-25",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "石井文美",
      "jobTitle": "行政書士"
    },
    "description": "「基準を持ったパートナーだからこそ、企業も外国人も安心できる」。行政書士の石井文美さんに、ネットワーク「オーラ」の立ち上げ背景と仕組みづくりを聞きました。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "石井さんインタビュー — オーラ立ち上げ" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "オーラとは何をする団体？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "インドネシア人材の適正な受け入れを支える行政書士のネットワークです。パートナー基準を設けた更新制で品質を担保し、Slackを中心とした情報共有基盤で連携しています。"
        }
      },
      {
        "@type": "Question",
        "name": "パートナー行政書士の基準は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "在留資格申請の実務経験、適正な受け入れへの理解、継続的な活動参加の3点を基準としています。更新制を採用しており、基準を継続的に満たすことがパートナーであり続ける条件です。"
        }
      },
      {
        "@type": "Question",
        "name": "外国人材受け入れの課題は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "手続きの質のばらつき、法改正への対応速度、企業側の受け入れ体制の不備などが主な課題です。オーラでは、信頼できる行政書士のネットワークを通じて、これらの課題を解消することを目指しています。"
        }
      }
    ]
  }
  </script>

  <main>
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png"
              alt="石井さん"></div>
        </div>
        <h1>行政書士ネットワーク<br>「オーラ」立ち上げ記<br><span class="h1-sub">外国人材支援の仕組みづくり</span></h1>
        <div class="result-badges">
          <span class="result-badge">オーラ</span>
          <span class="result-badge">ネットワーク</span>
          <span class="result-badge">外国人材</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">組織立ち上げ / 社会課題</span>
        </div>
        <p>
          インドネシア人材の適正受け入れを支える行政書士ネットワーク「オーラ」。その立ち上げの経緯と仕組みづくりを、石井文美さんに聞きました。
        </p>
      </div>
    </section>

    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今日は石井さんに「オーラ」の立ち上げについて聞いていくよ。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role" style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
            <h3 style="margin:2px 0 4px;">石井文美さん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">行政書士。「オーラ」を立ち上げ、外国人材の適正受け入れを支える仕組みづくりに取り組む。</p>
          </div>
          <div class="character-card">
            <span class="character-role" style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg" alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として組織立ち上げ・情報基盤設計を伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <section class="container">
      <div class="card dialogue-flow fade-up">

        <div class="narrative">
          <p>
            「基準を持ったパートナーだからこそ、企業も外国人も安心できる」——石井さんの確信は揺るがない。
          </p>
          <p>
            外国人材の受け入れは制度が複雑で、関わる人も多い。行政書士が個別に対応するだけでは限界がある。だからこそ、信頼できる行政書士をネットワークでつなぐ「オーラ」が必要だった。
          </p>
        </div>

        <div class="dialogue">

          <div class="section-label">オーラとは</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「オーラ」ってどんな団体なの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              インドネシア人材の適正な受け入れを支える行政書士のネットワークです。個人事務所だと情報も人手も限界がある。ネットワークで力を合わせることで、より質の高い支援ができると考えています。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              なぜインドネシアに絞っているの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              インドネシアからの技能実習生や特定技能人材が急増しているんです。まずは一つの国に集中して、モデルケースを作りたい。成功したら他の国にも広げていけますから。
            </div>
          </div>

          <div class="section-label">キックオフ説明会</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              キックオフ説明会の反応はどうだった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              「こういう場がほしかった」という声が多かったですね。みんな同じ課題を感じていたんだと実感しました。ただ、「どうやって品質を保つのか」という鋭い質問もあって、そこはパートナー基準で応えていく形です。
            </div>
          </div>

          <div class="section-label">Slack中心の連絡体制</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              連絡体制はどうしてるの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              Slackを中心にしています。向さんにチャンネル設計を手伝ってもらって、テーマごとに情報が整理される仕組みを作りました。法改正の速報とか、申請のノウハウとか、すぐ共有できるのが大きい。
            </div>
          </div>

          <div class="section-label">パートナー基準の設計</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              パートナーの基準はどう決めたの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              実務経験、適正な受け入れへの理解、継続的な活動参加。この3つを基準にしています。更新制なので、入って終わりではない。常に基準を満たしている必要があります。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              営業用のパンフレットも作ったんだよね？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              はい。企業向けの営業パンフレットを作りました。「オーラのパートナー行政書士に頼めば安心」ということが伝わるように。信頼を可視化するツールですね。
            </div>
          </div>

          <div class="narrative-inline">
            <p>石井さんが大事にしているのは「小さく始めて、信頼で広げる」というアプローチだ。広告で一気に拡大するのではなく、一件ずつ実績を積み、口コミでパートナーを増やす。この地道さが、ネットワークの品質を保つ鍵になっている。</p>
          </div>

          <blockquote class="pull-quote">
            「基準を持ったパートナーだからこそ、<br>企業も外国人も安心できる」
          </blockquote>

          <div class="section-label">今後の展望</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              これからオーラをどう育てていきたい？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="石井さん">
              <span class="name-tag">石井さん</span>
            </div>
            <div class="bubble-text">
              まずは勉強会を定期的に開催したい。パートナー同士で知識をアップデートし合う場を作る。あと、将来的にはインドネシア以外の国の人材受け入れにも横展開していきたいですね。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              石井さん、ありがとうございました！オーラの成長、応援してるよ。
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="container" style="padding-top:40px; padding-bottom:40px;">
      <div class="voice-note fade-up" style="max-width:800px; margin:0 auto;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);" alt="向">
          <span class="note-name" style="margin:0">担当 向より</span>
        </div>
        石井さんの「オーラ」は、単なる行政書士の集まりではなく、品質基準を持った組織です。Slackの設計やパートナー基準の整理をお手伝いしましたが、石井さん自身が「適正な受け入れ」という明確な軸を持っていたからこそ、ブレない組織設計ができた。小さく始めて信頼で広げるアプローチが、この分野にぴったり合っています。
      </div>
    </section>

    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <div class="faq-section fade-up" style="max-width:760px; margin:0 auto;">
        <h2 class="faq-heading">よくある質問</h2>
        <details class="faq-item">
          <summary>オーラとは何をする団体？</summary>
          <p>インドネシア人材の適正な受け入れを支える行政書士のネットワークです。パートナー基準を設けた更新制で品質を担保し、Slackを中心とした情報共有基盤で連携しています。</p>
        </details>
        <details class="faq-item">
          <summary>パートナー行政書士の基準は？</summary>
          <p>在留資格申請の実務経験、適正な受け入れへの理解、継続的な活動参加の3点を基準としています。更新制を採用しており、基準を継続的に満たすことがパートナーであり続ける条件です。</p>
        </details>
        <details class="faq-item">
          <summary>外国人材受け入れの課題は？</summary>
          <p>手続きの質のばらつき、法改正への対応速度、企業側の受け入れ体制の不備などが主な課題です。オーラでは、信頼できる行政書士のネットワークを通じて、これらの課題を解消することを目指しています。</p>
        </details>
      </div>
    </section>

    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <aside class="related-links fade-up" style="max-width:720px; margin:0 auto; padding:24px; background:rgba(22,97,78,0.04); border-radius:12px;">
        <p style="font-weight:600; font-size:14px; color:var(--sea); margin-bottom:12px;">関連コンテンツ</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
          <li><a href="/blog/aym-interview-immigration-ai/" style="font-size:13px; color:var(--sea);">行政書士業務×AIインタビュー →</a></li>
          <li><a href="/services/advisory/" style="font-size:13px; color:var(--sea);">AI顧問サービスについて →</a></li>
        </ul>
      </aside>
    </section>

    <section id="contact" class="container" style="padding-top:0; padding-bottom:100px;">
      <div class="card cta-card fade-up" style="max-width:720px;margin:0 auto;text-align:center">
        <h3>組織の立ち上げを、仕組みから支える</h3>
        <p class="mini" style="line-height:1.8;margin-top:12px;color:var(--text-light);">
          コールテンは、組織の情報基盤設計からコミュニケーション設計まで伴走します。<br>
          新しい組織を立ち上げたい方、まずはご相談ください。
        </p>
        <div style="margin-top:16px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap; align-items:center;">
          <a class="btn" href="/services/advisory/">AI顧問サービスの詳細</a>
          <a class="btn secondary" href="/blog/">ブログ一覧に戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
    .hero { padding: 160px 0 32px; text-align: center; background: transparent; }
    .intro-section { padding-top: 0; margin-top: 0; }
    .hero-inner { display: flex; flex-direction: column; align-items: center; gap: 24px; max-width: 800px; margin: 0 auto; }
    .h1-sub { font-size: clamp(18px, 2.5vw, 24px); font-weight: 600; display: block; margin-top: 8px; color: var(--text-light); }
    .meta { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: center; margin-top: 24px; }
    .tag { display: inline-block; padding: 8px 16px; border-radius: 100px; background: var(--mint); color: var(--sea); font-weight: 700; font-size: 13px; border: 1px solid var(--line); }
    .pill { display: inline-block; padding: 8px 16px; border-radius: 100px; background: #fff; border: 1px solid var(--line); font-weight: 700; font-size: 13px; color: var(--text-light); }
    .avatar-frame { width: 160px; height: 160px; margin: 0 auto; display: flex; align-items: center; justify-content: center; background: url('https://res.cloudinary.com/dg3mdcuju/image/upload/v1764661828/%E3%83%95%E3%83%AC%E3%83%BC%E3%83%A0_kyyx9d.png') center/contain no-repeat; }
    .avatar-lg { width: 80px; height: 80px; border-radius: 50%; overflow: hidden; box-shadow: var(--shadow-md); background: #fff; }
    .avatar-lg img { width: 100%; height: 100%; object-fit: cover; }
