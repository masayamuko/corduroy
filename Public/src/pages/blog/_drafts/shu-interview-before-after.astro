---
import Layout from '../../layouts/Layout.astro';

const title = "「調べるだけ」のAIから「相棒」へ —— 行政書士しゅうへいさんのBeforeAfter｜株式会社コールテン";
const description = "AIを検索ツール止まりで使っていた行政書士のしゅうへいさんが、対話型の相棒として活用するようになるまで。内省の回転数が上がり、AI会社への転身やDX推進副委員長就任へと繋がったBeforeAfterを聞きました。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/shu-interview-before-after/"
  ogUrl="https://www.corduroy.co.jp/blog/shu-interview-before-after/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/shu-interview-before-after/#article",
    "url": "https://www.corduroy.co.jp/blog/shu-interview-before-after/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/shu-interview-before-after/"
    },
    "headline": "「調べるだけ」のAIから「相棒」へ —— 行政書士しゅうへいさんのBeforeAfter",
    "datePublished": "2026-03-18",
    "dateModified": "2026-03-18",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "周平",
      "jobTitle": "行政書士 / DX推進 / AI会社勤務"
    },
    "description": "AIを検索ツール止まりで使っていた行政書士のしゅうへいさんが、対話型の相棒として活用するようになるまで。内省の回転数が上がり、AI会社への転身やDX推進副委員長就任へと繋がったBeforeAfterを聞きました。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "しゅうへいさんBeforeAfter" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "BeforeAfterはどれくらいの期間で実感できますか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "しゅうへいさんの場合、最初のセッションから3時間没頭するほどの変化を実感しました。AIを検索ツールから対話相手に切り替えるだけで、数週間のうちに内省の回転数が上がり、仕事の判断スピードも変わったそうです。"
        }
      },
      {
        "@type": "Question",
        "name": "AIを対話相手にするとはどういうことですか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "単に質問して答えを受け取るのではなく、AIの返答に対して自分の考えをぶつけ、さらに深掘りしていくやり方です。コーチングのように自分の思考を整理・言語化するプロセスが生まれ、内省の質と速度が大きく変わります。"
        }
      },
      {
        "@type": "Question",
        "name": "行政書士業務にAIは使えますか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "しゅうへいさんは行政書士としての専門性とAI活用を掛け合わせ、DX推進副委員長やAI会社での業務など活躍の幅を広げました。法令リサーチや書類整理だけでなく、業務フロー改善や研修設計にもAIが活きるとのことです。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png"
              alt="しゅうへいさん"
              onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';"></div>
        </div>
        <h1>「調べるだけ」のAIから「相棒」へ<br><span class="h1-sub">行政書士しゅうへいさんのBeforeAfter</span></h1>
        <div class="result-badges">
          <span class="result-badge">BeforeAfter</span>
          <span class="result-badge">対話型AI</span>
          <span class="result-badge">内省回転数UP</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">AI活用 / キャリア</span>
        </div>
        <p>
          行政書士として活動するしゅうへいさん。AIの使い方は「調べもの」止まりだった。コールテンの「第二の自分ワーク」をきっかけに、AIが対話の相棒へと変わり、キャリアそのものが動き出したBeforeAfterを聞きました。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>ここからはボクが、しゅうへいさんにBeforeAfterを聞いていくね。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png"
                alt="しゅうへいさん"
                onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
            <h3 style="margin:2px 0 4px;">しゅうへいさん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              行政書士。DX推進副委員長。AI開発会社にも勤務。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">「第二の自分ワーク」を通じてAI活用を伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入 -->
        <div class="narrative">
          <p>
            「AIの返答を"良い/悪い"で切って終わると伸びない。柔軟に捉えて自分の軸で使うと、どんどん面白くなる」——しゅうへいさんはそう言い切った。
          </p>
          <p>
            行政書士として士業の世界にいながら、AI開発会社に勤め、行政書士会のDX推進副委員長も務める。その転機は、コールテンの「スマフラ講座」だった。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== 出会い: スマフラ講座 ===== -->
          <div class="section-label">出会い: スマフラ講座がきっかけ</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              しゅうへいさん、コールテンとの出会いはどこから？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              スマフラ講座ですね。向さんが講師をやっていた、AIの使い方を学ぶ講座。最初は「便利ツールの紹介かな」くらいの気持ちで参加したんですけど、全然違った。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              何が違ったの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              「第二の自分をつくる」っていうコンセプト。AIに調べてもらうんじゃなくて、AIと対話して自分を掘り下げていく。それが入口で、一気にハマった。
            </div>
          </div>

          <!-- ===== 初速が異常 ===== -->
          <div class="section-label">初速が異常——ゲーム感覚で3時間</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              最初の体験ってどんな感じだった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              ゲーム感覚に近かったです。気づいたら3時間経ってた。「次はこう聞いてみよう」「この角度はどうだ」って、どんどん深掘りしたくなる。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              Before のときは、AIに聞いて「ふーん」で終わり。内省に繋がらなかったんです。でも対話型に切り替えた瞬間、回転数が全然変わった。
            </div>
          </div>

          <!-- ===== 合う人の特徴 ===== -->
          <div class="section-label">合う人の特徴——ゼロイチで切らない人</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              この使い方って、どんな人に合うと思う？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              AIの返答をゼロイチで切らない人。「使えるか使えないか」じゃなくて、「ここを膨らませたら面白いかも」って柔軟に捉えられる人は、どんどん伸びると思います。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              逆に合わない人は？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              「良い/悪い」でパッと判断して終わる人。AIの返答って完璧じゃないけど、そこから自分の軸で広げていくのが面白いんですよ。ゼロイチで切ると、そこで止まっちゃう。
            </div>
          </div>

          <!-- ===== 仕事での変化 ===== -->
          <div class="section-label">仕事での変化——AI会社で対話型が武器に</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AIの使い方が変わって、仕事面ではどう変わった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              大きかったのは、AI開発の会社に入ったこと。面接で「AIとどう関わってきたか」を聞かれたとき、対話型で使ってきた経験がそのまま武器になりました。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              上司に「AIと対話して進めて」と言われたとき、第二の自分づくりで染み付いたやり方がそのまま強みになった。Beforeの自分だったら、何をしていいかわからなかったと思います。
            </div>
          </div>

          <!-- ===== DX推進 ===== -->
          <div class="section-label">DX推進副委員長への道</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              行政書士会のDX推進副委員長にもなったんだよね。それもAI活用がきっかけ？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              そうですね。AI活用の経験が評価されて声がかかった。Beforeの自分は、士業の仕事を淡々とこなすだけだった。Afterは、テクノロジーで業界を動かす側に立てている。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>しゅうへいさんのBeforeAfterは、ツールの使い方が変わっただけではない。「自分との向き合い方」が変わったことで、キャリアの選択肢そのものが広がった。AIが内省の相棒になったとき、見えてくる景色はまるで違う。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            「AIの返答を"良い/悪い"で切って終わると伸びない。<br>柔軟に捉えて自分の軸で使うと、<br>どんどん面白くなる」
          </blockquote>

          <!-- ===== コールテンの学び ===== -->
          <div class="section-label">コールテンの学び——「第二の自分」が入口</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              コールテンで一番学びになったことって何だった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              「第二の自分をつくる」というコンセプトが入口として最高だったこと。技術を教わるんじゃなくて、自分を知ることから始まるっていうのが新しかった。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              しゅうへいさん、ありがとう！BeforeAfterがすごくリアルに伝わったよ。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              こちらこそ。AIって「何ができるか」より「どう付き合うか」が大事だと思うんです。それを体感できたのが、一番の変化ですね。
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 担当コメント -->
    <section class="container" style="padding-top:40px; padding-bottom:40px;">
