---
import Layout from '../../layouts/Layout.astro';

const title = "青少年支援の現場でAIを使う —— 「福岡の会」柴田さんの挑戦｜株式会社コールテン";
const description = "グループホーム立ち上げ、若者の緊急対応、人材確保——課題山積の青少年支援の現場で、AIによる資料・動画制作を試みる「福岡の会」柴田さんに、支援の知恵を形にする取り組みを聞きました。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/sjfk-interview-youth-support/"
  ogUrl="https://www.corduroy.co.jp/blog/sjfk-interview-youth-support/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/sjfk-interview-youth-support/#article",
    "url": "https://www.corduroy.co.jp/blog/sjfk-interview-youth-support/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/sjfk-interview-youth-support/"
    },
    "headline": "青少年支援の現場でAIを使う —— 「福岡の会」柴田さんの挑戦",
    "datePublished": "2026-01-20",
    "dateModified": "2026-01-20",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "柴田さん",
      "jobTitle": "代表",
      "worksFor": {
        "@type": "Organization",
        "name": "青少年の自立を支える福岡の会"
      }
    },
    "description": "グループホーム立ち上げ、若者の緊急対応、人材確保——課題山積の青少年支援の現場で、AIによる資料・動画制作を試みる「福岡の会」柴田さんに、支援の知恵を形にする取り組みを聞きました。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "柴田さんインタビュー（青少年支援）" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "青少年支援でAIはどう使える？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "福岡の会では、支援活動の紹介資料や動画をAIで試作しています。現場の支援者が持つ知恵やノウハウを、外部に伝わる形に変換することで、寄付・人材確保・行政連携などの課題解決につなげる取り組みです。"
        }
      },
      {
        "@type": "Question",
        "name": "グループホーム立ち上げの課題は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "物件探し・近隣理解・人材確保・行政手続きなど、多方面の課題が同時に発生します。特に青少年向けは「何をする施設かわからない」という不安が近隣住民に生まれやすく、活動内容を丁寧に説明できる資料の整備が重要です。"
        }
      },
      {
        "@type": "Question",
        "name": "支援団体のAI導入の始め方は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "まずは「外部に見せる資料」の作成から始めるのがおすすめです。支援の現場で日常的にやっていることを言語化し、AIで資料や動画のたたき台を作る。完成度よりも「形にすること」を優先し、そこから改善していく進め方が現場に馴染みやすいです。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png"
              alt="柴田さん"
              onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';"></div>
        </div>
        <h1>青少年支援の現場でAIを使う<br><span class="h1-sub">「福岡の会」柴田さんの挑戦</span></h1>
        <div class="result-badges">
          <span class="result-badge">青少年支援</span>
          <span class="result-badge">グループホーム</span>
          <span class="result-badge">AI活用</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">福祉 / 子ども支援</span>
        </div>
        <p>
          グループホームの立ち上げ、若者の緊急対応、人材確保——課題が山積する青少年支援の現場。「青少年の自立を支える福岡の会」代表の柴田さんに、現場の知恵をAIで形にする取り組みについて聞きました。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>ここからはボクが、柴田さんに話を聞いていくね。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png"
                alt="柴田さん"
                onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
            <h3 style="margin:2px 0 4px;">柴田さん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              青少年の自立を支える福岡の会 代表。グループホーム運営や若者の自立支援に取り組む。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として制作支援・業務整理で伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入 -->
        <div class="narrative">
          <p>
            「支援の現場は毎日が想定外」——柴田さんはそう笑った。
          </p>
          <p>
            青少年の自立を支える福岡の会。児童養護施設や里親家庭を離れた若者たちの「その先」を支えるNPOだ。グループホームの立ち上げ、緊急の住居確保、就労支援。やるべきことは無限にある。だが、それを外に伝える余裕がない——。AIとの出会いは、そんな現場の「伝えられない」を変えるきっかけになった。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== 福岡の会とは ===== -->
          <div class="section-label">福岡の会とは</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              まず「福岡の会」がどんな団体なのか、教えてもらえますか？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              正式名称は「青少年の自立を支える福岡の会」です。児童養護施設を出た子や、家庭に居場所がない若者の生活を支えています。グループホームの運営、就労支援、緊急時の受け入れが主な活動ですね。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「緊急時の受け入れ」って、どんな状況？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              夜中に「今日泊まる場所がない」って連絡が来ることもあります。家を追い出された、施設を出たけど行き先がない。そういう子をまず安全な場所につなぐのが最初の一歩です。
            </div>
          </div>

          <!-- ===== グループホーム立ち上げの現状 ===== -->
          <div class="section-label">グループホーム立ち上げの現状</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              グループホームの立ち上げが進んでいるって聞いたけど、どんな状況？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              物件は決まったんですが、そこからが大変で。近隣への説明、行政との手続き、スタッフの採用……全部同時に動かさないといけない。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              近隣への説明って、難しいもの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              「何をする施設なのかわからない」っていう不安が一番大きいんです。だから、活動内容をきちんと伝えられる資料がすごく大事で。でも、日々の支援に追われて資料を作る時間がなかなか取れない。
            </div>
          </div>

          <!-- ===== 人材確保のボトルネック ===== -->
          <div class="section-label">人材確保のボトルネック</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              人材確保の面ではどう？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              正直、一番のボトルネックです。福祉の仕事ってどうしても「大変そう」というイメージが先行する。実際に大変なんですけど（笑）、やりがいや意味をちゃんと伝えられていないのが問題だと思っています。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              求人票だけだと伝わらないんですよね。現場の雰囲気とか、支援の中で感じる手応えとか。そういうものを見せられる手段がほしかった。
            </div>
          </div>

          <!-- ===== 若者支援のリアル ===== -->
          <div class="section-label">若者支援のリアル</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              実際に若者を支援するとき、何が一番大変？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              スピードですね。住む場所と仕事を短期間で決めないといけない。施設を出た子は「待ってくれる場所」がないから、一ヶ月以内に生活基盤を作らないと路頭に迷ってしまう。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              一ヶ月……短いね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              だからこそ、対応の手順とか、よくあるパターンとか、現場で蓄積してきた知恵がすごく重要なんです。でも、それがスタッフの頭の中にしかない。
            </div>
          </div>

          <!-- ===== 支援知を整理して外部に伝える ===== -->
          <div class="section-label">支援知を整理して外部に伝える</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              現場の知恵を整理して外に出す、ということ？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              そうです。行政に説明するとき、寄付をお願いするとき、新しいスタッフに引き継ぐとき。全部「伝える」が必要なのに、そこに使える形になっていない。それが一番のもどかしさでした。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>支援の現場には、外からは見えない膨大な知恵がある。だがそれは、現場の人の経験と勘の中に埋もれている。柴田さんが求めていたのは、その知恵を「見える形」にする手段だった。</p>
          </div>

          <!-- ===== AIで資料・動画を試作 ===== -->
          <div class="section-label">AIで資料・動画を試作</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AIを使い始めたきっかけは？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="柴田さん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">柴田さん</span>
            </div>
            <div class="bubble-text">
              コールテンの向さんに「現場の話をそのまま資料にできますよ」って言われたのが最初です。最初は半信半疑でしたけど、試しに活動紹介の資料を作ってもらったら、思った以上にちゃんとしたものが出てきた。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
