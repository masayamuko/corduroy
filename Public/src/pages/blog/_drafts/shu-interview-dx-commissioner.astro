---
import Layout from '../../layouts/Layout.astro';

const title = "行政書士がDX推進副委員長に —— AI活用が仕事を変えた実話｜株式会社コールテン";
const description = "行政書士のしゅうへいさんが、AI活用をきっかけにDX推進副委員長に就任。士業の業界にAIを持ち込み、研修設計や組織改革を進める実話を聞きました。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/shu-interview-dx-commissioner/"
  ogUrl="https://www.corduroy.co.jp/blog/shu-interview-dx-commissioner/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/shu-interview-dx-commissioner/#article",
    "url": "https://www.corduroy.co.jp/blog/shu-interview-dx-commissioner/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/shu-interview-dx-commissioner/"
    },
    "headline": "行政書士がDX推進副委員長に —— AI活用が仕事を変えた実話",
    "datePublished": "2026-03-12",
    "dateModified": "2026-03-12",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "沼澤周平",
      "jobTitle": "行政書士 / DX推進副委員長"
    },
    "description": "行政書士のしゅうへいさんが、AI活用をきっかけにDX推進副委員長に就任。士業の業界にAIを持ち込み、研修設計や組織改革を進める実話を聞きました。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "しゅうへいさんDX推進インタビュー" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "士業がDX推進するメリットは？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "しゅうへいさんの場合、現場の業務を深く理解しているからこそ、AIやデジタルツールの導入ポイントが明確でした。法令知識とテクノロジーの橋渡し役として、同業者からの信頼も厚くなり、副委員長就任に至りました。"
        }
      },
      {
        "@type": "Question",
        "name": "行政書士会のAI導入は何から始めましたか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "まず基礎研修から始めました。AIとは何か、何ができるかを丁寧に伝えるところからスタートし、実際の業務で使える具体的な場面を一つずつ見せていく形です。いきなり高度なツールを導入するのではなく、理解の土台を作ることを優先しました。"
        }
      },
      {
        "@type": "Question",
        "name": "セキュリティ面での注意点は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "士業は個人情報や機密情報を扱うため、AIに入力する情報の範囲を明確にすることが最重要です。しゅうへいさんは「何を入力してよく、何を入力してはいけないか」のガイドラインを研修に組み込み、安全に使える環境づくりから始めました。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png"
              alt="しゅうへいさん"
              onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';"></div>
        </div>
        <h1>行政書士がDX推進副委員長に<br><span class="h1-sub">AI活用が仕事を変えた実話</span></h1>
        <div class="result-badges">
          <span class="result-badge">士業DX</span>
          <span class="result-badge">副委員長</span>
          <span class="result-badge">組織変革</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">DX推進 / 士業</span>
        </div>
        <p>
          行政書士のしゅうへいさんが、コールテンでのAI活用経験をきっかけに行政書士会DX推進委員会の副委員長に。士業の業界にAIを持ち込み、研修や組織改革を進める裏側を聞きました。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今回は、しゅうへいさんのDX推進の話を深掘りしていくよ。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png"
                alt="しゅうへいさん"
                onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
            <h3 style="margin:2px 0 4px;">しゅうへいさん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              行政書士。DX推進委員会 副委員長。AI開発会社にも勤務。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入 -->
        <div class="narrative">
          <p>
            「上司に『AIと対話して進めて』と言われた時、第二の自分づくりで染み付いたやり方がそのまま強みになった」——しゅうへいさんは淡々と、しかし確信を持って語った。
          </p>
          <p>
            行政書士として実務をこなしながら、行政書士会のDX推進副委員長として組織変革を推進する。その裏には、コールテンで学んだ「AIとの対話」がある。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== DX推進委員会に入った経緯 ===== -->
          <div class="section-label">DX推進委員会に入った経緯</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              DX推進委員会に入ったきっかけは？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              行政書士会の中で「AIに詳しい人」として認知されるようになったんです。コールテンでやっていた第二の自分ワークや、AI会社での経験が、自然と周りに伝わっていて。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              声がかかった感じ？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              そうです。「DXを推進したいけど、何から手をつけていいかわからない」っていう課題があって、そこに自分の経験がハマった感じですね。
            </div>
          </div>

          <!-- ===== 副委員長としての活動 ===== -->
          <div class="section-label">副委員長としての活動</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              副委員長として、具体的にどんなことをしてるの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              大きく3つあって。1つ目がAI基礎研修の設計と実施。2つ目が業務改善のヒアリングと提案。3つ目が会員同士のコミュニティづくり。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              研修って、どういう内容？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              まず「AIとは何か」から丁寧に始めます。いきなりツールを紹介しても使えないんですよ。理解の土台をつくってから、実際の業務で使える場面を一つずつ見せていく。
            </div>
          </div>

          <!-- ===== AI導入・セキュリティ観点 ===== -->
          <div class="section-label">セキュリティの壁をどう超えるか</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              士業って個人情報をたくさん扱うよね。セキュリティ面はどうしてる？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              そこが一番慎重にやっている部分です。「何を入力してよくて、何を入力してはいけないか」のガイドラインを研修に組み込んでいます。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              「AIは怖い」ではなくて、「ルールを決めれば安全に使える」という認識に変えていくのが大事ですね。
            </div>
          </div>

          <!-- ===== コミュニティ運営 ===== -->
          <div class="section-label">行政書士間コミュニティの立ち上げ</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              コミュニティづくりって、どんなことをしてるの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              AI活用に興味がある行政書士同士が情報交換できる場をつくっています。一人で試行錯誤するより、仲間がいるほうが続くし、発見も多い。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              まさにコールテンの講座でしゅうへいさん自身が経験したことだね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              そうなんです。スマフラ講座で「一緒に学ぶ仲間がいる」ことのパワーを体感したから、それを行政書士会でもやりたいと思った。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>しゅうへいさんの取り組みが興味深いのは、「自分がAIを使えるようになった」で終わらないところだ。学んだことを組織に還元し、仕組みに変えていく。個人の変化が、業界の変化へと広がっていくプロセスがここにある。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            「上司に『AIと対話して進めて』と言われた時、<br>第二の自分づくりで染み付いたやり方が<br>そのまま強みになった」
          </blockquote>

          <!-- ===== AI会社での経験 ===== -->
          <div class="section-label">AI会社で「対話して進めて」と言われて</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              AI会社での仕事でも、コールテンで学んだことは活きてる？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              めちゃくちゃ活きてます。上司に「AIと対話して進めて」と言われた時、第二の自分づくりで染み付いたやり方がそのまま使えた。他の人が戸惑う場面でも、自然に動けるんです。
            </div>
          </div>

          <!-- ===== これからの展望 ===== -->
          <div class="section-label">業務改善の展望</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              今後、行政書士業界のDXはどう進んでいくと思う？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
              <span class="name-tag">しゅうへいさん</span>
            </div>
            <div class="bubble-text">
              書類作成の効率化はもちろんですが、僕が一番やりたいのは「考える業務」にAIを活かすこと。法令の解釈やクライアントへの提案をAIと壁打ちしながら磨いていく文化をつくりたいですね。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              しゅうへいさん、ありがとう！士業のDXがどう進んでいくか、すごく楽しみだね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647438/shuheinumazawa.png" alt="しゅうへいさん"
                  onerror="this.onerror=null;this.src='https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png';">
