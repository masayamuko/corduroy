---
import Layout from '../../layouts/Layout.astro';

const title = "「できること」と「やりたいこと」が重なった日 —— たかろーさんと世界の教育チャンネルの裏側｜株式会社コールテン";
const description = "動画制作のプロが、子ども教育への思いをAIの力で形にし始めた。フィンランドの教育哲学をショート動画にするプロジェクト「世界の教育チャンネル」の裏側を、たかろーさんに聞きました。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/tkr-interview-education/"
  ogUrl="https://www.corduroy.co.jp/blog/tkr-interview-education/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/tkr-interview-education/#article",
    "url": "https://www.corduroy.co.jp/blog/tkr-interview-education/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/tkr-interview-education/"
    },
    "headline": "「できること」と「やりたいこと」が重なった日 —— たかろーさんと世界の教育チャンネルの裏側",
    "datePublished": "2026-03-25",
    "dateModified": "2026-03-25",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "中野たかろー",
      "jobTitle": "フリーランス ウェブクリエイター"
    },
    "description": "動画制作のプロが、子ども教育への思いをAIの力で形にし始めた。フィンランドの教育哲学をショート動画にするプロジェクト「世界の教育チャンネル」の裏側を、たかろーさんに聞きました。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "たかろーさん×世界の教育チャンネル" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "AIで教育コンテンツを作れますか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "台本の作成、キャラクターの音声生成、動画の構成設計までAIで支援できます。ただし、AI任せにするのではなく、テーマの選定や表現のトーンなど「人の判断」が入る設計が品質の鍵になります。"
        }
      },
      {
        "@type": "Question",
        "name": "AIで動画を量産するにはどうすればいいですか？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "1本作れることと、量産できることは別です。キャラ設定、素材セット、構成ルール、テロップ仕様などの「設計図」を先に定義し、AIが参照できる形にしておくことが重要です。たかろーさんのプロジェクトでもこの設計図づくりが転機になりました。"
        }
      },
      {
        "@type": "Question",
        "name": "動画制作とAI活用を組み合わせるメリットは？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "動画制作では品質調整、分析、改善の反復が多く、AI活用の余地が大きい領域です。たかろーさんの場合、制作で生計を立てながら、AIで時間を捻出し、本当にやりたい子ども教育の発信に充てるという循環を目指しています。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png"
              alt="たかろーさん"></div>
        </div>
        <h1>「できること」と「やりたいこと」が<br>重なった日<br><span class="h1-sub">たかろーさんと世界の教育チャンネルの裏側</span></h1>
        <div class="result-badges">
          <span class="result-badge">世界の教育を動画に</span>
          <span class="result-badge">AI×動画で量産設計</span>
          <span class="result-badge">子ども支援への接続</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">動画編集 / AI活用 / 教育コンテンツ</span>
        </div>
        <p>
          フリーランスで動画やWeb制作を手がけるたかろーさん。「仕事としてできること」と「本当にやりたいこと」の間にはいつも距離があった。世界各国の教育を紹介するショート動画プロジェクトが、その距離を縮め始めている。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_wave.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今回は、たかろーさんと一緒に進めている「世界の教育チャンネル」について聞いていくよ。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png"
                alt="たかろーさん">
            <h3 style="margin:2px 0 4px;">たかろーさん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              動画編集・Web制作・カメラマンとして活躍するフリーランス。子どもとの関わりに強い思いがあり、「世界の教育チャンネル」の企画・制作を担当。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問としてプロジェクトの設計・制作フロー構築を支援しています。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入: in medias res -->
        <div class="narrative">
          <p>
            フィンランドには「ラスナオロ」という言葉がある。<br>
            直訳すると「そばにいること」。子どものそばに大人がいて、見守り、必要な時だけ手を差し伸べる。教え込むのではなく、子ども自身の力を信じるという考え方だ。
          </p>
          <p>
            その言葉を45秒のショート動画にする。文字で読めば簡単そうだが、これを「見て理解できる」動画にするには、構成、テロップ、音声、間——すべての設計が問われる。
          </p>
          <p>
            たかろーさんが手がける「世界の教育チャンネル」は、世界各国の教育哲学をAIの力を借りてショート動画にするプロジェクト。第1話のフィンランド編が完成し、量産に向けた設計図づくりの真っ最中だ。
          </p>
          <p>
            動画制作のプロが、なぜ教育コンテンツに向かうのか。AIはそこでどう使われているのか。テトくんが聞いた。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== 「教育」に向かう理由 ===== -->
          <div class="section-label">動画制作のプロが「教育」に向かう理由</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              たかろーさんは動画もWebも写真もできるじゃん。いろんなことできるのに、なんで「教育」なの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              制作の仕事は「求められるからできる」領域なんですよ。でも子どもと関わるとか、コーチング的な関わりって「思いが乗る」領域で。将来的には小中学生に低負担で関われる支援をやりたいんです。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              なるほど。でも「教育に関わりたい」だけだと、具体的に何をすればいいか悩みそうだよね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              そうなんです。そこでコールテンさんと話していく中で出てきたのが「世界の教育チャンネル」の企画で。世界中の教育の考え方をショート動画で紹介するっていう。自分の動画スキルと、教育への興味が初めて重なったなと。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>写真・動画・Webは「求められるからできる」領域。子ども支援やコーチングは「思いが乗る」領域——たかろーさんの中には、明確な線引きがある。制作で生計を立てながら、そこへ向かうための時間をどうつくるか。この問いに、AIとの出会いが一つの答えを出し始めていた。</p>
            <p>そして世界の教育チャンネルは、その二つの領域がようやく重なったプロジェクトだ。</p>
          </div>

          <!-- ===== AIで動画を作るということ ===== -->
          <div class="section-label">AIで教育動画を作るということ</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              実際にAIを使って動画をどうやって作ってるの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              まずAIで台本を作って、そこからキャラクターのセリフを生成して、音声をつけて、尺に合わせて調整する。テーマごとにリサーチもAIに手伝ってもらってます。フィンランドの「ラスナオロ」ってどういう概念？みたいなところから。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              おお！台本もリサーチも音声もAI？ほぼ全工程じゃん。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              そう見えるかもしれないけど、AIに全部任せるとうまくいかないんですよ。テロップの切り替わりタイミングとか、音声の印象とか、最後は人間が調整しないと見られるものにならない。冒頭3秒のフックとかは特に。
            </div>
          </div>

          <!-- Feature Highlight: 制作フロー -->
          <div class="cycle-diagram">
            <div class="cycle-step">AIでリサーチ</div>
            <div class="cycle-step">台本生成</div>
            <div class="cycle-step">音声・素材生成</div>
            <div class="cycle-step">人の手で仕上げ</div>
          </div>

          <div class="voice-note">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                  style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);"
                  alt="向">
              <span class="note-name" style="margin:0">担当 向より</span>
            </div>
            動画制作には「品質調整、分析、改善の反復」が多く、AIとの相性が良い領域です。ただしAI任せにすると後から修正不能になりやすい。仕組みを理解しながら、人の判断を残す設計が大切です。
          </div>

          <!-- ===== 「1本作れる」と「量産できる」は違う ===== -->
          <div class="section-label">「1本作れる」と「量産できる」は全然違う</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              1本目のフィンランド編はできたんだよね？そこからどうだった？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              1本作れたのは嬉しかったんですけど、同じ品質で2本目以降を作ろうとすると、手順がわからなくなるんですよ。1本目で感覚的にやった部分が多くて。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              あ〜、それって制作あるあるかも。1回できた≠毎回できる、みたいな。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              まさにそれです。キャラの設定、使う素材、音声の選び方、テロップのルール——こういう「設計図」を先に決めておかないと、毎回ゼロから考え直すことになる。そこがコールテンさんと一緒に整理している部分ですね。
            </div>
          </div>

          <!-- プロンプトボックス: 設計図の要素 -->
          <div class="prompt-box">
            <span class="prompt-label">量産に必要な「設計図」</span>
            <p style="margin:0; font-weight:700; color:var(--ink);">キャラ設定 / 素材セット / 音声選定 / 構成ルール / テロップ仕様 / 画面切り替え</p>
            <p style="margin:8px 0 0; font-size:13px; color:var(--text-light);">※これらをAIが参照できる形で先に定義しておくことで、2本目以降の再現性が上がる。</p>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>Web制作の世界では「デザインシステム」と呼ばれる考え方がある。色、フォント、ボタンのサイズ——ルールを決めておけば、誰が作っても一定の品質が保たれる。</p>
            <p>たかろーさんがぶつかった壁は、まさにこれと同じだ。1本の動画を気合いで作ることはできる。でも10本、20本と続けるには、「設計図」が先にないと破綻する。AIを使う場合はなおさらだ。AIが何を参照して出力しているかを把握していないと、品質がブレる。</p>
            <p>「AIに丸投げすると後で修正不能になりやすい」——コールテンとの対話の中で、たかろーさんはこの原則を体感していった。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            1本作れることと、量産できることは別。<br>先に「設計図」を作るのが遠回りに見えて一番の近道だった。
          </blockquote>

          <!-- ===== AIの「中身」を理解するということ ===== -->
          <div class="section-label">AIの「中身」を理解するということ</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              制作だけじゃなくて、AIの仕組み自体にも興味あるの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              使い始めた頃はChatGPTを検索代わりに使うだけだったんですけど、講座を受けてからは「AIがどう認識して、何を参照して出力しているか」を気にするようになりました。それがわかると、的外れな回答が返ってきた時に「あ、これは参照先が違うんだな」って原因がわかるんです。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/e_background_removal/f_webp,q_auto:eco/corduroy/characters/teto/teto_microphone.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              なるほど〜。使い方だけじゃなくて、裏側がわかると扱い方が変わるんだね。
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764647437/takaro_freelance.png" alt="たかろーさん">
              <span class="name-tag">たかろーさん</span>
            </div>
            <div class="bubble-text">
              動画の制作フローも同じで、どのファイルが何を担ってるか、プロジェクトの構造を理解しないと、AIにうまく指示が出せない。「わからないことは都度AIに仕組みを聞いて、理解した内容をファイルにまとめる」っていうやり方が今は一番しっくりきてます。
            </div>
          </div>

          <!-- Feature Highlight: 学習スタイル -->
          <div class="card" style="background:var(--green); border:none; color:#eee; padding:20px; font-family:monospace; margin:10px 0;">
            <div style="color:var(--line-strong); margin-bottom:10px; font-size:12px;">// たかろーさんの学習スタイル</div>
            <p style="margin:0 0 10px 0; color:#eee;">たかろー：「このフォルダ構成ってどういう仕組みで動いてるの？」</p>
            <p style="color:var(--mint); margin:0;">
              AI：「srcフォルダの中にエピソードごとのディレクトリがあり、各シーンの台本・音声・素材を格納しています。buildコマンドを実行すると、この構成から自動で動画が生成されます。」</p>
          </div>

