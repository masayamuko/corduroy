---
import Layout from '../../layouts/Layout.astro';

// ブログ記事リスト（新しい順）
// 新しい記事を追加するときは、このリストの先頭に追加し、
// 対応する個別ページ（src/pages/blog/<slug>.astro）も必要なら作成する。
const categories = ['すべて', 'お知らせ', '活動報告', 'パートナー自慢', '子ども支援', 'AI活用', '会社情報', 'その他'];

const posts = [
  {
    slug: 'smf-partner-pride',
    date: '2026-04-23',
    category: 'パートナー自慢',
    title: 'スマイリーフラワーズを本気で応援する理由',
    excerpt: '代表の原体験、社会的養護の子どもたちを留学に送り出すという志、そして現場で本気で向き合い続ける姿勢。コールテンがスマイリーフラワーズを全力で応援したい理由を書きました。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/v1776929848/smileyflowers_logo.png',
    external: false,
  },
  {
    slug: 'nks-kashiko-instructor',
    date: '2026-04-21',
    category: ['活動報告', '子ども支援'],
    title: '一般社団法人日本こども色彩協会のkashiko色彩インストラクター認定講座を修了しました',
    excerpt: '5年ぶりの連続講座。色彩を通じて「じぶん色」を引き出すkashikoプログラムを学び、学び続けることの大切さを再確認しました。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'itoshima-110km-walk',
    date: '2026-04-19',
    category: 'その他',
    title: '糸島三都110キロウォークに参加しました',
    excerpt: 'スマイリーフラワーズさんのチームで糸島三都110キロウォークに挑戦。代表の向はリタイアしたものの、SMFのお二人は見事完歩。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_fill,w_400,h_400,g_auto/v1776922851/corduroy/news/itoshima-110k-walking.jpg',
    external: false,
  },
  {
    slug: 'shu-ai-advisory',
    date: '2026-04-01',
    category: '活動報告',
    title: '行政書士のしゅうへいさんにAI顧問契約をいただきました',
    excerpt: 'しゅう行政書士事務所のしゅうへいさんに、3ヶ月のお試しAI顧問契約をいただきました。一人で仕事をしている方がAIエージェントでチーム化していく第一歩をサポートしています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'asiz-partnership',
    date: '2026-03-16',
    category: '活動報告',
    title: '一般社団法人As iZさんの青少年プログラムにサポートスタッフとして参加しています',
    excerpt: '感情知能（EQ）教育に取り組む一般社団法人As iZさんの青少年支援プログラムに、サポートスタッフとして参加しています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'ohara-partnership',
    date: '2025-12-24',
    category: '活動報告',
    title: '一般社団法人OHRAさんと定期ミーティングを始めました',
    excerpt: '外国人との共生社会に取り組む一般社団法人OHRAさんから、団体内のAI活用や士業の方々への研修についてご相談をいただきました。月1回のミーティングで少しずつAI化を進めています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'tkr-ai-advisory',
    date: '2025-12-24',
    category: '活動報告',
    title: 'フリーランスたかろーさんにAI顧問契約をいただきました',
    excerpt: '動画編集者としてフリーランスで活動するたかろーさんに、AI顧問契約をいただきました。Claude Codeを用いた動画編集やAI活用で、フリーランスとしての業務を便利にするサポートをしています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'smf-partnership',
    date: '2025-12-22',
    category: '活動報告',
    title: 'NPO法人スマイリーフラワーズさんにAI顧問契約をいただきました',
    excerpt: '留学支援と社会的養護に取り組むNPO法人スマイリーフラワーズさんへ、AI顧問としてのサポートを開始しました。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'san-partnership',
    date: '2025-12-01',
    category: '活動報告',
    title: '株式会社スデニアルの佐野さんと定期ミーティングを開始しました',
    excerpt: '2025年12月から株式会社スデニアルの佐野さんと毎週ミーティング。プロマーケター×AI活用で、本当に価値あるものを届けるための協業を模索しています。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
  {
    slug: 'incorporation',
    date: '2025-11-21',
    category: '会社情報',
    title: '株式会社コールテンを設立しました',
    excerpt: 'ChatGPTにコーチングすることから始まったAI活用の旅。その先に会社をつくりました。AIとの関係性を育てる支援を使命に、歩み始めます。',
    thumbnail: 'https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png',
    external: false,
  },
];

const title = "ブログ｜株式会社コールテン";
const description = "コールテンの活動報告やAI活用に関する気づきを発信しています。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/"
  ogUrl="https://www.corduroy.co.jp/blog/"
  ogType="website"
>
  <main>
    <section class="hero">
      <div class="container">
        <div class="fade-up" style="text-align:center;">
          <span class="eyebrow">BLOG</span>
          <h1>ブログ</h1>
        </div>
      </div>
    </section>

    <section class="container" style="padding-top:20px; padding-bottom:120px;">
      <div class="filter-controls fade-up">
        <div class="category-chips">
          {categories.map((cat) => (
            <button type="button" class:list={['chip', { active: cat === 'すべて' }]} data-filter={cat}>{cat}</button>
          ))}
        </div>
        <div class="sort-toggle">
          <button type="button" class="sort-btn active" data-sort="desc">新しい順</button>
          <button type="button" class="sort-btn" data-sort="asc">古い順</button>
        </div>
      </div>
      <a href="/members/about/" class="featured-banner fade-up" data-featured-category="AI活用">
        <div class="featured-banner-inner">
          <div class="featured-banner-text">
            <span class="featured-eyebrow">FEATURED</span>
            <h2 class="featured-title">コールテンの仕事術 — 29名のAI社員と共に。</h2>
            <p class="featured-desc">なぜ1体ではなく29名に分けたのか。Claude Agent SDKの公式機能を活用したAI活用の全容を公開。</p>
            <span class="featured-link">詳しく見る →</span>
          </div>
        </div>
      </a>

      <div class="posts-list fade-up">
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>まだ投稿はありません。</p>
          </div>
        ) : (
          posts.map((post) => (
            <a
              href={post.external ? post.slug : `/blog/${post.slug}`}
              class="post-card"
              data-categories={Array.isArray(post.category) ? post.category.join(',') : post.category}
              data-date={post.date}
              target={post.external ? '_blank' : '_self'}
              rel={post.external ? 'noopener noreferrer' : undefined}
            >
              <div class="post-thumb">
                <img src={post.thumbnail} alt="" width="120" height="120" loading="lazy" />
              </div>
              <div class="post-body">
                <div class="post-meta">
                  <time class="post-date">{post.date}</time>
                  {Array.isArray(post.category)
                    ? post.category.map(cat => <span class="post-cat">{cat}</span>)
                    : <span class="post-cat">{post.category}</span>
                  }
                </div>
                <h2 class="post-title">{post.title}</h2>
                <p class="post-excerpt">{post.excerpt}</p>
                <span class="post-link">続きを読む →</span>
              </div>
            </a>
          ))
        )}
        <div class="filter-empty" style="display:none;">
          <p>該当する記事はありません。</p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    padding: 60px 0 40px;
    background: linear-gradient(180deg, var(--cream) 0%, #f0f7f4 100%);
    text-align: center;
  }
  .eyebrow {
    display: inline-block;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.2em;
    font-size: 12px;
    font-family: "Space Grotesk", sans-serif;
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: clamp(36px, 5vw, 54px);
    margin-bottom: 0;
  }

  .filter-controls {
    max-width: 820px;
    margin: 0 auto 24px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    flex: 1;
  }
  .chip {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-light);
    background: rgba(22,97,78,0.06);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.03em;
    font-family: inherit;
    line-height: inherit;
  }
  .chip:hover {
    background: rgba(22,97,78,0.12);
  }
  .chip.active {
    background: var(--sea);
    color: #fff;
    border-color: var(--sea);
  }
  .chip.active:hover {
    background: var(--sea);
  }
  .sort-toggle {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
    align-self: center;
  }
  .sort-btn {
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-light);
    background: transparent;
    border: 1px solid var(--line);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    line-height: inherit;
  }
  .sort-btn:hover {
    border-color: var(--sea);
    color: var(--sea);
  }
  .sort-btn.active {
    background: var(--sea);
    color: #fff;
    border-color: var(--sea);
  }

  .posts-list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .post-card {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 28px 32px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 10px rgba(5,32,24,0.04);
    transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
    animation: fadeIn 0.3s ease;
  }
  .post-card.filtered-out {
    display: none;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .post-thumb {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 14px;
    overflow: hidden;
    background: var(--cream);
    border: 1px solid var(--line);
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-body {
    flex: 1;
    min-width: 0;
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(5,32,24,0.08);
    border-color: rgba(22,97,78,0.18);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
  }
  .post-date {
    font-family: "Space Grotesk", sans-serif;
    font-size: 13px;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }
  .post-cat {
    display: inline-block;
    background: rgba(22,97,78,0.08);
    color: var(--sea);
    border-radius: 99px;
    padding: 3px 11px;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .post-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.5;
    margin: 0 0 10px;
  }
  .post-excerpt {
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.85;
    margin: 0 0 14px;
  }
  .post-link {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    color: var(--sea);
    font-family: "Space Grotesk", sans-serif;
  }

  .empty-state,
  .filter-empty {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-light);
  }

  /* Featured Banner */
  .featured-banner {
    display: block;
    max-width: 820px;
    margin: 0 auto 28px;
    text-decoration: none;
    color: inherit;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .featured-banner:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(5,32,24,0.12);
  }
  .featured-banner.banner-hidden {
    display: none;
  }
  .featured-banner-inner {
    background: linear-gradient(135deg, var(--sea) 0%, #1a7a60 60%, var(--mint) 100%);
    padding: 40px 40px;
    position: relative;
  }
  .featured-banner-inner::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    background: radial-gradient(circle at 90% 20%, rgba(255,255,255,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .featured-banner-text {
    position: relative;
    z-index: 1;
  }
  .featured-eyebrow {
    display: inline-block;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.2em;
    font-size: 11px;
    font-family: "Space Grotesk", sans-serif;
    margin-bottom: 14px;
    background: rgba(255,255,255,0.15);
    padding: 4px 12px;
    border-radius: 99px;
  }
  .featured-title {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    color: #fff;
    line-height: 1.5;
    margin: 0 0 12px;
  }
  .featured-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    line-height: 1.85;
    margin: 0 0 18px;
    max-width: 560px;
  }
  .featured-link {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    font-family: "Space Grotesk", sans-serif;
    background: rgba(255,255,255,0.15);
    padding: 6px 16px;
    border-radius: 99px;
    transition: background 0.2s ease;
  }
  .featured-banner:hover .featured-link {
    background: rgba(255,255,255,0.25);
  }

  @media (max-width: 640px) {
    .hero { padding: 40px 16px 28px; }
    .filter-controls { flex-direction: column; gap: 12px; }
    .sort-toggle { align-self: flex-start; }
    .post-card { padding: 20px; gap: 16px; }
    .post-thumb { width: 72px; height: 72px; border-radius: 10px; }
    .post-title { font-size: 17px; }
    .featured-banner-inner { padding: 28px 24px; }
    .featured-title { font-size: 19px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const chips = document.querySelectorAll('.chip[data-filter]');
    const sortBtns = document.querySelectorAll('.sort-btn[data-sort]');
    const postsList = document.querySelector('.posts-list');
    const cards = document.querySelectorAll('.post-card[data-categories]');
    const emptyMsg = document.querySelector('.filter-empty');
    const featuredBanner = document.querySelector('.featured-banner[data-featured-category]');
    let activeCategory = 'すべて';
    let sortOrder = 'desc';

    function updateBanner() {
      if (!featuredBanner) return;
      const bannerCat = featuredBanner.dataset.featuredCategory;
      if (activeCategory === 'すべて' || activeCategory === bannerCat) {
        featuredBanner.classList.remove('banner-hidden');
      } else {
        featuredBanner.classList.add('banner-hidden');
      }
    }

    function applyFilter() {
      let visibleCount = 0;
      cards.forEach(card => {
        if (activeCategory === 'すべて') {
          card.classList.remove('filtered-out');
          visibleCount++;
        } else {
          const cats = card.dataset.categories.split(',');
          if (cats.includes(activeCategory)) {
            card.classList.remove('filtered-out');
            visibleCount++;
          } else {
            card.classList.add('filtered-out');
          }
        }
      });
      if (emptyMsg) {
        emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
      }
    }

    function applySort() {
      const sorted = [...cards].sort((a, b) => {
        const da = a.dataset.date;
        const db = b.dataset.date;
        return sortOrder === 'desc' ? db.localeCompare(da) : da.localeCompare(db);
      });
      sorted.forEach(card => postsList.appendChild(card));
      if (emptyMsg) postsList.appendChild(emptyMsg);
    }

    function update() {
      applySort();
      applyFilter();
      updateBanner();
    }

    function updateAria() {
      chips.forEach(c => c.setAttribute('aria-pressed', c.classList.contains('active')));
      sortBtns.forEach(b => b.setAttribute('aria-pressed', b.classList.contains('active')));
    }

    chips.forEach(chip => {
      chip.setAttribute('aria-pressed', chip.classList.contains('active'));
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeCategory = chip.dataset.filter;
        update();
        updateAria();
      });
    });

    sortBtns.forEach(btn => {
      btn.setAttribute('aria-pressed', btn.classList.contains('active'));
      btn.addEventListener('click', () => {
        sortBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        sortOrder = btn.dataset.sort;
        update();
        updateAria();
      });
    });
  });
</script>
