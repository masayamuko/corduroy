---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/"
  ogUrl="https://www.corduroy.co.jp/blog/"
  ogType="website"
>
  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/"},
        {"@type": "ListItem", "position": 2, "name": "ブログ"}
      ]
    }
  </script>

  <main>
    <section class="hero">
      <div class="container">
        <div class="fade-up" style="text-align:center;">
          <span class="eyebrow">BLOG</span>
          <h1>ブログ</h1>
        </div>
      </div>
    </section>

    <section class="container" style="padding-top:20px; padding-bottom:120px;">
      <div class="filter-controls fade-up">
        <div class="category-chips">
          {categories.map((cat) => (
            <button type="button" class:list={['chip', { active: cat === 'すべて' }]} data-filter={cat}>{cat}</button>
          ))}
        </div>
        <div class="sort-toggle">
          <button type="button" class="sort-btn active" data-sort="desc">新しい順</button>
          <button type="button" class="sort-btn" data-sort="asc">古い順</button>
        </div>
      </div>
      <div class="posts-list fade-up">
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>まだ投稿はありません。</p>
          </div>
        ) : (
          posts.map((post) => (
            <a
              href={post.external ? post.slug : (post.slug.startsWith('/') ? post.slug : `/blog/${post.slug}/`)}
              class:list={['post-card', { featured: post.featured }]}
              data-categories={Array.isArray(post.category) ? post.category.join(',') : post.category}
              data-date={post.date}
              target={post.external ? '_blank' : '_self'}
              rel={post.external ? 'noopener noreferrer' : undefined}
            >
              {post.featured && <span class="recommend-badge">おすすめ</span>}
              <div class="post-thumb">
                <img src={post.thumbnail} alt="" width="120" height="120" loading="lazy" />
              </div>
              <div class="post-body">
                <div class="post-meta">
                  <time class="post-date">{post.date}</time>
                  {Array.isArray(post.category)
                    ? post.category.map(cat => <span class="post-cat">{cat}</span>)
                    : <span class="post-cat">{post.category}</span>
                  }
                </div>
                <h2 class="post-title">{post.title}</h2>
                <p class="post-excerpt">{post.excerpt}</p>
                <span class="post-link">続きを読む →</span>
              </div>
            </a>
          ))
        )}
        <div class="filter-empty" style="display:none;">
          <p>該当する記事はありません。</p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    padding: 60px 0 40px;
    background: linear-gradient(180deg, var(--cream) 0%, #f0f7f4 100%);
    text-align: center;
  }
  .eyebrow {
    display: inline-block;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.2em;
    font-size: 12px;
    font-family: "Space Grotesk", sans-serif;
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: clamp(36px, 5vw, 54px);
    margin-bottom: 0;
  }

  .filter-controls {
    max-width: 820px;
    margin: 0 auto 24px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    flex: 1;
  }
  .chip {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-light);
    background: rgba(22,97,78,0.06);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.03em;
    font-family: inherit;
    line-height: inherit;
  }
  .chip:hover {
    background: rgba(22,97,78,0.12);
  }
  .chip.active {
    background: var(--sea);
    color: #fff;
    border-color: var(--sea);
  }
  .chip.active:hover {
    background: var(--sea);
  }
  .sort-toggle {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
    align-self: center;
  }
  .sort-btn {
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-light);
    background: transparent;
    border: 1px solid var(--line);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
    line-height: inherit;
  }
  .sort-btn:hover {
    border-color: var(--sea);
    color: var(--sea);
  }
  .sort-btn.active {
    background: var(--sea);
    color: #fff;
    border-color: var(--sea);
  }

  .posts-list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .post-card {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 24px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 28px 32px;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 10px rgba(5,32,24,0.04);
    transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
    animation: fadeIn 0.3s ease;
  }
  .post-card.filtered-out {
    display: none;
  }
  /* Featured (おすすめ) card — green inverted */
  .post-card.featured {
    background: var(--sea);
    border-color: var(--sea);
    color: #fff;
    box-shadow: 0 4px 18px rgba(22,97,78,0.18);
  }
  .post-card.featured:hover {
    border-color: var(--sea);
    box-shadow: 0 14px 32px rgba(22,97,78,0.28);
  }
  .post-card.featured .post-thumb {
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.08);
  }
  .post-card.featured .post-date {
    color: rgba(255,255,255,0.85);
  }
  .post-card.featured .post-cat {
    background: rgba(255,255,255,0.18);
    color: #fff;
  }
  .post-card.featured .post-title {
    color: #fff;
  }
  .post-card.featured .post-excerpt {
    color: rgba(255,255,255,0.92);
  }
  .post-card.featured .post-link {
    color: var(--accent);
  }
  .recommend-badge {
    position: absolute;
