---
import Layout from '../../layouts/Layout.astro';

const title = "行政書士ネットワークで外国人共生を支える —— OHARAの挑戦｜株式会社コールテン";
const description = "インドネシア人材の適正受け入れを目指す行政書士ネットワーク「OHARA」。パートナー制の設計、口コミ重視の広がり方、将来の視察ツアー構想まで、代表の梅田さんに聞きました。";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://www.corduroy.co.jp/blog/ohara-interview-foreign-coexistence/"
  ogUrl="https://www.corduroy.co.jp/blog/ohara-interview-foreign-coexistence/"
  ogImage="https://www.corduroy.co.jp/assets/images/ogp.png"
  ogType="article"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": "https://www.corduroy.co.jp/blog/ohara-interview-foreign-coexistence/#article",
    "url": "https://www.corduroy.co.jp/blog/ohara-interview-foreign-coexistence/",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://www.corduroy.co.jp/blog/ohara-interview-foreign-coexistence/"
    },
    "headline": "行政書士ネットワークで外国人共生を支える —— OHARAの挑戦",
    "datePublished": "2026-02-20",
    "dateModified": "2026-02-20",
    "image": "https://www.corduroy.co.jp/assets/images/ogp.png",
    "author": {
      "@type": "Person",
      "name": "向 雅也",
      "url": "https://www.corduroy.co.jp/members/masaya/"
    },
    "publisher": {
      "@id": "https://www.corduroy.co.jp/#organization"
    },
    "about": {
      "@type": "Person",
      "name": "梅田",
      "jobTitle": "代表",
      "worksFor": {
        "@type": "Organization",
        "name": "一般社団法人OHARA"
      }
    },
    "description": "インドネシア人材の適正受け入れを目指す行政書士ネットワーク「OHARA」。パートナー制の設計、口コミ重視の広がり方、将来の視察ツアー構想まで、代表の梅田さんに聞きました。"
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://www.corduroy.co.jp/" },
      { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://www.corduroy.co.jp/blog/" },
      { "@type": "ListItem", "position": 3, "name": "OHARAインタビュー — 外国人共生" }
    ]
  }
  </script>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "外国人人材の適正受け入れとは？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "企業側の労働環境と外国人側の在留資格・生活支援の両面を整え、双方が安心できる受け入れ体制を作ることです。OHARAでは基準を満たした行政書士がパートナーとして関わることで、質の高い受け入れを実現しています。"
        }
      },
      {
        "@type": "Question",
        "name": "行政書士の役割は？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "在留資格の申請・更新手続きだけでなく、企業と外国人の橋渡し役として、受け入れ体制の設計やトラブル防止のアドバイスも行います。OHARAでは行政書士が社会インフラの一部として機能することを目指しています。"
        }
      },
      {
        "@type": "Question",
        "name": "OHARAに参加するには？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "OHARAのパートナー行政書士になるには、一定の基準を満たす必要があります。既存パートナーからの紹介や説明会を通じて参加を検討できます。まずはOHARAの公式ページからお問い合わせください。"
        }
      }
    ]
  }
  </script>

  <main>
    <!-- ===== ヒーロー ===== -->
    <section class="hero">
      <div class="container hero-inner fade-up">
        <div class="avatar-frame">
          <div class="avatar-lg"><img
              src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png"
              alt="梅田さん"></div>
        </div>
        <h1>行政書士ネットワークで<br>外国人共生を支える<br><span class="h1-sub">OHARAの挑戦</span></h1>
        <div class="result-badges">
          <span class="result-badge">外国人共生</span>
          <span class="result-badge">行政書士</span>
          <span class="result-badge">インドネシア</span>
        </div>
        <div class="meta">
          <span class="tag">インタビュー</span>
          <span class="pill">社会課題 / ネットワーク</span>
        </div>
        <p>
          インドネシア人材の適正受け入れを支える行政書士ネットワーク「OHARA」。なぜ行政書士が社会インフラになるのか、代表の梅田さんにその挑戦を聞きました。
        </p>
      </div>
    </section>

    <!-- ===== 登場人物紹介 ===== -->
    <section class="intro-section">
      <div class="container">
        <div class="card big-bubble" style="margin-bottom:16px;">
          <div class="dialogue">
            <div class="bubble teto">
              <div class="bubble-avatar">
                <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png"
                    alt="盤上テトくん">
                <span class="name-tag">盤上テト</span>
              </div>
              <div class="bubble-text">
                広報担当のテトです！<br>今日は梅田さんに、外国人共生への想いを聞いていくよ。
              </div>
            </div>
          </div>
        </div>
        <div class="character-grid cols-2">
          <div class="character-card">
            <span class="character-role"
                style="background:#f4f1ff; border-color:#e2dcfa; color:#1f2440;">クライアントさん</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png"
                alt="梅田さん">
            <h3 style="margin:2px 0 4px;">梅田さん</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">
              一般社団法人OHARA代表。インドネシア人材の適正受け入れを推進する行政書士ネットワークを運営。</p>
          </div>
          <div class="character-card">
            <span class="character-role"
                style="background:#fff7ea; border-color:#f2ddbf; color:#3a2c15;">サポート担当</span>
            <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
                alt="向 雅也">
            <h3 style="margin:2px 0 4px;">向 雅也</h3>
            <p class="mini" style="margin:0; color:var(--text-light);">AI顧問として組織運営を伴走サポート。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 本編 ===== -->
    <section class="container">
      <div class="card dialogue-flow fade-up">

        <!-- ナラティブ導入 -->
        <div class="narrative">
          <p>
            「信頼できる行政書士をつなぐだけで、受け入れの質は変わる」——梅田さんの言葉には確信があった。
          </p>
          <p>
            外国人材の受け入れは制度も複雑で、関わる人も多い。だからこそ「誰に頼むか」が質を左右する。OHARAは、その「誰」を保証するネットワークだ。
          </p>
        </div>

        <div class="dialogue">

          <!-- ===== なぜ行政書士ネットワークか ===== -->
          <div class="section-label">なぜ行政書士ネットワークか</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              なぜ行政書士同士でネットワークを作ろうと思ったの？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              外国人を受け入れたい企業が増えてるんですが、手続きの質がバラバラなんです。ちゃんとした行政書士に頼めば問題ないのに、そうじゃないケースも多い。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              インドネシア人材に特化しているのはなぜ？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              インドネシアは人口も多いし、日本への就労希望者も増えている。でも受け入れの仕組みが追いついていない。まずは一つの国に集中して、モデルケースを作りたいんです。
            </div>
          </div>

          <!-- ===== 適正な受け入れとは ===== -->
          <div class="section-label">適正な受け入れとは</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              「適正な受け入れ」って、具体的にはどういうこと？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              企業側の労働環境がちゃんとしていること、外国人側の在留資格が適正に取れていること、生活面のサポートがあること。この3つが揃って初めて「適正」だと思っています。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              パートナー制にしているのは、その質を担保するため？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              そうです。基準を設けて、更新制にしている。「OHARAのパートナー」という看板が信頼の証になるようにしたいんです。
            </div>
          </div>

          <!-- ===== 双方に安心を ===== -->
          <div class="section-label">双方に安心を届ける</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              企業側にとってのメリットは？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              「この行政書士に頼めば大丈夫」と分かること。受け入れのトラブルって、最初の手続きの質で決まることが多いので。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              広がり方としては口コミ中心なんだよね？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              はい。信頼がベースの仕事なので、広告で急に広げるより、一件ずつ実績を積む方が合っている。紹介してもらえるような仕事をし続けることが一番の営業です。
            </div>
          </div>

          <!-- ナラティブ挿入 -->
          <div class="narrative-inline">
            <p>梅田さんが描くのは「行政書士が社会インフラになる未来」だ。外国人材の受け入れが増える中で、信頼できる専門家のネットワークは社会全体の安心につながる。小さく始めて、口コミで広げる。派手さはないが、確実な一歩だ。</p>
          </div>

          <!-- ===== プルクオート ===== -->
          <blockquote class="pull-quote">
            「信頼できる行政書士をつなぐだけで、<br>受け入れの質は変わる」
          </blockquote>

          <!-- ===== 将来の構想 ===== -->
          <div class="section-label">将来の構想</div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              将来的にはどんな展開を考えてる？
            </div>
          </div>
          <div class="bubble right">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/c_pad,w_400,h_400,b_white/v1776924003/corduroy/brand/logo-square.png" alt="梅田さん">
              <span class="name-tag">梅田さん</span>
            </div>
            <div class="bubble-text">
              インドネシアへの視察ツアーを企画したいですね。現地の送り出し機関を見て、パートナーの行政書士が直接関係を作れる場を。やっぱり顔を合わせると信頼の深さが違うので。
            </div>
          </div>

          <div class="bubble teto">
            <div class="bubble-avatar">
              <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1764691164/TETO_cwicnz.png" alt="盤上テトくん">
              <span class="name-tag">盤上テト</span>
            </div>
            <div class="bubble-text">
              梅田さん、ありがとうございました！OHARAの挑戦、応援してるよ。
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 担当コメント -->
    <section class="container" style="padding-top:40px; padding-bottom:40px;">
      <div class="voice-note fade-up" style="max-width:800px; margin:0 auto;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <img src="https://res.cloudinary.com/dg3mdcuju/image/upload/v1765686550/Facebook_Image_20_usvjlj.jpg"
              style="width:36px;height:36px;border-radius:50%;object-fit:cover;box-shadow:0 2px 5px rgba(0,0,0,0.1);"
              alt="向">
          <span class="note-name" style="margin:0">担当 向より</span>
        </div>
        梅田さんの話を聞いていて感じるのは「信頼」への徹底的なこだわりです。パートナー基準を設け、更新制にし、口コミで広げる。派手さはないけれど、外国人材の受け入れという領域では、この地道さこそが最も大事だと思います。行政書士が社会インフラになる未来、一緒に作っていきたいですね。
      </div>
    </section>

    <!-- FAQ -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <div class="faq-section fade-up" style="max-width:760px; margin:0 auto;">
        <h2 class="faq-heading">よくある質問</h2>
        <details class="faq-item">
          <summary>外国人人材の適正受け入れとは？</summary>
          <p>企業側の労働環境と外国人側の在留資格・生活支援の両面を整え、双方が安心できる受け入れ体制を作ることです。OHARAでは基準を満たした行政書士がパートナーとして関わることで、質の高い受け入れを実現しています。</p>
        </details>
        <details class="faq-item">
          <summary>行政書士の役割は？</summary>
          <p>在留資格の申請・更新手続きだけでなく、企業と外国人の橋渡し役として、受け入れ体制の設計やトラブル防止のアドバイスも行います。OHARAでは行政書士が社会インフラの一部として機能することを目指しています。</p>
        </details>
        <details class="faq-item">
          <summary>OHARAに参加するには？</summary>
          <p>OHARAのパートナー行政書士になるには、一定の基準を満たす必要があります。既存パートナーからの紹介や説明会を通じて参加を検討できます。まずはOHARAの公式ページからお問い合わせください。</p>
        </details>
      </div>
    </section>

    <!-- 関連リンク -->
    <section class="container" style="padding-top:0; padding-bottom:40px;">
      <aside class="related-links fade-up" style="max-width:720px; margin:0 auto; padding:24px; background:rgba(22,97,78,0.04); border-radius:12px;">
        <p style="font-weight:600; font-size:14px; color:var(--sea); margin-bottom:12px;">関連コンテンツ</p>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
          <li><a href="/blog/ohara-interview-ai-advisor/" style="font-size:13px; color:var(--sea);">OHARA AI顧問インタビュー →</a></li>
          <li><a href="/clients/ohra/" style="font-size:13px; color:var(--sea);">OHARAの記事一覧 →</a></li>
          <li><a href="/services/advisory/" style="font-size:13px; color:var(--sea);">AI顧問サービスについて →</a></li>
        </ul>
      </aside>
    </section>

    <!-- CTA -->
    <section id="contact" class="container" style="padding-top:0; padding-bottom:100px;">
      <div class="card cta-card fade-up" style="max-width:720px;margin:0 auto;text-align:center">
        <h3>外国人共生の仕組みづくりを支援します</h3>
        <p class="mini" style="line-height:1.8;margin-top:12px;color:var(--text-light);">
          コールテンは、組織の立ち上げから運営基盤の整備まで伴走します。<br>
          まずはお気軽にご相談ください。
        </p>
        <div style="margin-top:16px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap; align-items:center;">
          <a class="btn" href="/services/advisory/">AI顧問サービスの詳細</a>
          <a class="btn secondary" href="/blog/">ブログ一覧に戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
    .hero { padding: 160px 0 32px; text-align: center; background: transparent; }
    .intro-section { padding-top: 0; margin-top: 0; }
    .hero-inner { display: flex; flex-direction: column; align-items: center; gap: 24px; max-width: 800px; margin: 0 auto; }
    .h1-sub { font-size: clamp(18px, 2.5vw, 24px); font-weight: 600; display: block; margin-top: 8px; color: var(--text-light); }
    .meta { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: center; margin-top: 24px; }
    .tag { display: inline-block; padding: 8px 16px; border-radius: 100px; background: var(--mint); color: var(--sea); font-weight: 700; font-size: 13px; border: 1px solid var(--line); }
    .pill { display: inline-block; padding: 8px 16px; border-radius: 100px; background: #fff; border: 1px solid var(--line); font-weight: 700; font-size: 13px; color: var(--text-light); }
