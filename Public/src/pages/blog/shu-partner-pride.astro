  .article-head {
    max-width: 760px;
    margin: 0 auto 40px;
    text-align: left;
  }
  .article-head .meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
