  }
  .article-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 40px 48px;
    box-shadow: 0 4px 20px rgba(5,32,24,0.04);
    max-width: 720px;
    margin: 0 auto;
  }
  .article-card p {
    font-size: 15.5px;
    line-height: 2.1;
    color: var(--text);
    margin: 0 0 24px;
  }
  .article-card p:last-child { margin-bottom: 0; }
  .article-card h2 {
    font-size: 22px;
    margin: 48px 0 16px;
    padding-left: 14px;
    border-left: 4px solid var(--sea);
    color: var(--ink);
    line-height: 1.5;
  }
  .article-card h2:first-of-type { margin-top: 32px; }
  .article-figure {
    margin: 32px 0;
    text-align: center;
  }
  .article-figure img {
    display: block;
    width: 180px;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
    border-radius: 50%;
    box-shadow: 0 8px 22px rgba(5,32,24,0.10);
    background: #fff;
  }

  .article-foot {
    max-width: 760px;
    margin: 40px auto 0;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .article-card { padding: 28px 24px; }
    .article-card p { font-size: 14.5px; line-height: 1.95; }
    .article-figure img { width: 150px; }
  }
</style>
