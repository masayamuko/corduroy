{
  "buildCommand": "cd Public && npm install && npm run build",
  "outputDirectory": "Public/dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/legal/privacy",
      "permanent": true
    },
    {
      "source": "/tokushoho.html",
      "destination": "/legal/tokushoho",
      "permanent": true
    },
    {
      "source": "/tokushoho",
      "destination": "/legal/tokushoho",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/legal/privacy",
      "permanent": true
    },
    {
      "source": "/voice-takaro.html",
      "destination": "/voices/takaro",
      "permanent": true
    },
    {
      "source": "/voice-nakano.html",
      "destination": "/voices/takaro",
      "permanent": true
    },
    {
      "source": "/service-study.html",
      "destination": "/services/study/",
      "permanent": true
    },
    {
      "source": "/service-system.html",
      "destination": "/services/system/",
      "permanent": true
    },
    {
      "source": "/service-study",
      "destination": "/services/study/",
      "permanent": true
    },
    {
      "source": "/service-advisory.html",
      "destination": "/services/advisory/",
      "permanent": true
    }
  ]
